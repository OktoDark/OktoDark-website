{% extends 'emails/layout.html.twig' %}

{% block title %}{{ 'email.login_alert.subject'|trans({}, 'emails') }} – {{ settings.getSiteName() }}{% endblock %}

{% block badge %}
    <div class="badge">{{ 'email.badge.security_alert'|trans({}, 'emails') }}</div>
{% endblock %}

{% block extra_styles %}
    .meta {
        margin: 24px 0;
        padding: 20px;
        border-radius: 10px;
        background: rgba(15,23,42,0.5);
        border: 1px solid #1f2937;
    }
    .meta-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-bottom: 8px;
    }
    .meta-row:last-child {
        margin-bottom: 0;
    }
    .meta-label {
        color: #6b7280;
    }
    .meta-value {
        color: #e5e7eb;
        font-weight: 500;
        text-align: right;
    }
{% endblock %}

{% block content %}
    <h1>{{ 'email.login_alert.h1'|trans({}, 'emails') }}</h1>
    <p>{{ 'email.greeting'|trans({'%name%': user.username}, 'emails') }}</p>
    <p>{{ 'email.login_alert.body_intro'|trans({'%siteName%': '<strong>' ~ settings.getSiteName() ~ '</strong>'}, 'emails')|raw }}</p>

    <div class="meta">
        <div class="meta-row">
            <span class="meta-label">{{ 'email.details.time'|trans({}, 'emails') }} </span>
            <span class="meta-value">{{ loggedAt|date('Y-m-d H:i:s') }}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">{{ 'email.details.ip'|trans({}, 'emails') }} </span>
            <span class="meta-value">{{ ip }}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">{{ 'email.details.location'|trans({}, 'emails') }} </span>
            <span class="meta-value">{{ location ?? 'Unknown' }}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">{{ 'email.details.device'|trans({}, 'emails') }} </span>
            <span class="meta-value">{{ userAgent }}</span>
        </div>
    </div>

    <p>{{ 'email.login_alert.advice_ok'|trans({}, 'emails') }}</p>
    <p>{{ 'email.login_alert.advice_not'|trans({}, 'emails')|raw }}</p>

    <div class="cta-container">
        <a href="{{ url('settings_area', { tab: 'security' }) }}" class="cta-button">{{ 'email.login_alert.button'|trans({}, 'emails') }}</a>
    </div>
{% endblock %}

{% block footer %}
    {{ parent() }}
    <p>{{ 'email.login_alert.received_reason'|trans({}, 'emails') }} 
       <a href="{{ url('settings_area', { tab: 'security' }) }}">{{ 'email.login_alert.manage_settings'|trans({}, 'emails') }}</a>
    </p>
{% endblock %}
