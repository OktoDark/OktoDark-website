{% extends 'emails/layout.html.twig' %}

{% block title %}{{ 'email.invite.subject'|trans({}, 'emails') }} – {{ settings.getSiteName() }}{% endblock %}

{% block badge %}
    <div class="badge">{{ 'email.badge.exclusive_invitation'|trans({}, 'emails') }}</div>
{% endblock %}

{% block content %}
    <h1>{{ 'email.invite.h1'|trans({}, 'emails') }}</h1>
    <p>{{ 'email.greeting_general'|trans({}, 'emails') }}</p>
    <p>{{ 'email.invite.body_intro'|trans({'%siteName%': '<strong>' ~ settings.getSiteName() ~ '</strong>'}, 'emails')|raw }}</p>
    
    <p>{{ 'email.invite.claim'|trans({}, 'emails') }}</p>

    <div class="cta-container">
        <a href="{{ url('app_register') }}" class="cta-button">{{ 'email.invite.button'|trans({}, 'emails') }}</a>
    </div>

    <p>{{ 'email.invite.next_steps'|trans({}, 'emails') }}</p>

    <p>{{ 'email.invite.questions'|trans({}, 'emails') }}</p>
    
    <p>{{ 'email.verify.footer'|trans({}, 'emails') }}<br>
    <strong>{{ 'email.team'|trans({'%siteName%': settings.getSiteName()}, 'emails') }}</strong></p>
{% endblock %}
