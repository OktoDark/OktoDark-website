{% extends 'emails/layout.html.twig' %}

{% block title %}{{ 'email.failed_login.subject'|trans({}, 'emails') }} - {{ settings.getSiteName() }}{% endblock %}

{% block badge %}
    <span class="badge">{{ 'email.badge.security_alert'|trans({}, 'emails') }}</span>
{% endblock %}

{% block content %}
    <h1>{{ 'email.failed_login.h1'|trans({}, 'emails') }}</h1>
    <p>{{ 'email.greeting'|trans({'%name%': user.firstName}, 'emails') }}</p>
    <p>{{ 'email.failed_login.body_intro'|trans({'%email%': '<strong>' ~ user.email ~ '</strong>'}, 'emails')|raw }}</p>
    <p>
        {{ 'email.failed_login.body_counts'|trans({'%attempts%': '<strong>' ~ failedAttempts ~ '</strong>', '%date%': '<strong>' ~ alertedAt|date('Y-m-d H:i:s') ~ '</strong>'}, 'emails')|raw }}
    </p>

    <p>{{ 'email.failed_login.details'|trans({}, 'emails') }}</p>
    <ul>
        <li><strong>{{ 'email.details.ip'|trans({}, 'emails') }}</strong> {{ ip }}</li>
        <li><strong>{{ 'email.details.location'|trans({}, 'emails') }}</strong> {{ location ?: 'Unknown' }}</li>
        <li><strong>{{ 'email.details.user_agent'|trans({}, 'emails') }}</strong> {{ userAgent ?: 'Unknown' }}</li>
    </ul>

    <p>
        {{ 'email.failed_login.advice'|trans({}, 'emails') }}
    </p>

    <div class="cta-container">
        <a href="{{ url('settings_area', {'tab': 'security'}) }}" class="cta-button">{{ 'email.failed_login.button'|trans({}, 'emails') }}</a>
    </div>

    <p>{{ 'email.failed_login.footer_sign'|trans({}, 'emails') }}</p>
    <p>{{ 'email.team'|trans({'%siteName%': settings.getSiteName()}, 'emails') }}</p>
{% endblock %}
