{% extends 'emails/layout.html.twig' %}

{% block title %}{{ 'email.login_code.subject'|trans({}, 'emails') }} – {{ settings.getSiteName() }}{% endblock %}

{% block badge %}
    <div class="badge">{{ 'email.badge.verification'|trans({}, 'emails') }}</div>
{% endblock %}

{% block extra_styles %}
    .code-container {
        margin: 32px 0;
        padding: 24px;
        border-radius: 12px;
        background: rgba(22,163,74,0.1);
        border: 2px dashed #16a34a;
        text-align: center;
    }
    .code-value {
        font-family: 'Courier New', Courier, monospace;
        font-size: 36px;
        font-weight: 800;
        color: #16a34a;
        letter-spacing: 8px;
        margin: 0;
    }
    .expiry-note {
        font-size: 12px;
        color: #6b7280;
        margin-top: 12px;
    }
{% endblock %}

{% block content %}
    <h1>{{ 'email.login_code.h1'|trans({}, 'emails') }}</h1>
    <p>{{ 'email.greeting'|trans({'%name%': user.username}, 'emails') }}</p>
    <p>{{ 'email.login_code.body_intro'|trans({'%siteName%': '<strong>' ~ settings.getSiteName() ~ '</strong>'}, 'emails')|raw }}</p>

    <div class="code-container">
        <p class="code-value">{{ code }}</p>
        <p class="expiry-note">{{ 'email.login_code.expiry_note'|trans({}, 'emails') }}</p>
    </div>

    <p>{{ 'email.login_code.advice'|trans({}, 'emails') }}</p>

    <div class="cta-container">
        <a href="{{ url('login_2fa_verify') }}" class="cta-button">{{ 'email.login_code.button'|trans({}, 'emails') }}</a>
    </div>
{% endblock %}

{% block footer %}
    {{ parent() }}
    <p>{{ 'email.login_code.warning'|trans({}, 'emails') }}</p>
{% endblock %}
