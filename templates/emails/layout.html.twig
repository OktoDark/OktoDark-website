<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ settings.getSiteName() }}{% endblock %}</title>
    <style>
        body {
            background-color: #05060a;
            color: #e5e7eb;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
        }
        .wrapper {
            width: 100%;
            padding: 40px 0;
        }
        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #0b0d16;
            border-radius: 12px;
            border: 1px solid #1f2937;
            box-shadow: 0 18px 45px rgba(0,0,0,0.7);
            overflow: hidden;
        }
        .header {
            padding: 32px;
            background: radial-gradient(circle at top left, #22d3ee, #6366f1 40%, #0b0d16 80%);
            border-bottom: 1px solid rgba(15,23,42,0.8);
            text-align: center;
        }
        .logo {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #ffffff;
            text-decoration: none;
        }
        .badge {
            display: inline-block;
            margin-top: 12px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            background: rgba(15,23,42,0.6);
            color: #e5e7eb;
            border: 1px solid rgba(148,163,184,0.3);
        }
        .content {
            padding: 40px 32px;
        }
        h1 {
            font-size: 22px;
            font-weight: 700;
            margin: 0 0 20px;
            color: #f9fafb;
            line-height: 1.3;
        }
        p {
            font-size: 15px;
            line-height: 1.6;
            color: #9ca3af;
            margin: 0 0 20px;
        }
        .cta-container {
            margin: 32px 0;
            text-align: center;
        }
        .cta-button {
            display: inline-block;
            padding: 14px 28px;
            border-radius: 8px;
            background: linear-gradient(135deg, #22d3ee, #6366f1);
            color: #ffffff !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        .footer {
            padding: 32px;
            background: #080a11;
            border-top: 1px solid #1f2937;
            text-align: center;
            font-size: 12px;
            color: #6b7280;
        }
        .footer p {
            font-size: 12px;
            margin-bottom: 8px;
        }
        .footer a {
            color: #9ca3af;
            text-decoration: underline;
        }
        .divider {
            height: 1px;
            background: #1f2937;
            margin: 32px 0;
        }
        {% block extra_styles %}
        .social-links-email {
            margin-top: 20px;
            margin-bottom: 20px;
            text-align: center;
        }
        .social-links-email a {
            display: inline-block;
            margin: 0 8px;
        }
        .social-links-email img {
            vertical-align: middle;
            border: 0;
        }
        {% endblock %}
    </style>
</head>
<body>
<div class="wrapper">
    <div class="container">
        <div class="header">
            <div class="logo">{{ settings.getSiteName() }}</div>
            {% block badge %}{% endblock %}
        </div>
        <div class="content">
            {% block content %}{% endblock %}
        </div>
        <div class="footer">
            {% block footer %}
                <div style="margin:20px 0; text-align:center;">
                    <p style="padding-bottom:15px; color:#e5e7eb; font-weight:600; font-size:14px; margin: 0;">
                        {{ 'title.follow'|trans({}, 'footer') }}:
                    </p>
                    <div style="margin-top: 10px;">

                        <a href="https://x.com/OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/x.png')) }}"
                                 width="24" height="24" alt="X"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://youtube.com/@OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/youtube.png')) }}"
                                 width="24" height="24" alt="YouTube"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://discord.gg/UmfZPvF" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/discord.png')) }}"
                                 width="24" height="24" alt="Discord"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://twitch.tv/OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/twitch.png')) }}"
                                 width="24" height="24" alt="Twitch"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://www.patreon.com/OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/patreon.png')) }}"
                                 width="24" height="24" alt="Patreon"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://bitbucket.org/OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/bitbucket.png')) }}"
                                 width="24" height="24" alt="Bitbucket"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://gitlab.com/oktodark-studios" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/gitlab.png')) }}"
                                 width="24" height="24" alt="GitLab"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                        <a href="https://github.com/OktoDark" style="margin:0 8px; display:inline-block;">
                            <img src="{{ absolute_url(asset('images/EIcons/github.png')) }}"
                                 width="24" height="24" alt="GitHub"
                                 style="border:0; display:inline-block; color-scheme:light dark; supported-color-schemes:light dark; mix-blend-mode:normal;">
                        </a>

                    </div>
                </div>

                <p style="margin-top: 20px;">&copy; {{ "now"|date("Y") }} {{ settings.getSiteName() }}. {{ 'email.layout.rights_reserved'|trans({}, 'emails') }}</p>
                <p>{{ 'email.layout.automated_message'|trans({}, 'emails') }}</p>
            {% endblock %}
        </div>
    </div>
</div>
</body>
</html>
