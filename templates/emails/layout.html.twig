<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ settings.getSiteName() }}{% endblock %}</title>
    <style>
        body {
            background-color: #05060a;
            color: #e5e7eb;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
        }
        .wrapper {
            width: 100%;
            padding: 40px 0;
        }
        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #0b0d16;
            border-radius: 12px;
            border: 1px solid #1f2937;
            box-shadow: 0 18px 45px rgba(0,0,0,0.7);
            overflow: hidden;
        }
        .header {
            padding: 32px;
            background: radial-gradient(circle at top left, #22d3ee, #6366f1 40%, #0b0d16 80%);
            border-bottom: 1px solid rgba(15,23,42,0.8);
            text-align: center;
        }
        .logo {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: #ffffff;
            text-decoration: none;
        }
        .badge {
            display: inline-block;
            margin-top: 12px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            background: rgba(15,23,42,0.6);
            color: #e5e7eb;
            border: 1px solid rgba(148,163,184,0.3);
        }
        .content {
            padding: 40px 32px;
        }
        h1 {
            font-size: 22px;
            font-weight: 700;
            margin: 0 0 20px;
            color: #f9fafb;
            line-height: 1.3;
        }
        p {
            font-size: 15px;
            line-height: 1.6;
            color: #9ca3af;
            margin: 0 0 20px;
        }
        .cta-container {
            margin: 32px 0;
            text-align: center;
        }
        .cta-button {
            display: inline-block;
            padding: 14px 28px;
            border-radius: 8px;
            background: linear-gradient(135deg, #22d3ee, #6366f1);
            color: #ffffff !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
        }
        .footer {
            padding: 32px;
            background: #080a11;
            border-top: 1px solid #1f2937;
            text-align: center;
            font-size: 12px;
            color: #6b7280;
        }
        .footer p {
            font-size: 12px;
            margin-bottom: 8px;
        }
        .footer a {
            color: #9ca3af;
            text-decoration: underline;
        }
        .divider {
            height: 1px;
            background: #1f2937;
            margin: 32px 0;
        }
        {% block extra_styles %}{% endblock %}
    </style>
</head>
<body>
<div class="wrapper">
    <div class="container">
        <div class="header">
            <div class="logo">{{ settings.getSiteName() }}</div>
            {% block badge %}{% endblock %}
        </div>
        <div class="content">
            {% block content %}{% endblock %}
        </div>
        <div class="footer">
            {% block footer %}
                <p>&copy; {{ "now"|date("Y") }} {{ settings.getSiteName() }}. All rights reserved.</p>
                <p>This is an automated message, please do not reply directly to this email.</p>
            {% endblock %}
        </div>
    </div>
</div>
</body>
</html>
