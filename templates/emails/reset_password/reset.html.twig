{% extends 'emails/layout.html.twig' %}

{% block title %}{{ 'email.reset.subject'|trans({}, 'emails') }} – {{ settings.getSiteName() }}{% endblock %}

{% block badge %}
    <div class="badge">{{ 'email.badge.account_security'|trans({}, 'emails') }}</div>
{% endblock %}

{% block content %}
    <h1>{{ 'email.reset.h1'|trans({}, 'emails') }}</h1>
    
    <p>{{ 'email.greeting_simple'|trans({}, 'emails') }}</p>
    <p>{{ 'email.reset.body_intro'|trans({'%siteName%': '<strong>' ~ settings.getSiteName() ~ '</strong>'}, 'emails')|raw }}</p>
    
    <p>{{ 'email.reset.body_link'|trans({}, 'emails') }}</p>

    <div class="cta-container">
        <a href="{{ url('app_reset_password', { token: resetToken.token }) }}" class="cta-button">
            {{ 'email.reset.button'|trans({}, 'emails') }}
        </a>
    </div>

    <p style="text-align: center; color: #6b7280; font-size: 13px;">
        {{ 'email.reset.expiry'|trans({'%hours%': '<strong>' ~ (tokenLifetime / 3600)|round(0, 'floor') ~ '</strong>'}, 'emails')|raw }}<br>
        {{ 'email.reset.backup_url'|trans({}, 'emails') }}
    </p>
    
    <p style="word-break: break-all; font-size: 12px; color: #6366f1; text-align: center;">
        {{ url('app_reset_password', { token: resetToken.token }) }}
    </p>

    <p>{{ 'email.reset.footer_sign'|trans({}, 'emails') }}<br>
    <strong>{{ 'email.team'|trans({'%siteName%': settings.getSiteName()}, 'emails') }}</strong></p>
{% endblock %}
