<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="oktodark-maintenance">
<head>
    <meta charset="utf-8">
    <title>{{ 'maintenance.title'|trans({}, 'messages') }}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no">

    <link rel="icon" href="{{ s.siteCDN }}/themes/images/favicon.ico" type="image/x-icon">

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Roboto+Slab:wght@300;400;700&display=swap">

    <!-- Base Theme -->
    <link rel="stylesheet" href="{{ s.siteCDN }}/themes/modern/css/style.css">

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #0d0f12;
            color: #e5e7eb;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .maintenance-wrapper {
            text-align: center;
            max-width: 600px;
            padding: 40px 20px;
        }

        .maintenance-logo img {
            width: 260px;
            opacity: 0.95;
            filter: drop-shadow(0 0 12px rgba(0, 255, 255, 0.25));
        }

        h1 {
            margin-top: 30px;
            font-size: 2rem;
            font-weight: 700;
            color: #0cc5b6;
            letter-spacing: 1px;
        }

        p {
            margin-top: 15px;
            font-size: 1rem;
            opacity: 0.85;
        }

        .countdown-wrap {
            margin: 40px auto;
        }

        .footer {
            margin-top: 40px;
            font-size: 0.85rem;
            opacity: 0.6;
        }

        .glow-box {
            margin: 40px auto 0;
            padding: 20px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 0 25px rgba(0, 255, 255, 0.05);
        }

        .DateCountdown {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 25px;
        }

        .cd-box {
            text-align: center;
            padding: 10px 15px;
            background: rgba(255,255,255,0.05);
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: 0 0 12px rgba(0,255,255,0.08);
        }

        .cd-box span {
            font-size: 2rem;
            font-weight: 700;
            color: #0cc5b6;
        }

        .cd-box small {
            display: block;
            margin-top: 4px;
            font-size: 0.75rem;
            opacity: 0.7;
        }

    </style>
</head>

<body>
<div class="maintenance-wrapper">

    <div class="maintenance-logo">
        <img src="{{ s.siteCDN }}/themes/modern/images/logo.png" alt="OktoDark Logo">
    </div>

    <h1>{{ 'maintenance.appear'|trans({}, 'messages') }}</h1>

    <div class="glow-box">
        <div class="countdown-wrap">
            <div class="DateCountdown"
                 data-type="until"
                 data-date="2024-07-10 00:00:00"
                 data-format="wdhms"
                 data-color="#0cc5b6"
                 data-bg="rgba(255, 255, 255, .1)"
                 data-width="0.02"
                 data-size="175">
            </div>
        </div>

        <p>{{ 'maintenance.under'|trans({}, 'messages') }}</p>
    </div>

    <div class="footer">
        &copy; <span class="copyright-year"></span> OktoDark Studios
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const countdownElement = document.querySelector(".DateCountdown");
        if (!countdownElement) return;

    const targetDate = countdownElement.dataset.date; // "2024-07-10 00:00:00"
    const endTime = new Date(targetDate.replace(" ", "T")).getTime();

    function updateCountdown() {
        const now = Date.now();
        const diff = endTime - now;

        if (diff <= 0) {
            countdownElement.innerHTML = "<span>00:00:00</span>";
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
        const minutes = Math.floor((diff / (1000 * 60)) % 60);
        const seconds = Math.floor((diff / 1000) % 60);

        countdownElement.innerHTML = `
            <div class="cd-box">
                <span>${days}</span><small>d</small>
            </div>
            <div class="cd-box">
                <span>${hours.toString().padStart(2, '0')}</span><small>h</small>
            </div>
            <div class="cd-box">
                <span>${minutes.toString().padStart(2, '0')}</span><small>m</small>
            </div>
            <div class="cd-box">
                <span>${seconds.toString().padStart(2, '0')}</span><small>s</small>
            </div>
        `;
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);
    });
</script>

</body>
</html>
