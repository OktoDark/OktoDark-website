<!DOCTYPE html>
<html lang="{{ app.request.locale }}" class="oktodark-maintenance">
<head>
    <meta charset="utf-8">
    <title>{{ 'maintenance.title'|trans({}, 'messages') }}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="format-detection" content="telephone=no">

    <link rel="icon" href="{{ s.siteCDN }}/themes/images/favicon.ico" type="image/x-icon">

    <!-- Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Roboto+Slab:wght@300;400;700&display=swap">

    <!-- Base Theme -->
    <link rel="stylesheet" href="{{ s.siteCDN }}/themes/modern/css/style.css">

    <style>
        body {
            margin: 0;
            padding: 0;
            background: #0d0f12;
            color: #e5e7eb;
            font-family: 'Montserrat', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            text-align: center;
        }

        .maintenance-wrapper {
            max-width: 650px;
            padding: 40px 20px;
        }

        .maintenance-logo img {
            width: 260px;
            opacity: 0.95;
            filter: drop-shadow(0 0 22px rgba(0, 255, 255, 0.25));
        }

        h1 {
            margin-top: 35px;
            font-size: 2.4rem;
            font-weight: 700;
            color: #0cc5b6;
            letter-spacing: 1px;
            text-shadow: 0 0 14px rgba(0, 255, 255, 0.18);
        }

        .maintenance-subtitle {
            margin-top: 20px;
            font-size: 1.15rem;
            opacity: 0.85;
            line-height: 1.7;
        }

        .glow-box {
            margin: 45px auto 0;
            padding: 30px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.07);
        }

        .maintenance-status {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0cc5b6;
            margin-bottom: 15px;
            text-shadow: 0 0 10px rgba(0,255,255,0.2);
        }

        .maintenance-info {
            font-size: 1rem;
            opacity: 0.85;
            line-height: 1.6;
        }

        .footer {
            margin-top: 45px;
            font-size: 0.85rem;
            opacity: 0.6;
        }

        .maintenance-divider {
            width: 80px;
            height: 2px;
            background: #0cc5b6;
            margin: 25px auto;
            opacity: 0.4;
            border-radius: 2px;
        }
    </style>
</head>

<body>
<div class="maintenance-wrapper">

    <div class="maintenance-logo">
        <img src="{{ s.siteCDN }}/themes/modern/images/logo.png" alt="OktoDark Logo">
    </div>

    <h1>{{ 'maintenance.appear'|trans({}, 'maintenance') }}</h1>

    <p class="maintenance-subtitle">
        Our systems are temporarily offline for scheduled upgrades.<br>
        We’re enhancing performance, stability, and security across the entire OktoDark platform.
    </p>

    <div class="glow-box">
        <div class="maintenance-status">
            {{ 'maintenance.status'|trans({}, 'maintenance')|default('System Status: Updating') }}
        </div>

        <div class="maintenance-divider"></div>

        <p class="maintenance-info">
            During this time, access to all services is restricted.<br>
            We appreciate your patience and support while we prepare a better experience for you.
        </p>
    </div>

    <div class="footer">
        &copy; <span class="copyright-year"></span> OktoDark Studios
    </div>

</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var yearSpan = document.querySelector(".copyright-year");
        if (yearSpan) {
            yearSpan.textContent = new Date().getFullYear();
        }
    });
</script>

</body>
</html>
