{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.privacy'|trans({}, 'titles') }}{% endblock %}

{% block body_id 'privacy-policy' %}

{% block main %}

    <!-- Modern Page Title -->
    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.privacy'|trans({}, 'titles') }}</h2>
            <p class="lead text-muted mt-2">{{ 'privacy.subtitle'|trans({}, 'privacy') }}</p>
        </div>
    </section>

    <!-- Modern Content Section -->
    <section class="section section-lg bg-default">
        <div class="container">
            <div class="privacy-modern p-4 p-md-5">

                <dl class="list-terms modern-terms">
                    {{ 'privacy.section'|trans({}, 'privacy')|raw }}
                </dl>

                <a class="privacy-link-modern mt-4 d-inline-block"
                   href="mailto:contact@oktodark.com">
                    contact@oktodark.com
                </a>

            </div>
        </div>
    </section>

{% endblock %}