{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.contact'|trans({}, 'contact') }}{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'contact' %}

{% block main %}

    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.contact'|trans({}, 'contact') }}</h2>
            <p class="lead text-muted mt-2">{{ 'content.contact_subtitle'|trans({}, 'contact') }}</p>
        </div>
    </section>

    <section class="section section-lg bg-gray-100">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <p>{{ 'content.contact'|trans({}, 'contact') }}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="section section-lg bg-default text-center">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-9 col-lg-7">

                    <div class="contact-form-modern p-4 p-md-5">
                        {{ form_start(form, {
                            'attr': {
                                'class': 'rd-mailform modern-form',
                                'data-form-output': 'form-output-global',
                                'data-form-type': 'contact'
                            }
                        }) }}

                        <div class="form-wrap-modern text-start">
                            {{ form_row(form.name) }}
                            {{ form_row(form.email) }}
                            {{ form_row(form.category) }}
                            {{ form_row(form.subject) }}
                            {{ form_row(form.message) }}

                            <div class="form-group mt-3">
                                <label for="{{ form.captcha_answer.vars.id }}" class="form-label">
                                    {{ 'label.captcha_question'|trans({}, 'contact') }}: <strong>{{ captcha_question }}</strong>
                                </label>
                                {{ form_widget(form.captcha_answer) }}
                                {{ form_errors(form.captcha_answer) }}
                            </div>

                            {# Hide the honeypot field #}
                            <div style="display:none !important;">
                                {{ form_row(form.website) }}
                            </div>

                            {{ form_row(form.submit) }}
                        </div>

                        {{ form_rest(form) }}
                        {{ form_end(form) }}
                    </div>

                </div>
            </div>
        </div>
    </section>

{% endblock %}