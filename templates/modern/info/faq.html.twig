{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.faq'|trans({}, 'titles') }}{% endblock %}

{% block body_id 'faq' %}

{% block main %}

    <!-- Modern Page Title -->
    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.faq'|trans({}, 'titles') }}</h2>
            <p class="lead text-muted mt-2">{{ 'faq.subtitle'|trans({}, 'faq') }}</p>
        </div>
    </section>

    <!-- Modern FAQ Section -->
    <section class="section section-lg bg-default">
        <div class="container">
            <div class="faq-modern p-4 p-md-5">

                <dl class="list-terms modern-terms">
                    <dt class="heading-4">{{ 'faq.one_title_txt'|trans({}, 'faq') }}</dt>
                    <dd>{{ 'faq.one_content_txt'|trans({}, 'faq')|raw }}</dd>

                    <dt class="heading-4">{{ 'faq.two_title_txt'|trans({}, 'faq') }}</dt>
                    <dd>{{ 'faq.two_content_txt'|trans({}, 'faq') }}</dd>

                    <dt class="heading-4">{{ 'faq.three_title_txt'|trans({}, 'faq') }}</dt>
                    <dd>{{ 'faq.three_content_txt'|trans({}, 'faq')|raw }}</dd>
                </dl>

            </div>
        </div>
    </section>

{% endblock %}