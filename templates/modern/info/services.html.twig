{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.services'|trans({}, 'titles') }}{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'services' %}

{% block main %}

    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h1 class="display-5 fw-bold">{{ 'title.services'|trans({}, 'titles') }}</h1>
            <p class="lead opacity-75">{{ 'services.subtitle'|trans({}, 'services') }}</p>
        </div>
    </section>

    <section class="py-5 bg-light">
        <div class="container">

            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">

                {% for e in services %}
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 service-card animate__animated animate__fadeInUp">

                            <div class="card-header bg-secondary text-white text-center py-3">
                                <h4 class="my-0 fw-semibold">{{ e.serviceName }}</h4>
                            </div>

                            <div class="card-body text-center">

                                <p class="text-muted mb-1">{{ 'services.from'|trans({}, 'services') }}</p>

                                <h3 class="card-title pricing-card-title mb-3">
                                    <i class="fas fa-euro-sign fa-xs"></i>{{ e.servicePrice }}
                                    <small class="text-muted"> / {{ e.serviceWorkDays }}</small>
                                </h3>

                                <ul class="list-unstyled mb-4 text-start px-3">
                                    {{ e.serviceToDo|raw }}
                                </ul>

                                <a href="{{ path('contact') }}" class="btn btn-info text-bg-info w-100 py-2">
                                    {{ 'services.contact_us'|trans({}, 'services') }}
                                </a>

                            </div>

                        </div>
                    </div>
                {% endfor %}

            </div>

            <div class="text-center mt-4">
                <p class="text-muted">{{ 'services.notes'|trans({}, 'services') }}</p>
            </div>

        </div>
    </section>

{% endblock %}