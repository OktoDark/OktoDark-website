{% block footer %}
    <footer class="footer bg-dark text-light pt-5 pb-4">
        <div class="container-fluid px-0">
            <div class="container px-3 px-md-5">

                <div class="row gy-4 justify-content-center text-center">

                    <!-- FOLLOW US + LANGUAGE INLINE -->
                    <div class="d-flex justify-content-center align-items-center flex-wrap gap-4">

                        <div class="d-flex align-items-center flex-wrap gap-2 social-icons">
                            <span class="fw-bold me-1">
                                {{ 'title.follow'|trans({}, 'footer') }}:
                            </span>

                            <a href="https://x.com/OktoDark"><i class="fa-brands fa-x-twitter"></i></a>
                            <a href="https://youtube.com/@OktoDark"><i class="fa-brands fa-youtube"></i></a>
                            <a href="https://discord.gg/UmfZPvF"><i class="fa-brands fa-discord"></i></a>
                            <a href="https://twitch.tv/OktoDark"><i class="fa-brands fa-twitch"></i></a>
                            <a href="https://www.patreon.com/OktoDark"><i class="fa-brands fa-patreon"></i></a>
                            <a href="https://bitbucket.org/OktoDark"><i class="fa-brands fa-bitbucket"></i></a>
                            <a href="https://gitlab.com/oktodark-studios"><i class="fa-brands fa-gitlab"></i></a>
                            <a href="https://github.com/OktoDark"><i class="fa-brands fa-github"></i></a>
                        </div>

                        <span class="mx-3"></span>

                        <div class="dropdown d-flex align-items-center">
                            <a class="dropdown-toggle d-inline-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                                <i class="fas fa-globe"></i>
                                {{ 'language.selector'|trans({}, 'footer') }}:
                                {% for locale in locales() %}
                                    {% if locale.code == currentLocale %}
                                        {{ locale.name|capitalize }}
                                    {% endif %}
                                {% endfor %}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                {% for locale in locales() %}
                                    <li class="{{ currentLocale == locale.code ? 'active' : '' }}">
                                        <a class="dropdown-item" href="{{ path(currentRoute, currentParams|merge({_locale: locale.code})) }}">
                                            {{ locale.name|capitalize }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>

                    </div>

                    <!-- INLINE LINKS (UNCHANGED) -->
                    <div class="col-12 footer-column mt-4">
                        <div class="footer-inline-links small text-muted d-flex flex-wrap justify-content-center gap-2">

                            <a href="{{ path('faq') }}" class="footer-inline-link">
                                {{ 'title.faq'|trans({}, 'base') }}
                            </a>
                            <span class="separator"></span>

                            <a href="{{ path('services') }}" class="footer-inline-link">
                                {{ 'title.services'|trans({}, 'base') }}
                            </a>
                            <span class="separator"></span>

                            <a href="{{ path('contact') }}" class="footer-inline-link">
                                {{ 'title.contact'|trans({}, 'base') }}
                            </a>
                            <span class="separator"></span>

                            <a href="{{ path('privacy-policy') }}" class="footer-inline-link">
                                {{ 'privacy_policy.text'|trans({}, 'footer') }}
                            </a>
                            <span class="separator"></span>

                            <a href="#" id="open-x1" class="footer-inline-link no-scroll">
                                {{ 'site_preferences.text'|trans({}, 'footer') }}
                            </a>

                        </div>

                        <!-- COPYRIGHT -->
                        <div class="footer-bottom mt-3">
                            © {{ "now"|date("Y") }} {{ settings.siteName }} — {{ 'footer.all_rights_reserved_text'|trans({}, 'footer') }}
                        </div>
                    </div>

                </div>

                <div class="footer-divider mt-4"></div>

            </div>
        </div>
    </footer>
{% endblock %}
