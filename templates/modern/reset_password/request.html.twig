{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'title.reset_your_password'|trans({}, 'reset_password') }}{% endblock %}

{% block body_id 'reset-password-request' %}

{% block body %}

    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.reset_your_password'|trans({}, 'reset_password') }}</h2>
            <p class="lead text-muted mt-2">{{ 'text.reset_password_request_intro'|trans({}, 'reset_password') }}</p>
        </div>
    </section>

    <section class="section section-md bg-default text-center pt-0">
        <div class="container">
            <div class="row justify-content-center">

                <div class="login-modern p-4 p-md-5">

                    {% for flashError in app.flashes('reset_password_error') %}
                        <div class="alert alert-danger mb-3">{{ flashError }}</div>
                    {% endfor %}

                    {{ form_start(requestForm, { attr: { class: 'text-start' } }) }}

                    <fieldset>

                        <div class="form-wrap-modern text-start">
                            <label for="email">{{ 'label.email'|trans({}, 'reset_password') }}</label>
                            {{ form_widget(requestForm.email, {
                                attr: {
                                    id: 'email',
                                    class: 'form-control'
                                }
                            }) }}
                            {{ form_errors(requestForm.email) }}
                        </div>

                        <button class="button button-gradient w-100 py-2 mt-4" type="submit">
                            <i class="fa fa-paper-plane me-2"></i>
                            {{ 'button.send_reset_email'|trans({}, 'reset_password') }}
                        </button>

                        <div class="mt-3 text-center">
                            <a href="{{ path('security_login') }}" class="text-sm text-gray-400 hover:text-gray-200">
                                {{ 'text.back_to_login'|trans({}, 'reset_password') }}
                            </a>
                        </div>
                    </fieldset>

                    {{ form_end(requestForm) }}

                </div>

            </div>

            <div class="mt-4 text-muted small">
                {{ 'text.reset_password_note'|trans({}, 'reset_password') }}
            </div>

        </div>
    </section>

{% endblock %}