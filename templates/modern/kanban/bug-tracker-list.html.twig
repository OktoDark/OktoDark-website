{% extends "@theme/base.html.twig" %}

{% block title %}
	{{'kanban.bug_tracker_list.title'|trans({}, 'kanban')}}
{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'bug-trackers' %}

{% block main %}
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h1 class="display-5 fw-bold">{{'kanban.bug_tracker_list.title'|trans({}, 'kanban')}}</h1>
        </div>
    </section>

    <section class="py-5 bg-light">
        <div class="container py-4">
		<h4 class="fw-bold mb-4">{{'kanban.bug_tracker_list.heading_all'|trans({}, 'kanban')}}</h4>

		<form method="get" action="{{ path('kanban_bugs') }}" class="row g-3 mb-4">
			<div class="col-md-5">
				<input type="text" name="search" value="{{ search }}" class="form-control" placeholder="Search by name or description...">
			</div>
			<div class="col-md-3">
				<select name="status" class="form-select">
					<option value="all" {{ status == 'all' ? 'selected' : '' }}>All</option>
					<option value="active" {{ status == 'active' ? 'selected' : '' }}>Active</option>
					<option value="inactive" {{ status == 'inactive' ? 'selected' : '' }}>Inactive</option>
				</select>
			</div>
			<div class="col-md-2">
				<button type="submit" class="btn btn-primary w-100">
					<i class="fas fa-filter me-1"></i>Filter</button>
			</div>
			<div class="col-md-2">
				<a href="{{ path('kanban_bugs') }}" class="btn btn-outline-secondary w-100">Reset</a>
			</div>
		</form>

		<div class="row g-4">
			{% if bugTrackers is defined and bugTrackers|length > 0 %}
				{% for tracker in bugTrackers %}
				{% set projectLabel %}
				{% if tracker.ourGame %}
					<span class="badge bg-info text-dark me-1">
						<i class="bi bi-diagram-3 me-1"></i>
						{{ tracker.ourGame.name }}</span>
				{% elseif tracker.mod %}
					<span class="badge bg-warning text-dark me-1">
						<i class="bi bi-box me-1"></i>
						{{ tracker.mod.name }}</span>
				{% else %}
					<span class="badge bg-secondary me-1">
						<i class="bi bi-globe me-1"></i>
						{{ "kanban.bug_tracker_list.global"|trans({}, 'kanban') }}</span>
				{% endif %}
				{% endset %}
					{% set statusBadge %}
					{% if tracker.isActive %}
						<span class="badge bg-success">{{ "kanban.bug_tracker_list.active"|trans({}, 'kanban') }}</span>
					{% else %}
						<span class="badge bg-secondary">{{ "kanban.bug_tracker_list.inactive"|trans({}, 'kanban') }}</span>
					{% endif %}
					{% endset %}
					{% set description %}
					{% if tracker.description %}
						<p class="card-text text-muted small text-truncate mb-2" title="{{ tracker.description }}">{{ tracker.description }}</p>
					{% else %}
						<p class="card-text text-muted small mb-2">{{ "kanban.bug_tracker_list.no_description"|trans({}, 'kanban') }}</p>
					{% endif %}
					{% endset %}
					{% set ownerLine %}
					{% if tracker.owner %}
						<div class="d-flex align-items-center text-muted small mb-1">
							<i class="bi bi-person me-2"></i>
							<span>{{ tracker.owner.username }}</span>
						</div>
					{% endif %}
					{% endset %}
					{% set maintainerCount = tracker.trackers|length %}
					{% set maintainerLine %}
					{% if maintainerCount > 0 %}
						<div class="d-flex align-items-center text-muted small mb-2">
							<i class="bi bi-people me-2"></i>
							<span>{{ maintainerCount }}
								{{ "kanban.bug_tracker_list.maintainers_count"|trans({}, 'kanban') }}</span>
						</div>
					{% else %}
						<div class="d-flex align-items-center text-muted small mb-2">
							<i class="bi bi-people me-2"></i>
							<span>{{ "kanban.bug_tracker_list.maintainers_none"|trans({}, 'kanban') }}</span>
						</div>
					{% endif %}
					{% endset %}

				<div class="col-md-6 col-lg-4">
					<div class="card shadow-sm border-0 h-100">
						<div class="card-body d-flex flex-column">
							<div class="d-flex justify-content-between align-items-start mb-2">
								<h5 class="card-title mb-0 text-truncate">{{ tracker.name }}</h5>
								{{ statusBadge|raw }}
							</div>
							<div class="mb-2">{{ projectLabel|raw }}</div>
							{{ description|raw }}
							{{ ownerLine|raw }}
							{{ maintainerLine|raw }}
							<div class="mt-auto pt-2 text-end">
								<a href="{{ path('kanban_bugs_tracker', {'slug': tracker.slug}) }}" class="btn btn-primary">
									<i class="fas fa-eye me-1"></i>
									{{ "kanban.bug_tracker_list.view_tracker"|trans({}, 'kanban') }}</a>
							</div>
						</div>
					</div>
				</div>
				{% endfor %}
			{% else %}
				<div class="col-12 text-center py-5 text-muted">
					{% if search or status != 'all' %}
						<p class="mb-0">No bug trackers match your filters.</p>
					{% else %}
						<p class="mb-0">No bug trackers yet. Start by creating a new one.</p>
					{% endif %}
				</div>
			{% endif %}
		</div>
	</div>
</section>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
{% endblock %}
