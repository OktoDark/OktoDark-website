{% extends "@theme/base.html.twig" %}

{% block title %}{{'kanban.title'|trans({}, 'kanban')}}{% endblock %}

{% block main %}
    {% form_theme createBoardForm 'bootstrap_5_layout.html.twig' %} {# Explicitly set form theme #}
    <div class="boards-container container py-4" {% if game %}data-game-slug="{{ game.shortNameSlug }}"{% endif %}>
        <div class="boards-header d-flex justify-content-between align-items-center mb-4"> {# Used flex utilities #}
            <h4 class="mb-0">{% if game %}{{'kanban.board_list.heading_for_game'|trans({'%game_name%': game.name}, 'kanban')}}{% else %}{{'kanban.board_list.heading_all'|trans({}, 'kanban')}}{% endif %}</h4>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createBoardModal">
                <i class="bi bi-plus-circle me-2"></i>{{'kanban.board_list.create_button'|trans({}, 'kanban')}} {# Added Bootstrap Icon #}
            </button>
        </div>

        <div id="boardsList" class="row"> {# Already a Bootstrap row #}
            <!-- Boards loaded dynamically -->
        </div>
    </div>

    <!-- Create Board Modal -->
    <div class="modal fade" id="createBoardModal" tabindex="-1" aria-labelledby="createBoardModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="createBoardModalLabel">{{'kanban.create_board_modal.title'|trans({}, 'kanban')}}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{'kanban.create_board_modal.close_button_aria'|trans({}, 'kanban')}}"></button>
                </div>
                <div class="modal-body">
                    {{ form_start(createBoardForm, {'attr': {'id': 'createBoardForm'}}) }}
                    <div class="mb-3">
                        {{ form_label(createBoardForm.title) }}
                        {{ form_widget(createBoardForm.title) }}
                        {{ form_errors(createBoardForm.title) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(createBoardForm.description) }}
                        {{ form_widget(createBoardForm.description) }}
                        {{ form_errors(createBoardForm.description) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(createBoardForm.backgroundColor) }}
                        {{ form_widget(createBoardForm.backgroundColor) }}
                        {{ form_errors(createBoardForm.backgroundColor) }}
                    </div>
                    <div class="form-check mb-3">
                        {{ form_widget(createBoardForm.isPublic, {'attr': {'class': 'form-check-input'}}) }}
                        {{ form_label(createBoardForm.isPublic, null, {'label_attr': {'class': 'form-check-label'}}) }}
                        {{ form_errors(createBoardForm.isPublic) }}
                    </div>
                    {# Conditionally render ourGame field as hidden or select #}
                    {% if game %}
                        <input type="hidden" name="{{ createBoardForm.ourGame.vars.full_name }}" value="{{ game.id }}">
                    {% else %}
                        {{ form_row(createBoardForm.ourGame) }}
                    {% endif %}
                    <button type="submit" class="btn btn-primary mt-3">{{'kanban.create_board_modal.form.submit_button'|trans({}, 'kanban')}}</button>
                    {{ form_end(createBoardForm, {'render_rest': false}) }}
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ settings.siteCDN }}/kanban/js/api-client.js"></script>
    <script src="{{ settings.siteCDN }}/kanban/js/board-manager.js"></script>
    <script>
        var boardsContainer = document.querySelector('.boards-container');
        var gameSlug = boardsContainer.dataset.gameSlug || ''; // Get gameSlug from data attribute. It will be an empty string if game is null.

        // Initialize ApiClient with the correct base URL
        var apiClient = new ApiClient('{{ path('kanban_api_base') }}');

        // Initialize BoardManager with locale and gameSlug
        var boardManager = new BoardManager(apiClient, '{{ app.request.locale }}', gameSlug);

        document.addEventListener('DOMContentLoaded', function() {
            boardManager.loadBoards().then(function(boards) {
                boardManager.renderBoardsList(document.getElementById('boardsList'));
            });

            var createBoardForm = document.getElementById('createBoardForm');
            if (createBoardForm) {
                createBoardForm.addEventListener('submit', function(event) {
                    event.preventDefault();

                    var formData = new FormData(createBoardForm);
                    var data = {};
                    for (var pair of formData.entries()) {
                        data[pair[0]] = pair[1];
                    }

                    boardManager.createBoard(data)
                        .then(function(newBoard) {
                            console.log('Board created:', newBoard);
                            // Close modal using Bootstrap 5 API
                            var createBoardModal = bootstrap.Modal.getInstance(document.getElementById('createBoardModal'));
                            if (createBoardModal) {
                                createBoardModal.hide();
                            }
                            // Reload boards list
                            boardManager.loadBoards().then(function() {
                                boardManager.renderBoardsList(document.getElementById('boardsList'));
                            });
                            // Optionally, show a success message
                            alert('{{'kanban.create_board_modal.success_message'|trans({}, 'kanban')}}');
                            createBoardForm.reset(); // Clear the form
                        })
                        .catch(function(error) {
                            console.error('Error creating board:', error);
                            var errorMessage = '{{'kanban.create_board_modal.error_message_prefix'|trans({}, 'kanban')}}' + (error.message || '{{'kanban.create_board_modal.error_unknown'|trans({}, 'kanban')}}');

                            // Check if the error object contains detailed validation errors
                            if (error.errors) {
                                errorMessage += '\n\n{{'kanban.create_board_modal.error_details_prefix'|trans({}, 'kanban')}}';
                                for (var field in error.errors) {
                                    if (error.errors.hasOwnProperty(field)) {
                                        errorMessage += '\n- ' + field + ': ' + error.errors[field].join(', '); // Field names are not translated here
                                    }
                                }
                            }
                            alert(errorMessage);
                            // You might want to display validation errors more gracefully here, e.g., next to fields
                        });
                });
            }
        });
    </script>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/kanban/boards.css') }}">
{% endblock %}