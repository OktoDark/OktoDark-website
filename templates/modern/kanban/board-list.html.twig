{% extends "@theme/base.html.twig" %}

{% block title %}
	{{'kanban.title'|trans({}, 'kanban')}}
{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'boards' %}

{% block main %}
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h1 class="display-5 fw-bold">{{'kanban.board_list.heading_all'|trans({}, 'kanban')}}</h1>
        </div>
    </section>

    <section class="py-5 bg-light">
        <div class="container py-4">
		<h4 class="fw-bold mb-4">{{'kanban.board_list.heading_all'|trans({}, 'kanban')}}</h4>

		<form method="get" action="{{ path('kanban_index') }}" class="row g-3 mb-4">
			<div class="col-md-5">
				<input type="text" name="search" value="{{ search }}" class="form-control" placeholder="Search by name or description...">
			</div>
			<div class="col-md-3">
				<select name="status" class="form-select">
					<option value="all" {{ status == 'all' ? 'selected' : '' }}>All</option>
					<option value="public" {{ status == 'public' ? 'selected' : '' }}>Public</option>
					<option value="private" {{ status == 'private' ? 'selected' : '' }}>Private</option>
				</select>
			</div>
			<div class="col-md-2">
				<button type="submit" class="btn btn-primary w-100">
					<i class="fas fa-filter me-1"></i>Filter</button>
			</div>
			<div class="col-md-2">
				<a href="{{ path('kanban_index') }}" class="btn btn-outline-secondary w-100">Reset</a>
			</div>
		</form>

		<div class="row g-4">
			{% if boards is defined and boards|length > 0 %}
				{% for board in boards %}
					{% set projectLabel %}
					{% if board.ourGame %}
						<span class="badge bg-info text-dark me-1">
							<i class="bi bi-diagram-3 me-1"></i>
							{{ board.ourGame.shortNameSlug }}</span>
					{% else %}
						<span class="badge bg-secondary me-1">
							<i class="bi bi-globe me-1"></i>Global</span>
					{% endif %}
					{% endset %}
					{% set statusBadge %}
					{% if board.isPublic %}
						<span class="badge bg-success">Public</span>
					{% else %}
						<span class="badge bg-secondary">Private</span>
					{% endif %}
					{% endset %}
					{% set description %}
					{% if board.description %}
						<p class="card-text text-muted small text-truncate mb-2" title="{{ board.description }}">{{ board.description }}</p>
					{% else %}
						<p class="card-text text-muted small mb-2">No description</p>
					{% endif %}
					{% endset %}
					{% set ownerLine %}
					{% if board.owner %}
						<div class="d-flex align-items-center text-muted small mb-1">
							<i class="bi bi-person me-2"></i>
							<span>{{ board.owner.username }}</span>
						</div>
					{% endif %}
					{% endset %}
					{% set memberCount = board.members|length %}
					{% set maintainerLine %}
					{% if memberCount > 0 %}
						<div class="d-flex align-items-center text-muted small mb-2">
							<i class="bi bi-people me-2"></i>
							<span>{{ memberCount }}
								maintainers</span>
						</div>
					{% else %}
						<div class="d-flex align-items-center text-muted small mb-2">
							<i class="bi bi-people me-2"></i>
							<span>No maintainers</span>
						</div>
					{% endif %}
					{% endset %}

					<div class="col-md-6 col-lg-4">
						<div class="card shadow-sm border-0 h-100">
							<div class="card-body d-flex flex-column">
								<div class="d-flex justify-content-between align-items-start mb-2">
									<h5 class="card-title mb-0 text-truncate">{{ board.title }}</h5>
									{{ statusBadge|raw }}
								</div>
								<div class="mb-2">{{ projectLabel|raw }}</div>
								{{ description|raw }}
								{{ ownerLine|raw }}
								{{ maintainerLine|raw }}
								<div class="mt-auto pt-2 text-end">
									{% if board.ourGame %}
										<a href="{{ path('kanban_board_project', {'shortNameSlug': board.ourGame.shortNameSlug, 'slug': board.slug}) }}" class="btn btn-primary">
											<i class="fas fa-eye me-1"></i>View Board</a>
									{% else %}
										<a href="{{ path('kanban_board', {'slug': board.slug}) }}" class="btn btn-primary">
											<i class="fas fa-eye me-1"></i>View Board</a>
									{% endif %}
								</div>
							</div>
						</div>
					</div>
				{% endfor %}
			{% else %}
				<div class="col-12 text-center py-5 text-muted">
					{% if search or status != 'all' %}
						<p class="mb-0">No boards match your filters.</p>
					{% else %}
						<p class="mb-0">No boards yet. Start by creating a new board.</p>
					{% endif %}
				</div>
			{% endif %}
		</div>
	</div>
</section>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ settings.siteCDN }}/kanban/js/api-client.js"></script>
	<script src="{{ settings.siteCDN }}/kanban/js/board-manager.js"></script>
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('build/kanban/boards.css') }}">
{% endblock %}
