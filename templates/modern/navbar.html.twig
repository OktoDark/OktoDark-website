<header>
    <nav class="navbar navbar-expand-lg navbar-dark modern-nav fixed-top">
        <div class="container">

            {# LEFT: Logo #}
            <a class="navbar-brand" href="{{ path('home') }}">
                <img src="{{ settings.siteCDN }}/themes/{{ theme }}/images/logo.png"
                     alt="Logo"
                     width="120"
                     class="img-fluid">
            </a>

            {# Mobile toggle #}
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar"
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            {# RIGHT SIDE MENU #}
            <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                <ul class="navbar-nav right-menu">

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('home') }}">
                            {{ 'navbar.home'|trans({}, 'navbar') }}
                            <span class="nav-arrow"></span>
                        </a>
                    </li>

                    {# PROJECTS #}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            {{ 'navbar.projects'|trans({}, 'navbar') }}
                            <span class="nav-arrow"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('games') }}">{{ 'navbar.games'|trans({}, 'navbar') }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('mods') }}">{{ 'navbar.mods'|trans({}, 'navbar') }}</a></li>
                        </ul>
                    </li>

                    {# SERVICES #}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('services') }}">
                            {{ 'navbar.services'|trans({}, 'navbar') }}
                            <span class="nav-arrow"></span>
                        </a>
                    </li>

                    {# COMMUNITY #}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            {{ 'navbar.community'|trans({}, 'navbar') }}
                            <span class="nav-arrow"></span>
                        </a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="{{ path('forum') }}">{{ 'navbar.forum'|trans({}, 'navbar') }}</a></li>
                            <li><a class="dropdown-item" href="{{ path('blog') }}">{{ 'navbar.blog'|trans({}, 'navbar') }}</a></li>
                            <li><a class="dropdown-item" href="https://discord.gg/UmfZPvF">{{ 'navbar.discord'|trans({}, 'navbar') }}</a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('careers') }}">{{ 'navbar.careers'|trans({}, 'navbar') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('about') }}">{{ 'navbar.about'|trans({}, 'navbar') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('contact') }}">{{ 'navbar.contact'|trans({}, 'navbar') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('supportus') }}"><i class="fa-solid fa-heart" style="color:#fd0909;"></i> {{ 'navbar.support_us'|trans({}, 'navbar') }}</a>
                    </li>

                    {# USER MENU #}
                    {% if app.user %}

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                {{ 'navbar.member_area'|trans({}, 'navbar') }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">

                                <li><a class="dropdown-item" href="{{ path('member_area') }}">{{ 'navbar.member_area'|trans({}, 'navbar') }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('profile_view', { username: app.user.username }) }}">{{ 'navbar.profile'|trans({}, 'navbar') }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('settings_area') }}">{{ 'navbar.user_settings'|trans({}, 'navbar') }}</a></li>

                                {% if is_granted('ROLE_ADMIN') %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}">{{ 'navbar.admin'|trans({}, 'navbar') }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_assets') }}">{{ 'navbar.assets'|trans({}, 'navbar') }}</a></li>
                                {% endif %}

                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="{{ path('security_logout') }}">{{ 'navbar.logout'|trans({}, 'navbar') }}</a></li>
                            </ul>
                        </li>

                        {# NOTIFICATIONS BELL #}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarNotifications" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-bell"></i>
                                {% if app.user.unreadNotificationsCount > 0 %}
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="padding-top: 20px;">
                                            {{ app.user.unreadNotificationsCount }}
                                            <span class="visually-hidden">unread notifications</span>
                                        </span>
                                {% endif %}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarNotifications">
                                {% if app.user.unreadNotificationsCount > 0 %}
                                    {% for notification in app.user.notifications|filter(n => not n.isRead)|slice(0, 5) %} {# Show up to 5 unread notifications #}
                                        <li>
                                            <a class="dropdown-item notification-item {% if not notification.isRead %}unread{% endif %}" href="{{ notification.link }}">
                                                <div class="notification-title">{{ notification.title }}</div>
                                                <div class="notification-message">{{ notification.message|u.truncate(50, '...') }}</div>
                                                <div class="notification-time text-muted small">{{ notification.createdAt|ago }}</div>
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                    {% endfor %}
                                    <li>
                                        <form action="{{ path('notifications_mark_all_read') }}" method="post" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('mark_all_read') }}">
                                            <button type="submit" class="dropdown-item text-center text-primary" onclick="return confirm('{{ 'navbar.notifications.confirm_mark_all_read'|trans({}, 'navbar') }}');">
                                                <i class="fas fa-check-double me-1"></i> {{ 'navbar.notifications.mark_all_read'|trans({}, 'navbar') }}
                                            </button>
                                        </form>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-center" href="{{ path('notifications_index') }}">{{ 'navbar.notifications.view_all'|trans({}, 'navbar') }}</a></li>
                                {% else %}
                                    <li><span class="dropdown-item text-muted">{{ 'navbar.notifications.no_new'|trans({}, 'navbar') }}</span></li>
                                {% endif %}
                            </ul>
                        </li>

                    {% else %}
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                {{ 'navbar.member_area'|trans({}, 'navbar') }}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="{{ path('security_login') }}">{{ 'navbar.login'|trans({}, 'navbar') }}</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_register') }}">{{ 'navbar.register'|trans({}, 'navbar') }}</a></li>
                            </ul>
                        </li>
                    {% endif %}

                </ul>
            </div>

        </div>
    </nav>
</header>