{% extends '@theme/base.html.twig' %}

{% block title %}Dashboard – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_layout.html.twig' %}

        {% block admin_content %}

            <section class="section-page-title text-center py-4 fade-in">
                <h2 class="fw-bold">Admin Dashboard</h2>
                <p class="text-muted">Real‑time analytics for your OktoDark platform.</p>
            </section>

            <section class="py-3">

                {# TOP STAT CARDS #}
                <div class="row g-3 fade-in">
                    {% set cards = [
                        {'label': 'Users', 'value': stats.users, 'id': 'countUsers'},
                        {'label': 'Page Views Today', 'value': stats.page_views_today, 'id': 'countViews'},
                        {'label': 'Active Sessions', 'value': stats.active_sessions, 'id': 'countActive'},
                        {'label': 'Errors Today', 'value': stats.errors_today, 'danger': true, 'id': 'countErrors'}
                    ] %}

                    {% for c in cards %}
                        <div class="col-md-3 col-6">
                            <div class="card neon-card p-3 shadow-sm text-center">
                                <h5>{{ c.label }}</h5>
                                <p class="fs-3 fw-bold mb-1 {{ c.danger is defined and c.danger ? 'text-danger' : '' }}"
                                   id="{{ c.id }}">
                                    {{ c.value }}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# TRAFFIC + DEVICES #}
                <div class="row g-3 mt-4 fade-in">
                    <div class="col-md-8">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Traffic – Last 7 Days</h5>
                            <canvas id="trafficChart"></canvas>
                        </div>

                        <div class="card neon-card p-3 shadow-sm mt-4">
                            <h5 class="mb-3">Live Traffic</h5>
                            <canvas id="liveTrafficChart" height="120"></canvas>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Devices</h5>
                            <canvas id="deviceChart"></canvas>
                        </div>
                    </div>
                </div>

                {# BROWSERS + COUNTRIES #}
                <div class="row g-3 mt-4 fade-in">

                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Browsers</h5>
                            <ul class="list-group list-group-flush">
                                {% for b in stats.browsers %}
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>{{ b.browser ?? 'Unknown' }}</strong>
                                            {% if b.version is defined and b.version %}
                                                <span class="text-muted small ms-1">v{{ b.version }}</span>
                                            {% endif %}
                                        </div>
                                        <span class="fw-bold">{{ b.total }}</span>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted">No browser data yet.</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Countries</h5>
                            <canvas id="countryChart" style="height: 260px;"></canvas>
                        </div>
                    </div>

                </div>

                {# HOURLY HEATMAP + REFERRERS #}
                <div class="row g-3 mt-4 fade-in">
                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Active Hours</h5>
                            <canvas id="hourlyChart"></canvas>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Top Referrers</h5>
                            <canvas id="referrerChart"></canvas>
                        </div>
                    </div>
                </div>

                {# TOP ROUTES + TOP NEWS #}
                <div class="row g-3 mt-4 fade-in">
                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Top Routes</h5>
                            <ul class="list-group">
                                {% for route in stats.top_routes %}
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>{{ route.route }}</span>
                                        <span class="fw-bold">{{ route.total }}</span>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted">No data yet.</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Top News</h5>
                            <ul class="list-group">
                                {% for item in stats.top_news %}
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span>News #{{ item.contentId }}</span>
                                        <span class="fw-bold">{{ item.total }}</span>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted">No data yet.</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>

                {# TOP IPs + IP DISTRIBUTION #}
                <div class="row g-3 mt-4 fade-in">
                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Top IPs</h5>
                            <ul class="list-group">
                                {% for ip in stats.top_ips %}
                                    <li class="list-group-item d-flex justify-content-between">
                                        <span class="top-ip-left">
                                            {{ ip.ip ?? 'Unknown' }}
                                            <span class="text-muted small">({{ ip.country is defined and ip.country ? ip.country : '??' }})</span>
                                        </span>
                                        <span class="fw-bold">{{ ip.total }}</span>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted">No IP data yet.</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">IP Distribution</h5>
                            <canvas id="ipChart"></canvas>
                        </div>
                    </div>
                </div>

                {# RECENT SESSIONS #}
                <div class="row g-3 mt-4 fade-in">
                    <div class="col-12">
                        <div class="card neon-card p-3 shadow-sm">
                            <h5 class="mb-3">Recent Sessions</h5>
                            <ul class="list-group">
                                {% for s in stats.recent_sessions %}
                                    <li class="list-group-item session-item">
                                        <strong>{{ s.ip ?? 'Unknown IP' }}</strong>
                                        <div class="details">
                                            {{ s.browser ?? 'Unknown' }}
                                            {% if s.browserVersion is defined and s.browserVersion %}
                                                v{{ s.browserVersion }}
                                            {% endif %}
                                            /
                                            {{ s.os ?? 'Unknown' }}
                                            {% if s.osVersion is defined and s.osVersion %}
                                                {{ s.osVersion }}
                                            {% endif %}
                                            /
                                            {{ s.device ?? 'Unknown' }}
                                            {% if s.deviceModel is defined and s.deviceModel %}
                                                ({{ s.deviceModel }})
                                            {% endif %}
                                            /
                                            {{ s.country ?? '??' }}
                                        </div>
                                        <span class="timestamp">
                                            {{ s.lastSeenAt|date('Y-m-d H:i') }}
                                        </span>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted">No sessions yet.</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>

            </section>

            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

            <script>
                const tooltipStyle = {
                    backgroundColor: '#111',
                    titleColor: '#0cc5b6',
                    bodyColor: '#fff',
                    borderColor: '#0cc5b6',
                    borderWidth: 1,
                    padding: 10,
                    displayColors: false
                };

                function animateCounter(el, to) {
                    const duration = 800;
                    const start = parseInt(el.innerText.replace(/,/g, ''), 10) || 0;
                    const startTime = performance.now();

                    function frame(now) {
                        const progress = Math.min((now - startTime) / duration, 1);
                        const value = Math.floor(start + (to - start) * progress);
                        el.innerText = value.toLocaleString();
                        if (progress < 1) requestAnimationFrame(frame);
                    }
                    requestAnimationFrame(frame);
                }

                document.addEventListener('DOMContentLoaded', () => {
                    document.querySelectorAll('.neon-card p.fs-3').forEach(el => {
                        animateCounter(el, parseInt(el.innerText.replace(/,/g, ''), 10) || 0);
                });
                });

                /* TRAFFIC – LAST 7 DAYS */
                new Chart(document.getElementById('trafficChart'), {
                    type: 'line',
                    data: {
                        labels: {{ stats.traffic_last_7_days|map(d => d.date)|json_encode|raw }},
                        datasets: [{
                            label: 'Page Views',
                            data: {{ stats.traffic_last_7_days|map(d => d.total)|json_encode|raw }},
                            borderColor: '#0cc5b6',
                            backgroundColor: 'rgba(12,197,182,0.15)',
                            tension: 0.3,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } }
                    }
                });

                /* DEVICES */
                new Chart(document.getElementById('deviceChart'), {
                    type: 'doughnut',
                    data: {
                        labels: {{ stats.devices|map(d => d.device ?? 'Unknown')|json_encode|raw }},
                        datasets: [{
                            data: {{ stats.devices|map(d => d.total)|json_encode|raw }},
                            backgroundColor: ['#0cc5b6', '#0aa39a', '#066f68', '#044f4a'],
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { position: 'bottom' } }
                    }
                });

                /* COUNTRIES */
                new Chart(document.getElementById('countryChart'), {
                    type: 'bar',
                    data: {
                        labels: {{ stats.countries|map(c => c.country ?? '??')|json_encode|raw }},
                        datasets: [{
                            label: 'Visitors',
                            data: {{ stats.countries|map(c => c.total)|json_encode|raw }},
                            backgroundColor: '#0cc5b6'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } }
                    }
                });

                /* HOURLY */
                new Chart(document.getElementById('hourlyChart'), {
                    type: 'bar',
                    data: {
                        labels: {{ stats.hourly_heatmap|map(h => h.hour)|json_encode|raw }},
                        datasets: [{
                            label: 'Page Views',
                            data: {{ stats.hourly_heatmap|map(h => h.total)|json_encode|raw }},
                            backgroundColor: '#0aa39a'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } }
                    }
                });

                /* REFERRERS */
                new Chart(document.getElementById('referrerChart'), {
                    type: 'bar',
                    data: {
                        labels: {{ stats.referrers|map(r => r.referrer)|json_encode|raw }},
                        datasets: [{
                            label: 'Visits',
                            data: {{ stats.referrers|map(r => r.total)|json_encode|raw }},
                            backgroundColor: '#0cc5b6'
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } }
                    }
                });

                /* IP DISTRIBUTION */
                new Chart(document.getElementById('ipChart'), {
                    type: 'bar',
                    data: {
                        labels: {{ stats.top_ips|map(i => i.ip ?? 'Unknown')|json_encode|raw }},
                        datasets: [{
                            label: 'Requests',
                            data: {{ stats.top_ips|map(i => i.total)|json_encode|raw }},
                            backgroundColor: '#0cc5b6'
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } }
                    }
                });

                /* LIVE TRAFFIC CHART */
                const liveTrafficCtx = document.getElementById('liveTrafficChart').getContext('2d');
                let liveTrafficData = {
                    labels: [],
                    datasets: [{
                        label: 'Live Views',
                        data: [],
                        borderColor: '#0cc5b6',
                        backgroundColor: 'rgba(12,197,182,0.15)',
                        tension: 0.3,
                        fill: true
                    }]
                };

                const liveTrafficChart = new Chart(liveTrafficCtx, {
                    type: 'line',
                    data: liveTrafficData,
                    options: {
                        responsive: true,
                        plugins: { tooltip: tooltipStyle, legend: { display: false } },
                        animation: { duration: 300 }
                    }
                });

                /* SSE REAL-TIME STREAM */
                const evtSource = new EventSource('{{ path('admin_live_stream') }}');

                evtSource.onmessage = function (event) {
                    const data = JSON.parse(event.data);

                    const activeEl = document.getElementById('countActive');
                    if (activeEl && typeof data.active !== 'undefined') {
                        animateCounter(activeEl, data.active);
                    }

                    const now = data.time || new Date().toLocaleTimeString();
                    liveTrafficData.labels.push(now);
                    liveTrafficData.datasets[0].data.push(data.views ?? 0);

                    if (liveTrafficData.labels.length > 20) {
                        liveTrafficData.labels.shift();
                        liveTrafficData.datasets[0].data.shift();
                    }

                    liveTrafficChart.update();
                };
            </script>

        {% endblock %}

    {% endembed %}
{% endblock %}