{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.dashboard.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}

            <div class="section-title">
                <h2>{{ 'admin.dashboard.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.dashboard.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section class="py-3">

                {# TOP STAT CARDS #}
                <div class="row g-4 mb-4">
                    {% set cards = [
                        {'label': 'admin.dashboard.total_users'|trans({}, 'admin'), 'value': stats.users, 'id': 'countUsers', 'icon': 'fa-users'},
                        {'label': 'admin.dashboard.page_views'|trans({}, 'admin'), 'value': stats.page_views_today, 'id': 'countViews', 'icon': 'fa-eye'},
                        {'label': 'admin.dashboard.active_sessions'|trans({}, 'admin'), 'value': stats.active_sessions, 'id': 'countActive', 'icon': 'fa-bolt'},
                        {'label': 'admin.dashboard.errors_today'|trans({}, 'admin'), 'value': stats.errors_today, 'danger': true, 'id': 'countErrors', 'icon': 'fa-triangle-exclamation'}
                    ] %}

                    {% for c in cards %}
                        <div class="col-md-3 col-6">
                            <div class="admin-card">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="card-label">{{ c.label }}</div>
                                    <i class="fas {{ c.icon }} text-muted"></i>
                                </div>
                                <p class="card-value {{ c.danger is defined and c.danger ? 'text-danger' : '' }}" id="{{ c.id }}">
                                    {{ c.value }}
                                </p>
                            </div>
                        </div>
                    {% endfor %}
                </div>

                {# TRAFFIC + LIVE + DEVICES #}
                <div class="row g-4 mb-4">
                    <div class="col-lg-8">
                        <div class="admin-card mb-4">
                            <h5 class="mb-4">{{ 'admin.dashboard.traffic_7d'|trans({}, 'admin') }}</h5>
                            <canvas id="trafficChart" style="max-height: 350px;"></canvas>
                        </div>

                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.live_activity'|trans({}, 'admin') }}</h5>
                            <div class="d-flex align-items-center">
                                <div class="me-4 text-center">
                                    <div class="display-6 fw-bold text-accent" id="liveCount">0</div>
                                    <div class="small text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 1px;">Active</div>
                                </div>
                                <div class="flex-grow-1" style="min-height: 120px;">
                                    <canvas id="liveTrafficChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.device_dist'|trans({}, 'admin') }}</h5>
                            <div style="position: relative; height: 300px;">
                                <canvas id="deviceChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                {# BROWSERS + COUNTRIES #}
                <div class="row g-4 mb-4">

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.top_browsers'|trans({}, 'admin') }}</h5>
                            <div class="admin-list-group">
                                {% for b in stats.browsers %}
                                    <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="fas fa-globe me-2 text-muted"></i>
                                            <strong>{{ b.browser ?? 'Unknown' }}</strong>
                                            {% if b.version is defined and b.version %}
                                                <span class="text-muted small ms-1">v{{ b.version }}</span>
                                            {% endif %}
                                        </div>
                                        <span class="badge bg-dark">{{ b.total }}</span>
                                    </div>
                                {% else %}
                                    <div class="admin-list-group-item text-muted">No browser data yet.</div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.geo_dist'|trans({}, 'admin') }}</h5>
                            <canvas id="countryChart" style="max-height: 260px;"></canvas>
                            <div id="countryLegend" class="mt-4 d-flex flex-wrap gap-3"></div>
                        </div>
                    </div>

                </div>

                {# ROUTES + IPS #}
                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.top_routes'|trans({}, 'admin') }}</h5>
                            <div class="admin-list-group">
                                {% for route in stats.top_routes %}
                                    <div class="admin-list-group-item d-flex justify-content-between">
                                        <span class="text-truncate" title="{{ route.route }}">{{ route.route }}</span>
                                        <span class="fw-bold text-accent">{{ route.total }}</span>
                                    </div>
                                {% else %}
                                    <div class="admin-list-group-item text-muted">No data yet.</div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.top_ips'|trans({}, 'admin') }}</h5>
                            <div class="admin-list-group">
                                {% for ip in stats.top_ips %}
                                    <div class="admin-list-group-item d-flex justify-content-between">
                                        <span>
                                            <i class="fas fa-network-wired me-2 text-muted"></i>
                                            {{ ip.ip ?? 'Unknown' }}
                                            <span class="text-muted small ms-1">({{ ip.country ?? '??' }})</span>
                                        </span>
                                        <span class="fw-bold">{{ ip.total }}</span>
                                    </div>
                                {% else %}
                                    <div class="admin-list-group-item text-muted">No IP data yet.</div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                {# RECENT SESSIONS #}
                <div class="row g-4">
                    <div class="col-12">
                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.dashboard.recent_sessions'|trans({}, 'admin') }}</h5>
                            <div class="table-responsive">
                                <table class="admin-table">
                                    <thead>
                                        <tr>
                                            <th>IP Address</th>
                                            <th>Device / OS</th>
                                            <th>Browser</th>
                                            <th>Location</th>
                                            <th>Last Seen</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for s in stats.recent_sessions %}
                                            <tr>
                                                <td><code class="text-accent">{{ s.ip ?? 'Unknown' }}</code></td>
                                                <td>
                                                    {{ s.os ?? 'Unknown' }} {{ s.osVersion }}
                                                    <div class="small text-muted">{{ s.device ?? 'Unknown' }} {{ s.deviceModel }}</div>
                                                </td>
                                                <td>{{ s.browser ?? 'Unknown' }} <span class="small text-muted">v{{ s.browserVersion }}</span></td>
                                                <td>
                                                    <span class="fi fi-{{ s.country|lower }} me-2" title="{{ s.countryName ?? s.country ?? 'Unknown' }}" style="cursor: help;"></span>
                                                    {{ s.country ?? '??' }}
                                                </td>
                                                <td class="text-muted small">{{ s.lastSeenAt|date('Y-m-d H:i') }}</td>
                                            </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="5" class="text-center text-muted py-4">{{ 'admin.dashboard.no_sessions'|trans({}, 'admin') }}</td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

            </section>

            <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

            <script>
                document.addEventListener('DOMContentLoaded', () => {
                    const accentColor = '#0cc5b6';
                    const gridColor = 'rgba(255, 255, 255, 0.05)';
                    const textColor = '#8a949b';

                    Chart.defaults.color = textColor;
                    Chart.defaults.borderColor = gridColor;

                    /* -----------------------------
                       COUNTER ANIMATION
                    ------------------------------ */
                    function animateCounter(el, to) {
                        const duration = 800;
                        const start = parseInt(el.innerText.replace(/,/g, ''), 10) || 0;
                        const startTime = performance.now();

                        function frame(now) {
                            const progress = Math.min((now - startTime) / duration, 1);
                            const value = Math.floor(start + (to - start) * progress);
                            el.innerText = value.toLocaleString();
                            if (progress < 1) requestAnimationFrame(frame);
                        }
                        requestAnimationFrame(frame);
                    }

                    document.querySelectorAll('.card-value').forEach(el => {
                        animateCounter(el, parseInt(el.innerText.replace(/,/g, ''), 10) || 0);
                    });

                    /* -----------------------------
                       TRAFFIC – LAST 7 DAYS
                    ------------------------------ */
                    new Chart(document.getElementById('trafficChart'), {
                        type: 'line',
                        data: {
                            labels: {{ stats.traffic_last_7_days|map(d => d.date)|json_encode|raw }},
                            datasets: [{
                                label: 'Page Views',
                                data: {{ stats.traffic_last_7_days|map(d => d.total)|json_encode|raw }},
                                borderColor: accentColor,
                                backgroundColor: 'rgba(12, 197, 182, 0.1)',
                                tension: 0.4,
                                fill: true,
                                pointBackgroundColor: accentColor,
                                pointRadius: 4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: { beginAtZero: true, grid: { color: gridColor } },
                                x: { grid: { display: false } }
                            }
                        }
                    });

                    /* -----------------------------
                       DEVICES
                    ------------------------------ */
                    new Chart(document.getElementById('deviceChart'), {
                        type: 'doughnut',
                        data: {
                            labels: {{ stats.devices|map(d => (d.device ?? 'Unknown'))|json_encode|raw }},
                            datasets: [{
                                data: {{ stats.devices|map(d => d.total)|json_encode|raw }},
                                backgroundColor: [accentColor, '#5c6bc0', '#66bb6a', '#ffa726'],
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { position: 'bottom', labels: { boxWidth: 12, usePointStyle: true } }
                            },
                            cutout: '70%'
                        }
                    });

                    /* -----------------------------
                       COUNTRIES
                    ------------------------------ */
                    const countryData = {{ stats.countries|json_encode|raw }};
                    const countryLabels = countryData.map(c => (c.country ?? '??'));
                    const countryValues = countryData.map(c => c.total);
                    const countryNames = countryData.map(c => (c.countryName ?? c.country ?? 'Unknown'));

                    new Chart(document.getElementById('countryChart'), {
                        type: 'bar',
                        data: {
                            labels: countryLabels,
                            datasets: [{
                                label: 'Visitors',
                                data: countryValues,
                                backgroundColor: accentColor,
                                borderRadius: 4
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { beginAtZero: true, grid: { color: gridColor } },
                                x: { grid: { display: false } }
                            }
                        }
                    });

                    const legend = document.getElementById('countryLegend');
                    countryLabels.forEach((code, i) => {
                    const div = document.createElement('div');
                    const flagCode = code.toLowerCase();
                    const countryName = countryNames[i];

                    div.innerHTML = `
                        <span class="badge bg-light border text-dark d-flex align-items-center gap-2 py-2 px-3">
                            <span class="fi fi-${flagCode} rounded-1" title="${countryName}" style="cursor: help;"></span>
                            <span class="fw-bold">${countryValues[i]}</span>
                            <span class="text-muted">${code}</span>
                        </span>
                    `;

                    legend.appendChild(div);
                });


                    /* -----------------------------
                       LIVE TRAFFIC – ACTIVE USERS
                    ------------------------------ */
                    const liveTrafficCtx = document.getElementById('liveTrafficChart').getContext('2d');
                    const liveTrafficData = {
                        labels: [],
                        datasets: [{
                            label: 'Active Users',
                            data: [],
                            borderColor: accentColor,
                            backgroundColor: 'rgba(12, 197, 182, 0.05)',
                            tension: 0.4,
                            fill: true,
                            pointRadius: 0
                        }]
                    };

                    const liveTrafficChart = new Chart(liveTrafficCtx, {
                        type: 'line',
                        data: liveTrafficData,
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                y: { 
                                    beginAtZero: true, 
                                    display: true,
                                    grid: { color: gridColor },
                                    ticks: { precision: 0, stepSize: 1 }
                                },
                                x: { 
                                    display: true,
                                    grid: { display: false },
                                    ticks: { maxTicksLimit: 5, maxRotation: 0 }
                                }
                            }
                        }
                    });

                    function updateLiveUsers() {
                        fetch('{{ path('live_users') }}')
                            .then(res => res.json())
                            .then(json => {
                                const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                                liveTrafficData.labels.push(now);
                                liveTrafficData.datasets[0].data.push((json.active ?? 0));
                                if (liveTrafficData.labels.length > 20) {
                                    liveTrafficData.labels.shift();
                                    liveTrafficData.datasets[0].data.shift();
                                }
                                
                                const liveCountEl = document.getElementById('liveCount');
                                if (liveCountEl) animateCounter(liveCountEl, json.active);

                                const activeEl = document.getElementById('countActive');
                                if (activeEl) animateCounter(activeEl, json.active);
                                
                                liveTrafficChart.update();
                            })
                            .catch(err => console.error('Live traffic error:', err));
                    }

                    setInterval(updateLiveUsers, 5000);
                    updateLiveUsers();
                });
            </script>

            <style>
                .text-accent { color: var(--admin-accent); }
            </style>

        {% endblock %}

    {% endembed %}
{% endblock %}
