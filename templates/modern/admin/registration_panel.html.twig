{% extends '@theme/base.html.twig' %}

{% block title %}Registration Panel – Admin{% endblock %}

{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_layout.html.twig' %}

    {% block admin_content %}
    <section class="section-page-title text-center py-4">
        <h2 class="display-6 fw-bold">Registration Control</h2>
        <p class="text-muted">Manage public registration and waitlist.</p>
    </section>

    <section class="py-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
                <div>
                    <h5 class="mb-1">Status</h5>
                    {% if registration_enabled %}
                        <p class="mb-0 text-success">Registration is <strong>ONLINE</strong>.</p>
                    {% else %}
                        <p class="mb-0 text-danger">Registration is <strong>OFFLINE</strong>.</p>
                    {% endif %}
                    <p class="small text-muted mb-0">
                        Waitlist entries: <strong>{{ waitlist_count }}</strong>
                    </p>
                </div>

                <form method="post" action="{{ path('admin_registration_toggle') }}">
                    <button class="btn {{ registration_enabled ? 'btn-danger' : 'btn-success' }}">
                        {{ registration_enabled ? 'Disable Registration' : 'Enable Registration' }}
                    </button>
                </form>
            </div>
        </div>
    </section>
            {% endblock %}

    {% endembed %}

{% endblock %}