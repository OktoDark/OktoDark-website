{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.registration.title'|trans({}, 'admin') }} – Admin{% endblock %}

{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.registration.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.registration.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                <div class="admin-card">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                        <div>
                            <h5 class="mb-1 text-white">{{ 'admin.registration.status'|trans({}, 'admin') }}</h5>
                            {% if registration_enabled %}
                                <p class="mb-0 text-success"><i class="fas fa-check-circle me-2"></i>{{ 'admin.registration.online'|trans({}, 'admin') }}</p>
                            {% else %}
                                <p class="mb-0 text-danger"><i class="fas fa-times-circle me-2"></i>{{ 'admin.registration.offline'|trans({}, 'admin') }}</p>
                            {% endif %}
                            <p class="small text-muted mb-0 mt-2">
                                {{ 'admin.registration.entries'|trans({}, 'admin') }}: <strong>{{ waitlist_count }}</strong>
                            </p>
                        </div>

                        <form method="post" action="{{ path('admin_registration_toggle') }}">
                            <button type="submit" class="admin-btn {{ registration_enabled ? 'admin-btn-danger' : 'admin-btn-primary' }}">
                                <i class="fas {{ registration_enabled ? 'fa-ban' : 'fa-check' }} me-2"></i>
                                {{ registration_enabled ? 'admin.registration.disable'|trans({}, 'admin') : 'admin.registration.enable'|trans({}, 'admin') }}
                            </button>
                        </form>
                    </div>
                </div>
            </section>
        {% endblock %}

    {% endembed %}

{% endblock %}
