{% extends '@theme/base.html.twig' %}
{% block title %}{{ 'admin.team.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.team.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.team.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                {# ADD / EDIT FORM #}
                <div class="admin-card mb-5" id="formContainer">
                    <h4 class="mb-4" id="formTitle">{{ 'admin.team.add_edit'|trans({}, 'admin') }}</h4>

                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="id" id="memberId">

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="admin-form-label">{{ 'admin.team.position'|trans({}, 'admin') }}</label>
                                <input type="text" name="position" id="position" class="admin-form-control" required placeholder="e.g. Creative Director">
                            </div>

                            <div class="col-md-6">
                                <label class="admin-form-label">{{ 'admin.team.name'|trans({}, 'admin') }}</label>
                                <input type="text" name="name" id="name" class="admin-form-control" required placeholder="e.g. Jane Doe">
                            </div>

                            <div class="col-12">
                                <label class="admin-form-label">{{ 'admin.team.bio'|trans({}, 'admin') }}</label>
                                <textarea name="description" id="description" class="admin-form-control" rows="4" placeholder="Describe the member's contribution and expertise..."></textarea>
                            </div>

                            <div class="col-md-6">
                                <label class="admin-form-label">{{ 'admin.team.image'|trans({}, 'admin') }}</label>
                                <input type="file" name="teamImage" class="admin-form-control">
                                <small class="text-muted mt-2 d-block">Recommended size: 500x500px. JPG, PNG or WebP.</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="reset" class="admin-btn admin-btn-secondary" onclick="resetForm()">{{ 'admin.common.clear'|trans({}, 'admin') }}</button>
                            <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.common.save'|trans({}, 'admin') }}</button>
                        </div>
                    </form>
                </div>

                {# TEAM LIST #}
                <div class="admin-table-container">
                    <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{ 'admin.team.current'|trans({}, 'admin') }}</h4>
                        <span class="badge bg-dark">{{ team|length }} Members</span>
                    </div>

                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th style="width: 80px;">Profile</th>
                                <th>Identity</th>
                                <th>{{ 'admin.team.position'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.team.bio'|trans({}, 'admin') }}</th>
                                <th class="text-end">{{ 'admin.forum.categories.actions'|trans({}, 'admin') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for member in team %}
                                <tr>
                                    <td>
                                        {% if member.teamImage %}
                                            <img src="/uploads/team/{{ member.teamImage }}" alt="{{ member.name }}" class="rounded shadow-sm" style="width: 50px; height: 50px; object-fit: cover; border: 1px solid var(--admin-border);">
                                        {% else %}
                                            <div class="rounded bg-secondary d-flex align-items-center justify-content-center text-white-50" style="width: 50px; height: 50px;">
                                                <i class="fas fa-user"></i>
                                            </div>
                                        {% endif %}
                                    </td>

                                    <td><span class="fw-bold text-white">{{ member.name }}</span></td>
                                    <td><span class="admin-badge admin-badge-info">{{ member.position }}</span></td>
                                    <td><div class="small text-muted text-truncate" style="max-width: 300px;">{{ member.description }}</div></td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="admin-btn admin-btn-secondary admin-btn-sm"
                                                    onclick="editMember({{ member.id }}, '{{ member.position|e('js') }}', '{{ member.name|e('js') }}', '{{ member.description|e('js') }}')" title="{{ 'admin.common.edit'|trans({}, 'admin') }}">
                                                <i class="fas fa-edit"></i>
                                            </button>

                                            <a href="{{ path('admin_team', { delete: member.id }) }}"
                                               class="admin-btn admin-btn-danger admin-btn-sm"
                                               onclick="return confirm('Permanently remove this team member?')" title="{{ 'admin.common.delete'|trans({}, 'admin') }}">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <i class="fas fa-user-group d-block mb-3 fs-2 opacity-25"></i>
                                        {{ 'admin.team.no_members'|trans({}, 'admin') }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <script>
                function editMember(id, position, name, description) {
                    document.getElementById('formTitle').innerText = '{{ 'admin.common.edit'|trans({}, 'admin') }}: ' + name;
                    document.getElementById('memberId').value = id;
                    document.getElementById('position').value = position;
                    document.getElementById('name').value = name;
                    document.getElementById('description').value = description;

                    document.getElementById('formContainer').scrollIntoView({ behavior: 'smooth' });
                }

                function resetForm() {
                    document.getElementById('formTitle').innerText = '{{ 'admin.team.add_edit'|trans({}, 'admin') }}';
                    document.getElementById('memberId').value = '';
                }
            </script>
        {% endblock %}

    {% endembed %}
{% endblock %}
