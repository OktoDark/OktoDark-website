{% extends "@theme/base.html.twig" %}
{% block title %}{{ 'admin.contact.view_message'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <a href="{{ path('admin_contact_index') }}" class="admin-btn admin-btn-secondary admin-btn-sm">
                    <i class="fas fa-arrow-left"></i> {{ 'admin.contact.back_to_inbox'|trans({}, 'admin') }}
                </a>
                
                <form method="post" action="{{ path('admin_contact_delete', {'id': message.id}) }}" onsubmit="return confirm('Are you sure you want to delete this message?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ message.id) }}">
                    <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">
                        <i class="fas fa-trash"></i> {{ 'admin.contact.delete_message'|trans({}, 'admin') }}
                    </button>
                </form>
            </div>

            <div class="admin-card mb-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h4 class="mb-1 text-white">{{ 'admin.contact.subject'|trans({}, 'admin') }}: {{ message.subject }}</h4>
                        <div class="text-muted">
                            {{ 'admin.contact.from'|trans({}, 'admin') }}: <strong class="text-white">{{ message.name }}</strong> 
                            <span class="mx-2">&bull;</span> 
                            {{ 'admin.contact.department'|trans({}, 'admin') }}: <span class="admin-badge admin-badge-info">{{ message.department }}</span>
                        </div>
                    </div>
                    <div class="text-end">
                        <div class="small text-muted">{{ message.createdAt|date('F j, Y') }}</div>
                        <div class="small text-muted">{{ message.createdAt|date('H:i') }}</div>
                    </div>
                </div>

                <div class="p-4 rounded-3 border border-secondary border-opacity-10 bg-black bg-opacity-25">
                    <div class="admin-form-label mb-2 text-white-50">{{ 'admin.contact.original_message'|trans({}, 'admin') }}</div>
                    <div class="text-white" style="white-space: pre-wrap; line-height: 1.6;">{{ message.message }}</div>
                </div>
            </div>

            {% if message.replyMessage %}
                <div class="admin-card border-success border-opacity-25">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="mb-0 text-success"><i class="fas fa-reply me-2"></i>{{ 'admin.contact.our_response'|trans({}, 'admin') }}</h5>
                        <small class="text-muted">{{ 'admin.contact.replied_on'|trans({}, 'admin') }} {{ message.repliedAt|date('M j, Y H:i') }}</small>
                    </div>
                    <div class="p-3 rounded-3 bg-success bg-opacity-10 text-white" style="white-space: pre-wrap; line-height: 1.6;">{{ message.replyMessage }}</div>
                </div>
            {% else %}
                <div class="admin-card">
                    <h5 class="mb-4 text-white"><i class="fas fa-pen-nib me-2"></i>{{ 'admin.contact.write_reply'|trans({}, 'admin') }}</h5>
                    <form method="POST">
                        <input type="hidden" name="csrf_token" value="{{ csrf_token('admin_reply_contact') }}">

                        <div class="mb-4">
                            <label class="admin-form-label">{{ 'admin.contact.response_message'|trans({}, 'admin') }}</label>
                            <textarea name="reply_message" class="admin-form-control text-white" rows="6" placeholder="Type your response to {{ message.name }} here..."></textarea>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="admin-btn admin-btn-primary px-5">
                                <i class="fas fa-paper-plane"></i> {{ 'admin.contact.send_reply_archive'|trans({}, 'admin') }}
                            </button>
                        </div>
                    </form>
                </div>
            {% endif %}
        {% endblock %}
    {% endembed %}
{% endblock %}
