{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'admin.contact.inbox'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.contact.inbox'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.contact.inbox_subtitle'|trans({}, 'admin') }}</p>
            </div>

            <!-- Search Bar -->
            <form method="get" action="{{ path('admin_contact_index') }}" class="mb-4" id="searchForm">
                <input type="text"
                       name="search"
                       value="{{ app.request.query.get('search') }}"
                       placeholder="{{ 'admin.common.search'|trans({}, 'admin') }}"
                       class="form-control"
                       oninput="debouncedSearch()">
            </form>

            <script>
                var searchTimer;

                function debouncedSearch() {
                    clearTimeout(searchTimer);

                    searchTimer = setTimeout(function () {
                        document.getElementById('searchForm').submit();
                    }, 350); // delay in ms (300–400ms feels perfect)
                }
            </script>

            <!-- Flash Messages -->
            {% for message in app.flashes('success') %}
                <div class="alert alert-success border-0 shadow-sm mb-4">
                    <i class="fas fa-check-circle me-2"></i> {{ message }}
                </div>
            {% endfor %}

            <div class="admin-table-container">
                <div class="table-responsive">
                    <table class="admin-table">
                        <thead>
                        <tr>
                            <th>{{ 'admin.contact.status'|trans({}, 'admin') }}</th>
                            <th><a href="{{ path('admin_contact_index', {'sort': 'date', 'order': app.request.query.get('order') == 'asc' ? 'desc' : 'asc'}) }}">{{ 'admin.contact.date'|trans({}, 'admin') }}</a></th>
                            <th><a href="{{ path('admin_contact_index', {'sort': 'sender', 'order': app.request.query.get('order') == 'asc' ? 'desc' : 'asc'}) }}">{{ 'admin.contact.sender'|trans({}, 'admin') }}</a></th>
                            <th>{{ 'admin.contact.department'|trans({}, 'admin') }}</th>
                            <th><a href="{{ path('admin_contact_index', {'sort': 'subject', 'order': app.request.query.get('order') == 'asc' ? 'desc' : 'asc'}) }}">{{ 'admin.contact.subject'|trans({}, 'admin') }}</a></th>
                            <th class="text-end">{{ 'admin.common.actions'|trans({}, 'admin') }}</th>
                        </tr>
                        </thead>

                        <tbody>
                        {% for m in messages %}
                            <tr class="{{ not m.isRead ? 'fw-bold' : '' }}">
                                <td>
                                    {% if m.repliedAt %}
                                        <span class="badge bg-success d-inline-flex align-items-center gap-1">
                                            <i class="fas fa-check-circle"></i>
                                            {{ 'admin.contact.replied'|trans({}, 'admin') }}
                                        </span>
                                    {% elseif m.isRead %}
                                        <span class="badge bg-secondary d-inline-flex align-items-center gap-1">
                                            <i class="fas fa-envelope-open"></i>
                                            {{ 'admin.contact.read'|trans({}, 'admin') }}
                                        </span>
                                    {% else %}
                                        <span class="badge bg-info text-dark d-inline-flex align-items-center gap-1">
                                            <i class="fas fa-envelope"></i>
                                            {{ 'admin.contact.new'|trans({}, 'admin') }}
                                        </span>
                                    {% endif %}
                                </td>

                                <td>
                                    <div class="small">{{ m.createdAt|date('M j, Y') }}</div>
                                    <div class="small text-muted">{{ m.createdAt|date('H:i') }}</div>
                                </td>

                                <td>
                                    <div class="fw-bold">{{ m.name }}</div>
                                    <div class="small text-muted">{{ m.email }}</div>
                                </td>

                                <td>
                                    {% set deptColor = {
                                        'staff': 'bg-primary',
                                        'webmaster': 'bg-warning text-dark',
                                        'services': 'bg-success',
                                    }[m.department] ?? 'bg-secondary' %}

                                    <span class="badge {{ deptColor }}">{{ m.department }}</span>
                                </td>

                                <td>{{ m.subject }}</td>

                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">

                                        {# VIEW BUTTON #}
                                        <a href="{{ path('admin_contact_show', {id: m.id}) }}"
                                           class="btn btn-sm btn-light border px-3 py-2 d-inline-flex align-items-center justify-content-center"
                                           title="{{ 'admin.contact.view_message'|trans({}, 'admin') }}">
                                            <i class="fas fa-eye text-secondary"></i>
                                        </a>

                                        {# DELETE BUTTON #}
                                        <form method="post"
                                              action="{{ path('admin_contact_delete', {'id': m.id}) }}"
                                              onsubmit="return confirm('Are you sure you want to delete this message?');"
                                              class="d-inline">

                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ m.id) }}">

                                            <button type="submit"
                                                    class="btn btn-sm btn-light border px-3 py-2 d-inline-flex align-items-center justify-content-center"
                                                    title="{{ 'admin.contact.delete_message'|trans({}, 'admin') }}">
                                                <i class="fas fa-trash text-danger"></i>
                                            </button>
                                        </form>

                                    </div>
                                </td>

                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="fas fa-inbox d-block mb-3 fs-2 opacity-25"></i>
                                    {{ 'admin.contact.no_messages'|trans({}, 'admin') }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>

                    </table>
                </div>
            </div>

            <!-- Pagination -->
            {% set inactiveColor = 'text-dark' %}
            {% set activeTextColor = 'text-light' %}
            {% set activeBgColor = 'bg-primary' %}

            {% set start = current_page - 2 %}
            {% set end = current_page + 2 %}

            {% if start < 1 %}
                {% set end = end + (1 - start) %}
                {% set start = 1 %}
            {% endif %}

            {% if end > last_page %}
                {% set start = start - (end - last_page) %}
                {% set end = last_page %}
            {% endif %}

            {% if start < 1 %}
                {% set start = 1 %}
            {% endif %}

            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">

                    {# FIRST << #}
                    <li class="page-item {{ current_page == 1 ? 'disabled' : '' }}">
                        <a class="page-link py-1 px-2 {{ inactiveColor }}"
                           href="{{ current_page > 1 ? path('admin_contact_index', {
                               page: 1,
                               search: app.request.query.get('search'),
                               sort: app.request.query.get('sort'),
                               order: app.request.query.get('order')
                           }) : '#' }}">
                            <i class="fas fa-angle-double-left"></i>
                        </a>
                    </li>

                    {# PREVIOUS < #}
                    <li class="page-item {{ current_page == 1 ? 'disabled' : '' }}">
                        <a class="page-link py-1 px-2 {{ inactiveColor }}"
                           href="{{ current_page > 1 ? path('admin_contact_index', {
                               page: current_page - 1,
                               search: app.request.query.get('search'),
                               sort: app.request.query.get('sort'),
                               order: app.request.query.get('order')
                           }) : '#' }}">
                            <i class="fas fa-angle-left"></i>
                        </a>
                    </li>

                    {# LEFT ELLIPSIS #}
                    {% if start > 1 %}
                        <li class="page-item disabled">
                            <span class="page-link py-1 px-2">…</span>
                        </li>
                    {% endif %}

                    {# PAGE NUMBERS #}
                    {% for page in start..end %}
                        <li class="page-item {{ page == current_page ? 'active' : '' }}">
                            <a href="{{ path('admin_contact_index', {
                                page: page,
                                search: app.request.query.get('search'),
                                sort: app.request.query.get('sort'),
                                order: app.request.query.get('order')
                            }) }}"
                               class="page-link fw-semibold py-1 px-2
                          {{ page == current_page
                               ? activeTextColor ~ ' ' ~ activeBgColor
                               : inactiveColor }}">
                                {{ page }}
                            </a>
                        </li>
                    {% endfor %}

                    {# RIGHT ELLIPSIS #}
                    {% if end < last_page %}
                        <li class="page-item disabled">
                            <span class="page-link py-1 px-2">…</span>
                        </li>
                    {% endif %}

                    {# NEXT > #}
                    <li class="page-item {{ current_page == last_page ? 'disabled' : '' }}">
                        <a class="page-link py-1 px-2 {{ inactiveColor }}"
                           href="{{ current_page < last_page ? path('admin_contact_index', {
                               page: current_page + 1,
                               search: app.request.query.get('search'),
                               sort: app.request.query.get('sort'),
                               order: app.request.query.get('order')
                           }) : '#' }}">
                            <i class="fas fa-angle-right"></i>
                        </a>
                    </li>

                    {# LAST >> #}
                    <li class="page-item {{ current_page == last_page ? 'disabled' : '' }}">
                        <a class="page-link py-1 px-2 {{ inactiveColor }}"
                           href="{{ current_page < last_page ? path('admin_contact_index', {
                               page: last_page,
                               search: app.request.query.get('search'),
                               sort: app.request.query.get('sort'),
                               order: app.request.query.get('order')
                           }) : '#' }}">
                            <i class="fas fa-angle-double-right"></i>
                        </a>
                    </li>

                </ul>
            </nav>

        {% endblock %}
    {% endembed %}
{% endblock %}