{% extends '@theme/base.html.twig' %}

{% block title %}Admin – Import Dashboard{% endblock %}
{% block head %}{{ parent() }}{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>Import Dashboard</h2>
                <p>Manage database integrity, cleanup legacy data, and rebuild metadata.</p>
            </div>

            <section class="py-3">

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Cleanup Legacy Data</h5>
                            <p class="text-muted small mb-3">
                                Removes corrupted movie-season and movie-TV entries created before the schema fix.
                            </p>
                            <form method="post" action="{{ path('admin_import_cleanup') }}" onsubmit="return handlePost(this, 'cleanupResult');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_cleanup') }}">
                                <button type="submit" class="btn btn-warning">Run Cleanup</button>
                            </form>
                            <div id="cleanupResult" class="mt-3"></div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Remove Duplicates</h5>
                            <p class="text-muted small mb-3">
                                Deletes duplicate MediaMetadata, Movies, TV entries, Seasons, and Episodes.
                            </p>
                            <form method="post" action="{{ path('admin_import_remove_duplicates') }}" onsubmit="return handlePost(this, 'removeDuplicatesResult');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_remove_duplicates') }}">
                                <button type="submit" class="btn btn-outline-danger">Remove Duplicates</button>
                            </form>
                            <div id="removeDuplicatesResult" class="mt-3"></div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Rebuild Metadata (TMDB)</h5>
                            <p class="text-muted small mb-3">
                                Re-fetches and updates image, overview, genres, runtime, and externalId for all metadata.
                            </p>
                            <form method="post" action="{{ path('admin_import_rebuild_metadata') }}" onsubmit="return handlePost(this, 'rebuildMetadataResult');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_rebuild_metadata') }}">
                                <button type="submit" class="btn btn-primary">Rebuild Metadata</button>
                            </form>
                            <div id="rebuildMetadataResult" class="mt-3"></div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Purge Orphaned Entities</h5>
                            <p class="text-muted small mb-3">
                                Deletes Episodes, Seasons, TV, Movies, and MediaMetadata records that are no longer linked.
                            </p>
                            <form method="post" action="{{ path('admin_import_purge_orphans') }}" onsubmit="return handlePost(this, 'purgeOrphansResult');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_purge_orphans') }}">
                                <button type="submit" class="btn btn-outline-warning">Purge Orphans</button>
                            </form>
                            <div id="purgeOrphansResult" class="mt-3"></div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Recompute TV Progress</h5>
                            <p class="text-muted small mb-3">
                                Recalculates <code>progress</code> and <code>status</code> for all TV shows from their watched episodes.
                                Use this if Continue Watching shows incorrect percentages or missing entries.
                            </p>
                            <form method="post" action="{{ path('admin_import_recompute_tv_progress') }}" onsubmit="return handlePost(this, 'recomputeTvProgressResult');">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_recompute_tv_progress') }}">
                                <button type="submit" class="btn btn-info">Recompute TV Progress</button>
                            </form>
                            <div id="recomputeTvProgressResult" class="mt-3"></div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="admin-card">
                            <h5 class="mb-3">Validate Database Integrity</h5>
                            <p class="text-muted small mb-3">
                                Scans for duplicates, orphans, missing metadata, and corrupted relationships without modifying data.
                            </p>
                            <form method="get" action="{{ path('admin_import_validate_integrity') }}" onsubmit="return handleGet(this, 'validateIntegrityResult');">
                                <button type="submit" class="btn btn-outline-success">Validate Integrity</button>
                            </form>
                            <div id="validateIntegrityResult" class="mt-3"></div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-12">
                        <div class="admin-card">
                            <h5 class="mb-3">Backfill Missing Metadata (TMDB)</h5>
                            <p class="text-muted small mb-3">
                                Resolves missing <code>external_id</code> values by title-searching TMDB.
                                Runs in the background; output streams below. Defaults to a safe <strong>dry-run</strong> —
                                tick “Apply” to persist matches.
                            </p>
                            <form method="post" action="{{ path('admin_import_backfill_metadata') }}" onsubmit="return startBackfill(this);">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_import_backfill_metadata') }}">
                                <div class="row g-3 mb-3">
                                    <div class="col-md-3">
                                        <label class="form-label small">Media type</label>
                                        <select name="type" class="form-select form-select-sm">
                                            <option value="">All types</option>
                                            <option value="tv">tv</option>
                                            <option value="season">season</option>
                                            <option value="episode">episode</option>
                                            <option value="movie">movie</option>
                                            <option value="anime">anime</option>
                                            <option value="manga">manga</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small">Source (optional)</label>
                                        <input type="text" name="source" class="form-control form-control-sm" placeholder="manual, tmdb…">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Limit (0 = all)</label>
                                        <input type="number" name="limit" class="form-control form-control-sm" value="0" min="0">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Delay (ms)</label>
                                        <input type="number" name="delay" class="form-control form-control-sm" value="100" min="0">
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label small">Batch</label>
                                        <input type="number" name="batch" class="form-control form-control-sm" value="200" min="1">
                                    </div>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="apply" id="backfillApply" value="1">
                                    <label class="form-check-label small" for="backfillApply">
                                        Apply (write to database). Leave unchecked for a dry-run.
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="autorebuild" id="backfillAutorebuild" value="1" checked>
                                    <label class="form-check-label small" for="backfillAutorebuild">
                                        Auto-rebuild metadata after backfill (fully hydrates linked rows in one click).
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-success">Start Backfill</button>
                                <button type="button" class="btn btn-outline-danger" id="backfillStopBtn" disabled onclick="return stopBackfill();">Stop</button>
                                <span id="backfillResult" class="ms-2 d-inline-block align-middle"></span>
                            </form>

                            <pre id="backfillLog" class="bg-dark text-light p-3 rounded small mt-3" style="max-height: 320px; overflow-y: auto; white-space: pre-wrap;"></pre>

                            <div id="backfillRebuild" class="mt-3"></div>

                            <div class="mt-3 small text-muted">
                                <strong>Suggested workflow:</strong>
                                <ol class="mb-0">
                                    <li>Run a <em>dry-run</em> first (Apply unchecked) and review the “Matched” count.</li>
                                    <li>Backfill per type (e.g. <code>tv</code>) in chunks via <code>Limit</code> if the set is large.</li>
                                    <li>After linking IDs, <strong>Rebuild Metadata</strong> fully hydrates images/overviews — it runs automatically when the box above is ticked.</li>
                                    <li>Anime / manga are now resolved via AniList; game / book / comic rows remain skipped (no title provider).</li>
                                </ol>
                            </div>

                            <div class="mt-4 p-3 border rounded bg-light">
                                <h6 class="mb-2">Schedule automatically (cron)</h6>
                                <p class="small text-muted mb-2">
                                    Run unattended on a schedule to resolve newly-imported rows missing an
                                    <code>external_id</code>. Copy the line below into your server crontab
                                    (<code>crontab -e</code>); it runs hourly, in apply mode, with a safe rate limit:
                                </p>
<pre class="bg-dark text-light p-2 rounded small mb-0" style="white-space: pre-wrap;">0 * * * * {{ projectDir }}/bin/console yamtrack:backfill-metadata --apply --limit=500 --delay-ms=150 >> {{ projectDir }}/var/log/backfill_cron.log 2>&1</pre>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-12">
                        <div class="admin-card">
                            <h5 class="mb-3">Import Logs</h5>
                            <pre id="logsBox" class="bg-dark text-light p-3 rounded small" style="max-height: 300px; overflow-y: auto;">{{ logs|join('\n') }}</pre>
                        </div>
                    </div>
                </div>

            </section>

        {% endblock %}
    {% endembed %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        function handlePost(form, resultId) {
            const resultDiv = document.getElementById(resultId);
            resultDiv.innerHTML = '<div class="alert alert-info">Processing...</div>';

            fetch(form.action, {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                },
                body: new FormData(form),
            })
            .then(r => r.json())
            .then(data => {
                if (data.status) {
                    resultDiv.innerHTML = '<div class="alert alert-success">Operation completed successfully.</div>';
                } else {
                    resultDiv.innerHTML = '<div class="alert alert-warning">Operation finished with unknown status.</div>';
                }
                refreshLogs();
            })
            .catch(err => {
                resultDiv.innerHTML = '<div class="alert alert-danger">Error: ' + err + '</div>';
            });

            return false;
        }

        function refreshLogs() {
            fetch('{{ path("admin_import_dashboard") }}')
                .then(r => r.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newLogs = doc.querySelector('#logsBox');
                    if (newLogs && document.getElementById('logsBox')) {
                        document.getElementById('logsBox').textContent = newLogs.textContent;
                    }
                })
                .catch(() => {});
        }

        let backfillTimer = null;

        function startBackfill(form) {
            const resultDiv = document.getElementById('backfillResult');
            const stopBtn = document.getElementById('backfillStopBtn');
            resultDiv.innerHTML = '<div class="alert alert-info">Starting backfill…</div>';
            stopBtn.disabled = false;

            fetch(form.action, {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: new FormData(form),
            })
            .then(r => r.json())
            .then(data => {
                if (data.status === 'already_running') {
                    resultDiv.innerHTML = '<div class="alert alert-warning">A backfill is already running.</div>';
                    pollBackfill();
                } else if (data.status === 'started') {
                    resultDiv.innerHTML = '<div class="alert alert-success">Backfill started. Streaming log below…</div>';
                    pollBackfill();
                } else if (data.status === 'error') {
                    stopBtn.disabled = true;
                    resultDiv.innerHTML = '<div class="alert alert-danger">' + (data.message || 'Error') + '</div>';
                } else {
                    stopBtn.disabled = true;
                    resultDiv.innerHTML = '<div class="alert alert-warning">Unknown response.</div>';
                }
            })
            .catch(err => {
                stopBtn.disabled = true;
                resultDiv.innerHTML = '<div class="alert alert-danger">Error: ' + err + '</div>';
            });

            return false;
        }

        function stopBackfill() {
            const resultDiv = document.getElementById('backfillResult');
            const stopBtn = document.getElementById('backfillStopBtn');
            resultDiv.innerHTML = '<div class="alert alert-info">Stopping backfill…</div>';
            stopBtn.disabled = true;

            fetch('{{ path("admin_import_backfill_metadata_stop") }}', {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: new FormData(document.querySelector('form[action="{{ path("admin_import_backfill_metadata") }}"]')),
            })
            .then(r => r.json())
            .then(() => {
                if (backfillTimer) {
                    clearInterval(backfillTimer);
                    backfillTimer = null;
                }
                resultDiv.innerHTML = '<div class="alert alert-warning">Backfill stopped.</div>';
                pollBackfill(true);
            })
            .catch(err => {
                resultDiv.innerHTML = '<div class="alert alert-danger">Error: ' + err + '</div>';
            });

            return false;
        }

        function pollBackfill(afterStop) {
            if (backfillTimer) {
                clearInterval(backfillTimer);
            }

            const logBox = document.getElementById('backfillLog');
            const resultDiv = document.getElementById('backfillResult');
            const stopBtn = document.getElementById('backfillStopBtn');
            let settled = false;

            function finish() {
                if (settled) {
                    return;
                }
                settled = true;
                clearInterval(backfillTimer);
                backfillTimer = null;
                stopBtn.disabled = true;

                const autorebuild = document.getElementById('backfillAutorebuild');
                if (!afterStop && autorebuild && autorebuild.checked) {
                    resultDiv.innerHTML = '<div class="alert alert-success">Backfill finished. Rebuilding metadata…</div>';
                    autoRebuild();
                } else {
                    resultDiv.innerHTML = '<div class="alert alert-success">Backfill finished.</div>';
                }
            }

            backfillTimer = setInterval(() => {
                fetch('{{ path("admin_import_backfill_metadata_status") }}')
                    .then(r => r.json())
                    .then(data => {
                        logBox.textContent = data.log || '';
                        logBox.scrollTop = logBox.scrollHeight;

                        if (!data.running) {
                            finish();
                        }
                    })
                    .catch(() => {});
            }, 2000);
        }

        function autoRebuild() {
            const div = document.getElementById('backfillRebuild');
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '{{ path("admin_import_rebuild_metadata") }}';
            form.style.display = 'none';
            const token = document.querySelector('input[name="_token"][value="{{ csrf_token("admin_import_rebuild_metadata") }}"]');
            if (token) {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = '_token';
                input.value = token.value;
                form.appendChild(input);
            }
            document.body.appendChild(form);

            fetch(form.action, {
                method: 'POST',
                headers: { 'Accept': 'application/json' },
                body: new FormData(form),
            })
            .then(r => r.json())
            .then(() => {
                div.innerHTML = '<div class="alert alert-success">Metadata rebuilt for linked rows.</div>';
                refreshLogs();
            })
            .catch(err => {
                div.innerHTML = '<div class="alert alert-danger">Rebuild failed: ' + err + '</div>';
            })
            .finally(() => {
                form.remove();
            });
        }

        function handleGet(form, resultId) {
            const resultDiv = document.getElementById(resultId);
            resultDiv.innerHTML = '<div class="alert alert-info">Processing...</div>';

            fetch(form.action, { method: 'GET', headers: { 'Accept': 'application/json' } })
                .then(r => r.json())
                .then(data => {
                    resultDiv.innerHTML = '<div class="alert alert-success">Integrity validated.</div>';
                    refreshLogs();
                })
                .catch(err => {
                    resultDiv.innerHTML = '<div class="alert alert-danger">Error: ' + err + '</div>';
                });

            return false;
        }
    </script>
{% endblock %}
