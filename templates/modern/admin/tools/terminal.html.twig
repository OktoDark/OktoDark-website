{% extends '@theme/base.html.twig' %}
{% block title %}{{ 'admin.terminal.title'|trans([], 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.terminal.title'|trans([], 'admin') }}</h2>
                <p>{{ 'admin.terminal.subtitle'|trans([], 'admin') }}</p>
            </div>

            <section>
                <div class="admin-card mb-4">
                    <div class="row g-4 align-items-end">
                        <div class="col-md-8">
                            <label class="admin-form-label">{{ 'admin.terminal.available_commands'|trans([], 'admin') }}</label>
                            <select id="command-select" class="admin-form-control">
                                <option value="">{{ 'admin.terminal.select_placeholder'|trans([], 'admin') }}</option>
                                {% for item in allowedCommands %}
                                    <option value="{{ item.cmd }}">{{ item.label }} ({{ item.cmd }})</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <button id="runBtn" class="admin-btn admin-btn-primary w-100 justify-content-center">
                                <i class="fas fa-play"></i> {{ 'admin.terminal.run_operation'|trans([], 'admin') }}
                            </button>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="progress" style="height: 8px; background-color: var(--admin-border);">
                        <div id="progress-bar" class="progress-bar" role="progressbar" style="width: 0%; background-color: var(--admin-accent);"></div>
                    </div>
                    <div id="progress-text" class="small text-muted mt-2 text-end">{{ 'admin.terminal.ready'|trans([], 'admin') }}</div>
                </div>

                <div class="admin-table-container">
                    <div class="p-3 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center bg-black bg-opacity-25">
                        <span class="small fw-bold text-muted text-uppercase"><i class="fas fa-terminal me-2"></i> {{ 'admin.terminal.console_output'|trans([], 'admin') }}</span>
                        <button class="admin-btn admin-btn-secondary admin-btn-sm" onclick="clearTerminal()">
                            <i class="fas fa-eraser"></i> {{ 'admin.terminal.clear_output'|trans([], 'admin') }}
                        </button>
                    </div>
                    <div id="terminal" class="terminal-window p-4"></div>
                </div>
            </section>

            <style>
                .terminal-window {
                    background: #000;
                    color: #d4d4d4;
                    min-height: 450px;
                    max-height: 600px;
                    overflow-y: auto;
                    font-family: 'JetBrains Mono', 'Fira Code', monospace;
                    font-size: 0.85rem;
                    line-height: 1.5;
                    white-space: pre-wrap;
                    scrollbar-width: thin;
                    scrollbar-color: var(--admin-border) transparent;
                }
                .cmd-prefix { color: var(--admin-accent); font-weight: bold; }
                .status-running { color: var(--admin-warning); }
                .status-finished { color: var(--admin-success); }
                .status-failed { color: var(--admin-danger); }
            </style>

            <script>
                const translations = {
                    ready: "{{ 'admin.terminal.ready'|trans([], 'admin')|escape('js') }}",
                    initializing: "{{ 'admin.terminal.status.initializing'|trans([], 'admin')|escape('js') }}",
                    started: "{{ 'admin.terminal.status.started'|trans([], 'admin')|escape('js') }}",
                    failed: "{{ 'admin.terminal.status.failed'|trans([], 'admin')|escape('js') }}",
                    serverError: "{{ 'admin.terminal.status.server_error'|trans([], 'admin')|escape('js') }}",
                    processing: "{{ 'admin.terminal.status.processing'|trans([], 'admin')|escape('js') }}",
                    success: "{{ 'admin.terminal.status.success'|trans([], 'admin')|escape('js') }}",
                    error: "{{ 'admin.terminal.status.error'|trans([], 'admin')|escape('js') }}"
                };

                function clearTerminal() {
                    document.getElementById('terminal').innerHTML = "";
                    const progress = document.getElementById('progress-bar');
                    progress.style.width = "0%";
                    document.getElementById('progress-text').innerText = translations.ready;
                }

                document.getElementById('runBtn').addEventListener('click', function () {
                    const cmdSelect = document.getElementById('command-select');
                    const cmd = cmdSelect.value;
                    const terminal = document.getElementById('terminal');
                    const progress = document.getElementById('progress-bar');
                    const progressText = document.getElementById('progress-text');
                    const runBtn = this;

                    if (!cmd) return;

                    terminal.innerHTML = "<span class='cmd-prefix'>$ " + cmd + "</span>\n<span class='status-running'>" + translations.initializing + "</span>\n";
                    progress.style.width = "5%";
                    progressText.innerText = translations.started;
                    runBtn.disabled = true;

                    const formData = new URLSearchParams();
                    formData.append('command', cmd);
                    formData.append('_token', '{{ csrf_token("terminal-run") }}');

                    fetch('{{ path("admin_tools_terminal_run") }}', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                        body: formData.toString()
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.error) {
                            terminal.innerHTML += "\n<span class='status-failed'>[FATAL ERROR] " + data.error + "</span>";
                            runBtn.disabled = false;
                            progressText.innerText = translations.failed;
                            return;
                        }
                        watchJob(data.jobId);
                    })
                    .catch(err => {
                        terminal.innerHTML += "\n<span class='status-failed'>[FATAL ERROR] " + translations.serverError + "</span>";
                        runBtn.disabled = false;
                    });
                });

                function watchJob(jobId) {
                    const terminal = document.getElementById('terminal');
                    const progress = document.getElementById('progress-bar');
                    const progressText = document.getElementById('progress-text');
                    const runBtn = document.getElementById('runBtn');

                    const interval = setInterval(() => {
                        const url = '{{ path("admin_tools_terminal_status", {id: "REPLACE"}) }}'.replace("REPLACE", jobId);
                        
                        fetch(url)
                        .then(r => r.json())
                        .then(data => {
                            if (data.output) {
                                terminal.innerText = data.output;
                                terminal.scrollTop = terminal.scrollHeight;

                                const match = data.output.match(/(\d+)%/);
                                if (match) {
                                    const percent = match[1];
                                    progress.style.width = percent + "%";
                                    progressText.innerText = translations.processing + ": " + percent + "%";
                                }
                            }

                            if (data.status === 'finished' || data.status === 'failed') {
                                clearInterval(interval);
                                runBtn.disabled = false;
                                
                                if (data.status === 'finished') {
                                    progress.style.width = "100%";
                                    progress.style.backgroundColor = "var(--admin-success)";
                                    progressText.innerText = translations.success;
                                } else {
                                    progress.style.backgroundColor = "var(--admin-danger)";
                                    progressText.innerText = translations.error;
                                }
                            }
                        });
                    }, 1000);
                }
            </script>
        {% endblock %}

    {% endembed %}
{% endblock %}
