{% extends '@theme/base.html.twig' %}
{% block title %}Services Management{% endblock %}
{% block body_id 'admin_services' %}

{% block main %}
    {% embed '@theme/admin/partials/_layout.html.twig' %}

        {% block admin_content %}

            <section class="section-page-title text-center py-4 fade-in">
                <h2 class="fw-bold">Services Management</h2>
                <p class="text-muted">Manage the services offered by OktoDark Studios.</p>
            </section>

            <section class="py-3 fade-in">

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                {# ADD / EDIT FORM #}
                <div class="card neon-card p-4 shadow-sm mb-4">
                    <h4 class="mb-3">Add / Edit Service</h4>

                    <form method="post">

                        <input type="hidden" name="id" id="serviceId">

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Service Name</label>
                                <input type="text" name="serviceName" id="serviceName" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Price</label>
                                <input type="text" name="servicePrice" id="servicePrice" class="form-control" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Work Days</label>
                                <input type="text" name="serviceWorkDays" id="serviceWorkDays" class="form-control" required>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-bold">Service Description</label>
                                <textarea name="serviceToDo" id="serviceToDo" class="form-control" rows="6"></textarea>
                            </div>

                        </div>

                        <div class="text-end mt-4">
                            <button class="btn btn-success px-4">Save Service</button>
                        </div>

                    </form>
                </div>

                {# SERVICES LIST #}
                <div class="card neon-card p-4 shadow-sm">
                    <h4 class="mb-3">Services</h4>

                    <div class="table-responsive">
                        <table class="table table-dark table-striped align-middle">
                            <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Work Days</th>
                                <th>Description</th>
                                <th class="text-end">Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for s in services %}
                                <tr>
                                    <td>{{ s.id }}</td>
                                    <td>{{ s.serviceName }}</td>
                                    <td>{{ s.servicePrice }}</td>
                                    <td>{{ s.serviceWorkDays }}</td>
                                    <td>{{ s.serviceToDo }}</td>

                                    <td class="text-end">
                                        <button class="btn btn-sm btn-primary"
                                                onclick="editService({{ s.id }}, '{{ s.serviceName|e('js') }}', '{{ s.servicePrice|e('js') }}', '{{ s.serviceWorkDays|e('js') }}', `{{ s.serviceToDo|e('js') }}`)">
                                            Edit
                                        </button>

                                        <a href="{{ path('admin_services', { delete: s.id }) }}"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Delete this service?')">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted">No services added yet.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>

                </div>

            </section>

            <script>
                function editService(id, name, price, days, todo) {
                    document.getElementById('serviceId').value = id;
                    document.getElementById('serviceName').value = name;
                    document.getElementById('servicePrice').value = price;
                    document.getElementById('serviceWorkDays').value = days;
                    document.getElementById('serviceToDo').value = todo;

                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            </script>

        {% endblock %}

    {% endembed %}
{% endblock %}