{% extends '@theme/base.html.twig' %}
{% block title %}{{ 'admin.careers.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.careers.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.careers.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                {# ADD / EDIT FORM #}
                <div class="admin-card mb-5" id="formContainer">
                    <h4 class="mb-4" id="form-title">{{ 'admin.careers.add_edit'|trans({}, 'admin') }}</h4>

                    <form method="post" id="careerForm">
                        <input type="hidden" name="id" id="careerId">

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="admin-form-label">{{ 'admin.careers.view_title'|trans({}, 'admin') }}</label>
                                <input type="text" name="jobTitle" id="jobTitle" class="admin-form-control" required placeholder="e.g. Senior Backend Developer">
                            </div>

                            <div class="col-md-3">
                                <label class="admin-form-label">{{ 'admin.careers.positions_open'|trans({}, 'admin') }}</label>
                                <input type="number" name="number" id="number" class="admin-form-control" required placeholder="1">
                            </div>

                            <div class="col-md-3">
                                <label class="admin-form-label">{{ 'admin.careers.publish_date'|trans({}, 'admin') }}</label>
                                <input type="datetime-local" name="publishedAt" id="publishedAt" class="admin-form-control" value="{{ "now"|date('Y-m-d\\TH:i') }}">
                            </div>

                            <div class="col-12">
                                <label class="admin-form-label mb-3">{{ 'admin.careers.required_technical_skills'|trans({}, 'admin') }}</label>
                                <div class="row g-2 mb-3">
                                    {% set common_langs = ['PHP', 'CSS', 'JavaScript', 'Python', 'C++', 'C#', 'Unity', 'Unreal Engine'] %}
                                    {% for lang in common_langs %}
                                        <div class="col-6 col-md-3">
                                            <div class="form-check custom-check">
                                                <input class="form-check-input lang-checkbox" type="checkbox" value="{{ lang }}" id="lang_{{ loop.index }}" name="requirements[]">
                                                <label class="form-check-label text-white small" for="lang_{{ loop.index }}">
                                                    {{ lang }}
                                                </label>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                                
                                <div id="custom-requirements-container">
                                    <label class="admin-form-label small">{{ 'admin.careers.additional_requirements'|trans({}, 'admin') }}</label>
                                    <div id="custom-reqs-list" class="d-flex flex-wrap gap-2 mb-3"></div>
                                    <button type="button" class="admin-btn admin-btn-secondary admin-btn-sm" onclick="addCustomRequirement()">
                                        <i class="fas fa-plus"></i> {{ 'admin.careers.add_requirement'|trans({}, 'admin') }}
                                    </button>
                                </div>
                            </div>

                            <div class="col-12">
                                <label class="admin-form-label">{{ 'admin.careers.job_description'|trans({}, 'admin') }}</label>
                                <input id="description_input" type="hidden" name="description">
                                <div class="editor-wrapper">
                                    <trix-editor input="description_input" class="trix-editor-modern" placeholder="{{ 'admin.careers.description_placeholder'|trans({}, 'admin') }}"></trix-editor>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="admin-btn admin-btn-secondary" onclick="resetForm()">{{ 'admin.common.clear'|trans({}, 'admin') }}</button>
                            <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.common.save'|trans({}, 'admin') }}</button>
                        </div>
                    </form>
                </div>

                {# CAREERS LIST #}
                <div class="admin-table-container">
                    <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{ 'admin.careers.current'|trans({}, 'admin') }}</h4>
                        <span class="badge bg-dark">{{ careers|length }} Active</span>
                    </div>

                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin.careers.id'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.careers.position'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.careers.core_requirements'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.careers.openings'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.careers.published'|trans({}, 'admin') }}</th>
                                <th class="text-end">{{ 'admin.common.actions'|trans({}, 'admin') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for c in careers %}
                                <tr id="career-row-{{ c.id }}" 
                                    data-json="{{ {
                                        id: c.id,
                                        jobTitle: c.jobTitle,
                                        number: c.number,
                                        publishedAt: c.publishedAt ? c.publishedAt|date('Y-m-d\\TH:i') : '',
                                        requirements: c.requirements,
                                        description: c.description
                                    }|json_encode|e('html_attr') }}">
                                    <td><code class="text-accent small">#{{ c.id }}</code></td>
                                    <td><span class="fw-bold text-white">{{ c.jobTitle }}</span></td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            {% for req in c.requirements %}
                                                <span class="badge bg-secondary opacity-75" style="font-size: 0.65rem;">{{ req }}</span>
                                            {% endfor %}
                                        </div>
                                    </td>
                                    <td><span class="admin-badge admin-badge-info">{{ c.number }}</span></td>
                                    <td>
                                        <div class="small text-muted">{{ c.publishedAt ? c.publishedAt|date('M j, Y') : 'N/A' }}</div>
                                    </td>

                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="admin-btn admin-btn-secondary admin-btn-sm"
                                                    onclick="editCareer({{ c.id }})" title="{{ 'admin.common.edit'|trans({}, 'admin') }}">
                                                <i class="fas fa-edit"></i>
                                            </button>

                                            <a href="{{ path('admin_careers', { delete: c.id }) }}"
                                               class="admin-btn admin-btn-danger admin-btn-sm"
                                               onclick="return confirm('Permanently remove this job opening?')" title="{{ 'admin.common.delete'|trans({}, 'admin') }}">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-5">
                                        <i class="fas fa-briefcase d-block mb-3 fs-2 opacity-25"></i>
                                        {{ 'admin.careers.no_positions_listed'|trans({}, 'admin') }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <script src="https://unpkg.com/trix@2.0.8/dist/trix.umd.min.js"></script>
            <script>
                function addCustomRequirement(value = '') {
                    const container = document.getElementById('custom-reqs-list');
                    const div = document.createElement('div');
                    div.className = 'd-flex align-items-center bg-dark p-1 rounded border border-secondary border-opacity-25';
                    div.innerHTML = `
                        <input type="text" name="requirements[]" class="admin-form-control form-control-sm border-0 bg-transparent text-white" value="${value}" placeholder="Requirement...">
                        <button type="button" class="btn btn-sm text-danger" onclick="this.parentElement.remove()">
                            <i class="fas fa-times"></i>
                        </button>
                    `;
                    container.appendChild(div);
                }

                function editCareer(id) {
                    const row = document.getElementById('career-row-' + id);
                    if (!row) return;

                    const career = JSON.parse(row.getAttribute('data-json'));
                    
                    resetForm();
                    
                    document.getElementById('form-title').innerText = '{{ 'admin.common.edit'|trans({}, 'admin') }}: ' + career.jobTitle;
                    document.getElementById('careerId').value = career.id;
                    document.getElementById('jobTitle').value = career.jobTitle;
                    document.getElementById('number').value = career.number;
                    if (career.publishedAt) {
                        document.getElementById('publishedAt').value = career.publishedAt;
                    }
                    
                    const trixEditor = document.querySelector("trix-editor");
                    if (trixEditor && trixEditor.editor) {
                        trixEditor.editor.loadHTML(career.description || '');
                    }
                    
                    if (career.requirements && Array.isArray(career.requirements)) {
                        const checkboxes = document.querySelectorAll('.lang-checkbox');
                        career.requirements.forEach(req => {
                            let found = false;
                            checkboxes.forEach(cb => {
                                if (cb.value === req) {
                                    cb.checked = true;
                                    found = true;
                                }
                            });
                            
                            if (!found) {
                                addCustomRequirement(req);
                            }
                        });
                    }

                    document.getElementById('formContainer').scrollIntoView({ behavior: 'smooth' });
                }

                function resetForm() {
                    document.getElementById('careerForm').reset();
                    document.getElementById('careerId').value = '';
                    document.getElementById('form-title').innerText = '{{ 'admin.careers.add_edit'|trans({}, 'admin') }}';
                    
                    const trixEditor = document.querySelector("trix-editor");
                    if (trixEditor && trixEditor.editor) {
                        trixEditor.editor.loadHTML('');
                    }
                    
                    document.getElementById('custom-reqs-list').innerHTML = '';
                    document.querySelectorAll('.lang-checkbox').forEach(cb => cb.checked = false);
                }
            </script>
        {% endblock %}

    {% endembed %}
{% endblock %}
