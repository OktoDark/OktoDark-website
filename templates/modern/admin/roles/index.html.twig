{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.roles.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.roles.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.roles.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                {# ADD / EDIT FORM #}
                <div class="admin-card mb-5" id="formContainer">
                    <h4 class="mb-4" id="formTitle">{{ 'admin.roles.add_edit'|trans({}, 'admin') }}</h4>

                    <form method="post">
                        <input type="hidden" name="id" id="roleId">

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label for="roleName" class="admin-form-label">{{ 'admin.roles.name'|trans({}, 'admin') }}</label>
                                <input type="text" name="name" id="roleName" class="admin-form-control" required placeholder="e.g. ROLE_EDITOR">
                            </div>

                            <div class="col-md-6">
                                <label for="roleLabel" class="admin-form-label">{{ 'admin.roles.label'|trans({}, 'admin') }}</label>
                                <input type="text" name="label" id="roleLabel" class="admin-form-control" required placeholder="e.g. Editor">
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="reset" class="admin-btn admin-btn-secondary" onclick="resetForm()">{{ 'admin.common.clear'|trans({}, 'admin') }}</button>
                            <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.common.save'|trans({}, 'admin') }}</button>
                        </div>
                    </form>
                </div>

                {# ROLES LIST #}
                <div class="admin-table-container">
                    <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{ 'admin.roles.current'|trans({}, 'admin') }}</h4>
                        <span class="badge bg-dark">{{ roles|length }} {{ 'admin.common.total'|trans({}, 'admin') }}</span>
                    </div>

                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin.roles.name'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.roles.label'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.roles.users'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.roles.permissions'|trans({}, 'admin') }}</th>
                                <th class="text-end">{{ 'admin.forum.categories.actions'|trans({}, 'admin') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for role in roles %}
                                <tr>
                                    <td><code class="text-accent small">{{ role.name }}</code></td>
                                    <td><span class="fw-bold">{{ role.label }}</span></td>
                                    <td><span class="admin-badge admin-badge-info">{{ role.users|length }}</span></td>
                                    <td><span class="admin-badge admin-badge-success">{{ role.rolePermissions|length }}</span></td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="admin-btn admin-btn-secondary admin-btn-sm"
                                                    onclick="editRole({{ role.id }}, '{{ role.name|e('js') }}', '{{ role.label|e('js') }}')" title="{{ 'admin.common.edit'|trans({}, 'admin') }}">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <a href="{{ path('admin_roles_permissions', {id: role.id}) }}" class="admin-btn admin-btn-warning admin-btn-sm" title="{{ 'admin.roles.permissions'|trans({}, 'admin') }}">
                                                <i class="fas fa-key"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-5">
                                        <i class="fas fa-user-shield d-block mb-3 fs-2 opacity-25"></i>
                                        {{ 'admin.roles.empty'|trans({}, 'admin') }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <script>
                function editRole(id, name, label) {
                    document.getElementById('formTitle').innerText = '{{ 'admin.common.edit'|trans({}, 'admin') }}: ' + name;
                    document.getElementById('roleId').value = id;
                    document.getElementById('roleName').value = name;
                    document.getElementById('roleLabel').value = label;

                    document.getElementById('formContainer').scrollIntoView({ behavior: 'smooth' });
                }

                function resetForm() {
                    document.getElementById('formTitle').innerText = '{{ 'admin.roles.add_edit'|trans({}, 'admin') }}';
                    document.getElementById('roleId').value = '';
                }
            </script>
        {% endblock %}

    {% endembed %}
{% endblock %}
