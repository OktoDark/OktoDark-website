{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.roles.permissions_title'|trans({'%role%': role.label}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.roles.permissions_title'|trans({'%role%': role.label}, 'admin') }}</h2>
                <p>{{ 'admin.roles.permissions_subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="admin-card">
                    <h4 class="mb-4">{{ 'admin.roles.permissions_for'|trans({'%role%': role.label}, 'admin') }}</h4>

                    <form method="post">

                        {% set grouped = {} %}

                        {# Group permissions by PermissionGroup #}
                        {% for perm in permissions %}
                            {% set group = perm.groupLabel %}
                            {% if grouped[group] is not defined %}
                                {% set grouped = grouped|merge({ (group): [perm] }) %}
                            {% else %}
                                {% set grouped = grouped|merge({ (group): grouped[group]|merge([perm]) }) %}
                            {% endif %}
                        {% endfor %}

                        {% for group, perms in grouped %}
                            <h5 class="mt-4 mb-3 text-accent">{{ group }}</h5>

                            <div class="admin-table-container mb-4">
                                <div class="table-responsive">
                                    <table class="admin-table">
                                        <thead>
                                        <tr>
                                            <th>{{ 'admin.roles.permission'|trans({}, 'admin') }}</th>
                                            <th class="text-center" style="width: 150px;">{{ 'admin.roles.allowed'|trans({}, 'admin') }}</th>
                                        </tr>
                                        </thead>
                                        <tbody>
                                        {% for perm in perms %}
                                            {% set rp = role.rolePermissions|filter(rp => rp.permission.id == perm.id)|first %}
                                            <tr>
                                                <td>{{ perm.label }}</td>
                                                <td class="text-center">
                                                    <div class="form-check form-switch d-flex justify-content-center">
                                                        <input class="form-check-input" type="checkbox"
                                                               name="perm_{{ perm.id }}"
                                                               value="1"
                                                               {% if rp and rp.allowed %}checked{% endif %}>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        {% endfor %}

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a href="{{ path('admin_roles') }}" class="admin-btn admin-btn-secondary">{{ 'admin.common.cancel'|trans({}, 'admin') }}</a>
                            <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.roles.save_permissions'|trans({}, 'admin') }}</button>
                        </div>
                    </form>
                </div>
            </section>
        {% endblock %}

    {% endembed %}
{% endblock %}
