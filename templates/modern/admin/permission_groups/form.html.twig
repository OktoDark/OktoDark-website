{% extends '@theme/base.html.twig' %}

{% block title %}{{ title }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ title }}</h2>
                <p>{{ 'admin.permission_groups.form_subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="admin-card">
                    <h4 class="mb-4">{{ title }}</h4>

                    {{ form_start(form) }}
                    <div class="row g-4">
                        <div class="col-md-6">
                            {{ form_row(form.name, {
                                label: 'admin.permission_groups.name'|trans({}, 'admin'),
                                attr: { class: 'admin-form-control', placeholder: 'e.g. content_management' }
                            }) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.label, {
                                label: 'admin.permission_groups.label'|trans({}, 'admin'),
                                attr: { class: 'admin-form-control', placeholder: 'e.g. Content Management' }
                            }) }}
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a href="{{ path('admin_permission_groups') }}" class="admin-btn admin-btn-secondary">{{ 'admin.common.cancel'|trans({}, 'admin') }}</a>
                        <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.common.save'|trans({}, 'admin') }}</button>
                    </div>
                    {{ form_end(form) }}
                </div>
            </section>
        {% endblock %}

    {% endembed %}
{% endblock %}
