{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.permission_groups.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.permission_groups.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.permission_groups.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                {# ADD / EDIT FORM #}
                <div class="admin-card mb-5" id="formContainer">
                    <h4 class="mb-4" id="formTitle">{{ 'admin.permission_groups.add_edit'|trans({}, 'admin') }}</h4>

                    <form method="post">
                        <input type="hidden" name="id" id="groupId">

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label for="groupName" class="admin-form-label">{{ 'admin.permission_groups.name'|trans({}, 'admin') }}</label>
                                <input type="text" name="name" id="groupName" class="admin-form-control" required placeholder="e.g. content_management">
                            </div>

                            <div class="col-md-6">
                                <label for="groupLabel" class="admin-form-label">{{ 'admin.permission_groups.label'|trans({}, 'admin') }}</label>
                                <input type="text" name="label" id="groupLabel" class="admin-form-control" required placeholder="e.g. Content Management">
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="reset" class="admin-btn admin-btn-secondary" onclick="resetForm()">{{ 'admin.common.clear'|trans({}, 'admin') }}</button>
                            <button type="submit" class="admin-btn admin-btn-primary px-5">{{ 'admin.common.save'|trans({}, 'admin') }}</button>
                        </div>
                    </form>
                </div>

                {# PERMISSION GROUPS LIST #}
                <div class="admin-table-container">
                    <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">{{ 'admin.permission_groups.current'|trans({}, 'admin') }}</h4>
                        <span class="badge bg-dark">{{ groups|length }} {{ 'admin.common.total'|trans({}, 'admin') }}</span>
                    </div>

                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th>{{ 'admin.permission_groups.name'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.permission_groups.label'|trans({}, 'admin') }}</th>
                                <th class="text-end">{{ 'admin.forum.categories.actions'|trans({}, 'admin') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for group in groups %}
                                <tr>
                                    <td><code class="text-accent small">{{ group.name }}</code></td>
                                    <td><span class="fw-bold">{{ group.label }}</span></td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="admin-btn admin-btn-secondary admin-btn-sm"
                                                    onclick="editGroup({{ group.id }}, '{{ group.name|e('js') }}', '{{ group.label|e('js') }}')" title="{{ 'admin.common.edit'|trans({}, 'admin') }}">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="3" class="text-center text-muted py-5">
                                        <i class="fas fa-shield-halved d-block mb-3 fs-2 opacity-25"></i>
                                        {{ 'admin.permission_groups.empty'|trans({}, 'admin') }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <script>
                function editGroup(id, name, label) {
                    document.getElementById('formTitle').innerText = '{{ 'admin.common.edit'|trans({}, 'admin') }}: ' + name;
                    document.getElementById('groupId').value = id;
                    document.getElementById('groupName').value = name;
                    document.getElementById('groupLabel').value = label;

                    document.getElementById('formContainer').scrollIntoView({ behavior: 'smooth' });
                }

                function resetForm() {
                    document.getElementById('formTitle').innerText = '{{ 'admin.permission_groups.add_edit'|trans({}, 'admin') }}';
                    document.getElementById('groupId').value = '';
                }
            </script>
        {% endblock %}

    {% endembed %}
{% endblock %}
