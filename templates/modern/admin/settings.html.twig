{% extends '@theme/base.html.twig' %}
{% block title %}Website Settings{% endblock %}
{% block body_id 'admin_settings' %}

{% block main %}
    {% embed '@theme/admin/partials/_layout.html.twig' %}

        {% block admin_content %}

            <section class="section-page-title text-center py-4 fade-in">
                <h2 class="fw-bold">Website Settings</h2>
                <p class="text-muted">Manage global configuration for OktoDark.</p>
            </section>

            <section class="py-3 fade-in">

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success">{{ message }}</div>
                {% endfor %}

                <form method="post" class="card neon-card p-4 shadow-sm">

                    <h4 class="mb-3">General Settings</h4>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Site Name</label>
                            <input type="text" name="siteName" class="form-control"
                                   value="{{ settings.siteName }}">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Job Email</label>
                            <input type="text" name="jobmail" class="form-control"
                                   value="{{ settings.jobmail }}">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">CDN URL</label>
                            <input type="text" name="siteCDN" class="form-control"
                                   value="{{ settings.siteCDN }}">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold">Logo Filename</label>
                            <input type="text" name="logoName" class="form-control"
                                   value="{{ settings.logoName }}">
                        </div>

                    </div>

                    <div class="text-end mt-4">
                        <button class="btn btn-success px-4">Save Settings</button>
                    </div>

                </form>

            </section>

        {% endblock %}

    {% endembed %}
{% endblock %}