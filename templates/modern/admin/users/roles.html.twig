{% extends '@theme/base.html.twig' %}

{% block body %}
    <h1>Roles for {{ user.username }}</h1>

    <form method="post">
        <table class="table table-dark table-striped">
            <thead>
            <tr>
                <th>Role</th>
                <th>Label</th>
                <th>Assigned</th>
            </tr>
            </thead>
            <tbody>
            {% for role in roles %}
                <tr>
                    <td>{{ role.name }}</td>
                    <td>{{ role.label }}</td>
                    <td>
                        <input type="checkbox"
                               name="role_{{ role.id }}"
                               value="1"
                               {% if user.roleEntities.contains(role) %}checked{% endif %}>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <button class="btn btn-primary">Save</button>
    </form>
{% endblock %}
