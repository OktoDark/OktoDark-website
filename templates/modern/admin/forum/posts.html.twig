{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.forum.posts.title'|trans({}, 'admin') }} - Forum Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
<div class="section-title">
    <h2 class="fw-bold"><i class="fa-solid fa-reply-all me-2 text-accent"></i> {{ 'admin.forum.posts.title'|trans({}, 'admin') }}</h2>
    <p class="text-muted">{{ 'admin.forum.posts.subtitle'|trans({}, 'admin') }}</p>
</div>

<!-- Filters -->
<div class="admin-card mb-4">
    <form action="{{ path('admin_forum_posts') }}" method="get" class="row g-3">
        <div class="col-md-4">
            <label class="form-label small fw-bold">{{ 'admin.forum.badges.status'|trans({}, 'admin') }}</label>
            <div class="form-check form-switch mt-2">
                <input class="form-check-input" type="checkbox" name="reported" value="1" id="filterReported" {% if currentFilters.reported %}checked{% endif %}>
                <label class="form-check-label" for="filterReported">{{ 'admin.forum.posts.reported_only'|trans({}, 'admin') }}</label>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-bold">{{ 'admin.news.author'|trans({}, 'admin') }}</label>
            <input type="text" name="author" class="admin-form-control" placeholder="Username..." value="{{ currentFilters.author }}">
        </div>
        <div class="col-md-4 d-flex align-items-end gap-2">
            <button type="submit" class="admin-btn admin-btn-primary flex-grow-1 justify-content-center">{{ 'admin.forum.threads.filter'|trans({}, 'admin') }}</button>
            <a href="{{ path('admin_forum_posts') }}" class="admin-btn admin-btn-secondary px-3"><i class="fas fa-times"></i></a>
        </div>
    </form>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th class="ps-4">{{ 'admin.forum.posts.content'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.news.author'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.forum.posts.thread'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.forum.badges.status'|trans({}, 'admin') }}</th>
                <th>{{ 'admin.forum.threads.created'|trans({}, 'admin') }}</th>
                <th class="text-end pe-4">{{ 'admin.forum.categories.actions'|trans({}, 'admin') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for post in posts %}
            <tr class="{% if post.reported %}bg-danger-subtle{% endif %}">
                <td class="ps-4">
                    <div class="small text-dark text-truncate" style="max-width: 300px;">
                        {{ post.content|striptags|raw }}
                    </div>
                </td>
                <td>{{ post.author.username }}</td>
                <td>
                    <a href="{{ path('forum_thread_view', {slug: post.thread.slug}) }}" target="_blank" class="small text-decoration-none">
                        {{ post.thread.title|slice(0, 20) }}...
                    </a>
                </td>
                <td>
                    {% if post.reported %}
                        <span class="badge bg-danger"><i class="fa-solid fa-triangle-exclamation"></i> {{ 'admin.forum.posts.reported'|trans({}, 'admin') }}</span>
                    {% endif %}
                    {% if post.isAcceptedAnswer %}
                        <span class="badge bg-success"><i class="fa-solid fa-check"></i> {{ 'admin.forum.posts.solution'|trans({}, 'admin') }}</span>
                    {% endif %}
                    {% if not post.reported and not post.isAcceptedAnswer %}
                        <span class="badge bg-light text-muted border">{{ 'admin.forum.posts.standard'|trans({}, 'admin') }}</span>
                    {% endif %}
                </td>
                <td>{{ post.createdAt|date('M d, Y') }}</td>
                <td class="text-end pe-4">
                    <div class="btn-group btn-group-sm">
                        <a href="{{ path('forum_thread_view', {slug: post.thread.slug}) }}#post-{{ post.id }}" class="btn btn-white border" target="_blank" title="{{ 'admin.common.view'|trans({}, 'admin') }}"><i class="fa-solid fa-eye text-primary"></i></a>
                        
                        {% if post.reported %}
                            <a href="{{ path('admin_forum_post_dismiss_report', {id: post.id}) }}" class="btn btn-white border" title="{{ 'admin.forum.posts.dismiss_report'|trans({}, 'admin') }}"><i class="fa-solid fa-check text-success"></i></a>
                        {% endif %}

                        <form action="{{ path('admin_forum_post_delete', {id: post.id}) }}" method="post" class="d-inline" onsubmit="return confirm('{{ 'admin.forum.posts.delete_confirm'|trans({}, 'admin') }}');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                            <button class="btn btn-white border text-danger"><i class="fa-solid fa-trash"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="text-center py-5 text-muted">{{ 'admin.forum.posts.no_posts'|trans({}, 'admin') }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
        {% endblock %}

    {% endembed %}
{% endblock %}
