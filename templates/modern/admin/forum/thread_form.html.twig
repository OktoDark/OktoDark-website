{% extends '@theme/base.html.twig' %}
{% block title %}{{ title }} – Forum Admin{% endblock %}
{% block body_id 'admin' %}

{# Apply the custom trix theme to this form #}
{% form_theme form 'form/trix_editor_widget.html.twig' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}
        {% block admin_content %}
            <div class="admin-section-title mb-4">
                <h2 class="text-neon-blue fw-bold"><i class="fas fa-plus-circle me-2"></i>{{ title }}</h2>
                <p class="text-muted">Create a new community discussion from the admin panel.</p>
            </div>

            <div class="admin-card p-4 shadow-sm">
                {{ form_start(form, {'attr': {'class': 'admin-form'}}) }}
                    <div class="row g-4">
                        <div class="col-md-8">
                            <div class="form-group mb-4">
                                <label class="form-label small text-uppercase fw-bold text-muted mb-2">Thread Title</label>
                                {{ form_widget(form.title, {'attr': {'class': 'admin-form-control', 'placeholder': 'Enter thread title'}}) }}
                                {{ form_errors(form.title, {'attr': {'class': 'text-danger small mt-1'}}) }}
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="form-group mb-4">
                                <label class="form-label small text-uppercase fw-bold text-muted mb-2">Category</label>
                                {{ form_widget(form.category, {'attr': {'class': 'admin-form-control'}}) }}
                                {{ form_errors(form.category, {'attr': {'class': 'text-danger small mt-1'}}) }}
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-4">
                        <label class="form-label small text-uppercase fw-bold text-muted mb-2">Detailed Content</label>
                        {# This will now render the <trix-editor> thanks to the form_theme #}
                        <div class="editor-wrapper shadow-sm" style="width: 100%;">
                            {{ form_widget(form.content) }}
                        </div>
                        {{ form_errors(form.content, {'attr': {'class': 'text-danger small mt-1'}}) }}
                    </div>

                    <div class="d-flex justify-content-between mt-5 pt-3 border-top border-light">
                        <a href="{{ path('admin_forum_threads') }}" class="admin-btn admin-btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i> Back to List
                        </a>
                        <button type="submit" class="admin-btn admin-btn-primary shadow-neon">
                            <i class="fas fa-save me-1"></i> Save Thread
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}
