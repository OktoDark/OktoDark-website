{% extends '@theme/base.html.twig' %}

{% block title %}Moderation Logs - Forum Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
<div class="section-title">
    <h2 class="fw-bold"><i class="fa-solid fa-list-check me-2 text-accent"></i> Moderation Logs</h2>
    <p class="text-muted">Audit trail of all administrative actions in the forum.</p>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th class="ps-4">Moderator</th>
                <th>Action</th>
                <th>Target</th>
                <th>Details</th>
                <th class="text-end pe-4">Date</th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
            <tr>
                <td class="ps-4">
                    <div class="fw-bold">{{ log.moderator.username }}</div>
                </td>
                <td>
                    {% set action_class = 'bg-secondary' %}
                    {% if 'delete' in log.action %}
                        {% set action_class = 'bg-danger' %}
                    {% elseif 'lock' in log.action or 'pin' in log.action %}
                        {% set action_class = 'bg-warning text-dark' %}
                    {% elseif 'restore' in log.action or 'dismiss' in log.action %}
                        {% set action_class = 'bg-success' %}
                    {% endif %}
                    <span class="badge {{ action_class }}">{{ log.action|replace({'_': ' '})|capitalize }}</span>
                </td>
                <td>
                    <span class="badge bg-light text-dark border">{{ log.targetType|capitalize }} (ID: {{ log.targetId }})</span>
                </td>
                <td>
                    <div class="small text-muted" style="max-width: 300px;">
                        {{ log.details }}
                    </div>
                </td>
                <td class="text-end pe-4 small">
                    {{ log.createdAt|date('M d, Y H:i') }}
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="text-center py-5 text-muted">No moderation logs found.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
        {% endblock %}

    {% endembed %}
{% endblock %}