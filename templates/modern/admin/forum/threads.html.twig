{% extends '@theme/base.html.twig' %}

{% block title %}Manage Threads - Forum Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
<div class="section-title">
    <h2 class="fw-bold"><i class="fa-solid fa-comments me-2 text-accent"></i> Thread Management</h2>
    <p class="text-muted">View and manage all forum discussions.</p>
</div>

<!-- Filters -->
<div class="admin-card mb-4">
    <form action="{{ path('admin_forum_threads') }}" method="get" class="row g-3">
        <div class="col-md-3">
            <label class="form-label small fw-bold">Category</label>
            <select name="category" class="admin-form-control">
                <option value="">All Categories</option>
                {% for cat in categories %}
                <option value="{{ cat.id }}" {% if currentFilters.category == cat.id %}selected{% endif %}>{{ cat.name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold">Status</label>
            <select name="status" class="admin-form-control">
                <option value="">Any Status</option>
                <option value="locked" {% if currentFilters.status == 'locked' %}selected{% endif %}>Locked</option>
                <option value="pinned" {% if currentFilters.status == 'pinned' %}selected{% endif %}>Pinned</option>
                <option value="deleted" {% if currentFilters.status == 'deleted' %}selected{% endif %}>Soft-Deleted</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold">Author</label>
            <input type="text" name="author" class="admin-form-control" placeholder="Username..." value="{{ currentFilters.author }}">
        </div>
        <div class="col-md-3 d-flex align-items-end gap-2">
            <button type="submit" class="admin-btn admin-btn-primary flex-grow-1 justify-content-center">Filter</button>
            <a href="{{ path('admin_forum_threads') }}" class="admin-btn admin-btn-secondary px-3"><i class="fas fa-times"></i></a>
        </div>
    </form>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th class="ps-4">Title / Category</th>
                <th>Author</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end pe-4">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for thread in threads %}
            <tr class="{% if thread.deletedAt %}opacity-50 bg-light{% endif %}">
                <td class="ps-4">
                    <div class="fw-bold">{{ thread.title }}</div>
                    <span class="badge bg-success-subtle text-success small">{{ thread.category.name }}</span>
                </td>
                <td>{{ thread.author.username }}</td>
                <td>
                    {% if thread.pinned %}
                        <span class="badge bg-warning text-dark"><i class="fa-solid fa-thumbtack"></i> Pinned</span>
                    {% endif %}
                    {% if thread.locked %}
                        <span class="badge bg-danger"><i class="fa-solid fa-lock"></i> Locked</span>
                    {% endif %}
                    {% if thread.deletedAt %}
                        <span class="badge bg-secondary">Deleted</span>
                    {% endif %}
                    {% if not thread.pinned and not thread.locked and not thread.deletedAt %}
                        <span class="badge bg-light text-dark border">Active</span>
                    {% endif %}
                </td>
                <td>{{ thread.createdAt|date('M d, Y') }}</td>
                <td class="text-end pe-4">
                    <div class="btn-group btn-group-sm">
                        <a href="{{ path('forum_thread_view', {slug: thread.slug}) }}" class="btn btn-white border" target="_blank"><i class="fa-solid fa-eye text-primary"></i></a>
                        <a href="{{ path('admin_forum_thread_pin', {id: thread.id}) }}" class="btn btn-white border" title="Toggle Pin"><i class="fa-solid fa-thumbtack {% if thread.pinned %}text-warning{% endif %}"></i></a>
                        <a href="{{ path('admin_forum_thread_lock', {id: thread.id}) }}" class="btn btn-white border" title="Toggle Lock"><i class="fa-solid fa-lock {% if thread.locked %}text-danger{% endif %}"></i></a>
                        {% if thread.deletedAt %}
                            <a href="{{ path('admin_forum_thread_restore', {id: thread.id}) }}" class="btn btn-white border" title="Restore"><i class="fa-solid fa-rotate-left text-success"></i></a>
                        {% endif %}
                        <form action="{{ path('admin_forum_thread_delete', {id: thread.id}) }}" method="post" class="d-inline" onsubmit="return confirm('Permanently delete this thread?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ thread.id) }}">
                            <button class="btn btn-white border text-danger"><i class="fa-solid fa-trash"></i></button>
                        </form>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
        {% endblock %}

    {% endembed %}
{% endblock %}