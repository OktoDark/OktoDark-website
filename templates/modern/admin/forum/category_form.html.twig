{% extends '@theme/base.html.twig' %}
{% block title %}{{ title }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="mb-4">
                <a href="{{ path('admin_forum_categories') }}" class="admin-btn admin-btn-secondary admin-btn-sm mb-3">
                    <i class="fas fa-arrow-left"></i> Back to Categories
                </a>
                <div class="section-title">
                    <h2>{{ title }}</h2>
                    <p>Configure forum category properties and accessibility.</p>
                </div>
            </div>

            <div class="admin-card">
                {{ form_start(form) }}
                
                {# SURFACING FORM ERRORS #}
                <div class="mb-3">
                    {{ form_errors(form) }}
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="admin-form-label">Category Name</label>
                        {{ form_widget(form.name, { attr: { class: 'admin-form-control', placeholder: 'e.g. General Discussion' } }) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="col-md-6">
                        <label class="admin-form-label">Parent Category</label>
                        {{ form_widget(form.parent, { attr: { class: 'admin-form-control' } }) }}
                        <small class="text-muted">Leave empty to make this a main (top-level) category.</small>
                        {{ form_errors(form.parent) }}
                    </div>
                </div>

                <div class="mb-4">
                    <label class="admin-form-label">Description</label>
                    {{ form_widget(form.description, { attr: { class: 'admin-form-control', rows: 3, placeholder: 'Briefly describe what this category is for...' } }) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <label class="admin-form-label">Display Order Position</label>
                        {{ form_widget(form.position, { attr: { class: 'admin-form-control' } }) }}
                        {{ form_errors(form.position) }}
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="admin-btn admin-btn-primary px-5 shadow-sm fw-bold">
                        <i class="fas fa-save me-2"></i> Save Category
                    </button>
                </div>

                {# ENSURE CSRF TOKEN AND REMAINING FIELDS ARE RENDERED #}
                {{ form_rest(form) }}

                {{ form_end(form) }}
            </div>
        {% endblock %}

    {% endembed %}
{% endblock %}