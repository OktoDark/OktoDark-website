{% extends '@theme/base.html.twig' %}
{% block title %}{{ title }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="mb-4">
                <a href="{{ path('admin_forum_categories') }}" class="admin-btn admin-btn-secondary admin-btn-sm mb-3">
                    <i class="fas fa-arrow-left"></i> {{ 'admin.forum.category_form.back_to_categories'|trans({}, 'admin') }}
                </a>
                <div class="section-title">
                    <h2>{{ title }}</h2>
                    <p>{{ 'admin.forum.category_form.subtitle'|trans({}, 'admin') }}</p>
                </div>
            </div>

            <div class="admin-card">
                {{ form_start(form) }}
                
                {# SURFACING FORM ERRORS #}
                <div class="mb-3">
                    {{ form_errors(form) }}
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="admin-form-label">{{ 'admin.forum.category_form.name'|trans({}, 'admin') }}</label>
                        {{ form_widget(form.name, { attr: { class: 'admin-form-control', placeholder: 'admin.forum.category_form.name_placeholder'|trans({}, 'admin') } }) }}
                        {{ form_errors(form.name) }}
                    </div>

                    <div class="col-md-6">
                        <label class="admin-form-label">{{ 'admin.forum.category_form.parent'|trans({}, 'admin') }}</label>
                        {{ form_widget(form.parent, { attr: { class: 'admin-form-control' } }) }}
                        <small class="text-muted">{{ 'admin.forum.category_form.parent_help'|trans({}, 'admin') }}</small>
                        {{ form_errors(form.parent) }}
                    </div>
                </div>

                <div class="mb-4">
                    <label class="admin-form-label">{{ 'admin.forum.category_form.description'|trans({}, 'admin') }}</label>
                    {{ form_widget(form.description, { attr: { class: 'admin-form-control', rows: 3, placeholder: 'admin.forum.category_form.description_placeholder'|trans({}, 'admin') } }) }}
                    {{ form_errors(form.description) }}
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <label class="admin-form-label">{{ 'admin.forum.category_form.position'|trans({}, 'admin') }}</label>
                        {{ form_widget(form.position, { attr: { class: 'admin-form-control' } }) }}
                        {{ form_errors(form.position) }}
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="admin-btn admin-btn-primary px-5 shadow-sm fw-bold">
                        <i class="fas fa-save me-2"></i> {{ 'admin.forum.category_form.save_category'|trans({}, 'admin') }}
                    </button>
                </div>

                {# ENSURE CSRF TOKEN AND REMAINING FIELDS ARE RENDERED #}
                {{ form_rest(form) }}

                {{ form_end(form) }}
            </div>
        {% endblock %}

    {% endembed %}
{% endblock %}