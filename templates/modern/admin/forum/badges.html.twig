{% extends '@theme/base.html.twig' %}

{% block title %}Manage Badges - Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

{% block admin_content %}
    <div class="section-title">
        <h2 class="fw-bold"><i class="fa-solid fa-award me-2 text-accent"></i> Badge Management</h2>
        <p class="text-muted">Create and manage awards for your community members.</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> {{ message }}
        </div>
    {% endfor %}

    {# ADD / EDIT FORM #}
    <div class="admin-card mb-5" id="badgeFormContainer">
        <h4 class="mb-4" id="formTitle">Add / Edit Badge</h4>

        <form method="post" id="badgeForm">
            <input type="hidden" name="id" id="badgeId">

            <div class="row g-4">
                <div class="col-md-3">
                    <label class="admin-form-label">Badge Name</label>
                    <input type="text" name="name" id="badgeName" class="admin-form-control" required placeholder="e.g. Early Adopter">
                </div>

                <div class="col-md-3">
                    <label class="admin-form-label">FontAwesome Icon</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i id="iconPreview" class="fa-solid fa-award"></i></span>
                        <input type="text" name="icon" id="badgeIcon" class="admin-form-control border-start-0" required placeholder="fa-solid fa-award" oninput="updateIconPreview(this.value)">
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="admin-form-label">Badge Color</label>
                    <div class="input-group">
                        <input type="color" name="color" id="badgeColor" class="form-control form-control-color border-0 p-0" style="height: 44px; width: 44px; cursor: pointer;" value="#16a34a" oninput="updateColorPreview(this.value)">
                        <input type="text" id="badgeColorHex" class="admin-form-control border-start-0" value="#16A34A" readonly style="background: #f8f9fa;">
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="admin-form-label">Description</label>
                    <input type="text" name="description" id="badgeDescription" class="admin-form-control" required placeholder="e.g. Joined during beta phase">
                </div>

                {# AUTOMATION SETTINGS #}
                <div class="col-md-4">
                    <label class="admin-form-label">Auto-Award Type</label>
                    <select name="actionType" id="badgeActionType" class="admin-form-control">
                        <option value="">None (Manual)</option>
                        <option value="posts">Post Count</option>
                        <option value="threads">Thread Count</option>
                        <option value="reputation">Reputation Score</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="admin-form-label">Threshold (Target Number)</label>
                    <input type="number" name="threshold" id="badgeThreshold" class="admin-form-control" placeholder="e.g. 100">
                </div>

                <div class="col-md-4">
                    <label class="admin-form-label">Type</label>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" name="isPermanent" value="1" id="badgeIsPermanent">
                        <label class="form-check-label" for="badgeIsPermanent">Staff/Permanent Badge</label>
                    </div>
                    <small class="text-muted">Permanent badges won't be removed if stats drop.</small>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <button type="reset" class="admin-btn admin-btn-secondary" onclick="resetBadgeForm()">Clear</button>
                <button type="submit" class="admin-btn admin-btn-primary">Save Badge</button>
            </div>
        </form>
    </div>

    {# BADGES LIST #}
    <div class="admin-table-container">
        <div class="p-4 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Existing Badges</h4>
            <span class="badge bg-dark">{{ badges|length }} Total</span>
        </div>

        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                <tr>
                    <th class="ps-4">Visual</th>
                    <th>Name / Description</th>
                    <th>Auto-Award Criteria</th>
                    <th>Status</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
                </thead>

                <tbody>
                {% for badge in badges %}
                    <tr>
                        <td class="ps-4">
                            <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 44px; height: 44px; font-size: 1.3rem; background-color: {{ badge.color }}; color: #fff;">
                                <i class="{{ badge.icon }}"></i>
                            </div>
                        </td>
                        <td>
                            <div class="fw-bold">{{ badge.name }}</div>
                            <div class="text-muted x-small">{{ badge.description }}</div>
                        </td>
                        <td>
                            {% if badge.actionType %}
                                <span class="badge bg-info-subtle text-info border border-info-subtle">
                                    {{ badge.actionType|capitalize }}: {{ badge.threshold }}
                                </span>
                            {% else %}
                                <span class="text-muted small">Manual Only</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if badge.isPermanent %}
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Staff/Permanent</span>
                            {% else %}
                                <span class="badge bg-light text-muted border">Standard</span>
                            {% endif %}
                        </td>
                        <td class="text-end pe-4">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn btn-sm btn-white border shadow-sm"
                                        onclick="editBadge(
                                            {{ badge.id }},
                                            '{{ badge.name|e('js') }}',
                                            '{{ badge.icon|e('js') }}',
                                            '{{ badge.description|e('js') }}',
                                            '{{ badge.actionType|e('js') }}',
                                            '{{ badge.threshold }}',
                                            '{{ badge.isPermanent ? 1 : 0 }}',
                                            '{{ badge.color|e('js') }}'
                                        )" title="Edit">
                                    <i class="fas fa-edit text-primary"></i>
                                </button>
                                <a href="{{ path('admin_badges', { delete: badge.id }) }}"
                                   class="btn btn-sm btn-white border shadow-sm"
                                   onclick="return confirm('Delete this badge? This will remove it from all users.')" title="Delete">
                                    <i class="fas fa-trash text-danger"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">No badges created yet.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <script>
        function updateIconPreview(val) {
            const preview = document.getElementById('iconPreview');
            preview.className = val || 'fa-solid fa-award';
        }
        
        function updateColorPreview(val) {
            document.getElementById('badgeColorHex').value = val.toUpperCase();
        }

        function editBadge(id, name, icon, description, actionType, threshold, isPermanent, color) {
            document.getElementById('formTitle').innerText = 'Edit Badge: ' + name;
            document.getElementById('badgeId').value = id;
            document.getElementById('badgeName').value = name;
            document.getElementById('badgeIcon').value = icon;
            document.getElementById('badgeDescription').value = description;
            document.getElementById('badgeActionType').value = actionType;
            document.getElementById('badgeThreshold').value = threshold;
            document.getElementById('badgeIsPermanent').checked = isPermanent == '1';
            document.getElementById('badgeColor').value = color;
            document.getElementById('badgeColorHex').value = color.toUpperCase();
            
            updateIconPreview(icon);
            document.getElementById('badgeFormContainer').scrollIntoView({ behavior: 'smooth' });
        }

        function resetBadgeForm() {
            document.getElementById('formTitle').innerText = 'Add / Edit Badge';
            document.getElementById('badgeId').value = '';
            document.getElementById('badgeIsPermanent').checked = false;
            document.getElementById('badgeColor').value = '#16a34a';
            document.getElementById('badgeColorHex').value = '#16A34A';
            updateIconPreview('fa-solid fa-award');
        }
    </script>
{% endblock %}

    {% endembed %}
{% endblock %}