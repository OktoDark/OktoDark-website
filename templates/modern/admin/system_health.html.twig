{% extends '@theme/base.html.twig' %}
{% block title %}{{ 'admin.system.health'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.system.health'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.system.health_subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                <div class="row g-4">
                    {# Resource Usage #}
                    <div class="col-lg-6">
                        <div class="admin-card h-100">
                            <h5 class="mb-4 text-white"><i class="fas fa-server me-2 text-muted"></i>{{ 'admin.system.resources'|trans({}, 'admin') }}</h5>
                            
                            <div class="mb-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-white">{{ 'admin.system.disk'|trans({}, 'admin') }} ({{ health.disk.used }} / {{ health.disk.total }})</span>
                                    <span class="fw-bold text-white">{{ health.disk.percentage }}%</span>
                                </div>
                                <div class="progress" style="height: 8px; background-color: var(--admin-border);">
                                    <div class="progress-bar" 
                                         role="progressbar" style="width: {{ health.disk.percentage }}%; background-color: {{ health.disk.status == 'warning' ? 'var(--admin-danger)' : 'var(--admin-accent)' }}"></div>
                                </div>
                                <small class="text-muted">{{ health.disk.free }} {{ 'admin.system.available'|trans({}, 'admin') }}</small>
                            </div>

                            <div class="mb-0">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-white">{{ 'admin.system.memory'|trans({}, 'admin') }} ({{ health.memory.used }} / {{ health.memory.limit }})</span>
                                    <span class="fw-bold text-white">{{ health.memory.percentage }}%</span>
                                </div>
                                <div class="progress" style="height: 8px; background-color: var(--admin-border);">
                                    <div class="progress-bar" 
                                         role="progressbar" style="width: {{ health.memory.percentage }}%; background-color: {{ health.memory.status == 'warning' ? 'var(--admin-warning)' : 'var(--admin-success)' }}"></div>
                                </div>
                                <small class="text-muted">PHP Peak Memory: {{ health.memory.used }}</small>
                            </div>
                        </div>
                    </div>

                    {# Core Services #}
                    <div class="col-lg-6">
                        <div class="admin-card h-100">
                            <h5 class="mb-4 text-white"><i class="fas fa-cogs me-2 text-muted"></i>{{ 'admin.system.core_services'|trans({}, 'admin') }}</h5>
                            <div class="admin-list-group">
                                <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong class="text-white">{{ 'admin.system.database'|trans({}, 'admin') }}</strong>
                                        <div class="small text-muted">{{ health.database.message }}</div>
                                    </div>
                                    <span class="admin-badge {{ health.database.status == 'ok' ? 'admin-badge-success' : 'admin-badge-danger' }}">
                                        {{ health.database.status|upper }}
                                    </span>
                                </div>
                                <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong class="text-white">{{ 'admin.system.filesystem'|trans({}, 'admin') }}</strong>
                                        <div class="small text-muted">Cache & Logs directories are writable.</div>
                                    </div>
                                    <span class="admin-badge admin-badge-success">OK</span>
                                </div>
                                <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong class="text-white">{{ 'admin.system.environment'|trans({}, 'admin') }}</strong>
                                        <div class="small text-muted">{{ health.env|capitalize }} Mode (Debug: {{ health.debug ? 'On' : 'Off' }})</div>
                                    </div>
                                    <span class="admin-badge admin-badge-info">PHP {{ health.php.version }}</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Environment Details #}
                    <div class="col-12">
                        <div class="admin-card">
                            <h5 class="mb-4 text-white"><i class="fas fa-info-circle me-2 text-muted"></i>{{ 'admin.system.details'|trans({}, 'admin') }}</h5>
                            <div class="row text-center g-3">
                                <div class="col-md-3">
                                    <div class="p-3 bg-dark rounded border border-secondary border-opacity-25 h-100">
                                        <div class="text-muted small">Symfony Version</div>
                                        <div class="h5 mb-0 text-white">{{ health.symfony_version }}</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 bg-dark rounded border border-secondary border-opacity-25 h-100">
                                        <div class="text-muted small">PHP Memory Limit</div>
                                        <div class="h5 mb-0 text-white">{{ health.php.memory_limit }}</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 bg-dark rounded border border-secondary border-opacity-25 h-100">
                                        <div class="text-muted small">Max Upload Size</div>
                                        <div class="h5 mb-0 text-white">{{ health.php.upload_max_filesize }}</div>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="p-3 bg-dark rounded border border-secondary border-opacity-25 h-100">
                                        <div class="text-muted small">Operating System</div>
                                        <div class="h5 mb-0 text-white text-truncate">{{ constant('PHP_OS') }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        {% endblock %}

    {% endembed %}
{% endblock %}
