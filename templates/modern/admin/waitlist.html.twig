{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'admin.waitlist.title'|trans({}, 'admin') }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}
            <div class="section-title">
                <h2>{{ 'admin.waitlist.title'|trans({}, 'admin') }}</h2>
                <p>{{ 'admin.waitlist.subtitle'|trans({}, 'admin') }}</p>
            </div>

            <section>
                <div class="admin-table-container">
                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                            <tr>
                                <th># ID</th>
                                <th>{{ 'admin.common.email'|trans({}, 'admin') }}</th>
                                <th>{{ 'admin.waitlist.requested'|trans({}, 'admin') }}</th>
                                <th class="text-end">{{ 'admin.common.actions'|trans({}, 'admin') }}</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for entry in entries %}
                                <tr>
                                    <td><code class="text-accent small">#{{ entry.id }}</code></td>
                                    <td><span class="text-dark fw-bold">{{ entry.email }}</span></td>
                                    <td>
                                        <div class="small text-muted">{{ entry.createdAt|date('M j, Y') }}</div>
                                        <div class="small text-muted" style="font-size: 0.7rem;">{{ entry.createdAt|date('H:i') }}</div>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form method="post" action="{{ path('admin_waitlist_invite', {id: entry.id}) }}">
                                                <button type="submit" class="admin-btn admin-btn-primary admin-btn-sm" title="{{ 'admin.waitlist.invite'|trans({}, 'admin') }}">
                                                    <i class="fas fa-paper-plane"></i> {{ 'admin.waitlist.invite'|trans({}, 'admin') }}
                                                </button>
                                            </form>
                                            <form method="post" action="{{ path('admin_waitlist_delete', {id: entry.id}) }}"
                                                  onsubmit="return confirm('Permanently remove this entry from the waitlist?');">
                                                <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm" title="{{ 'admin.common.delete'|trans({}, 'admin') }}">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-5">
                                        <i class="fas fa-clock d-block mb-3 fs-2 opacity-25"></i>
                                        {{ 'admin.waitlist.empty'|trans({}, 'admin') }}
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        {% endblock %}

    {% endembed %}
{% endblock %}
