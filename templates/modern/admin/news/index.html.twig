{% extends '@theme/base.html.twig' %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_layout.html.twig' %}

        {% block admin_content %}

            <section class="section-page-title py-4">
                <h2 class="display-6 fw-bold">News Management</h2>
                <p class="text-muted">Manage all news articles published on OktoDark.</p>
            </section>

            <div class="mb-3">
                <a href="{{ path('admin_news_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Create News Article
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-dark table-striped mb-0">
                        <thead>
                        <tr>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Created At</th>
                            <th style="width: 150px;">Actions</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in news %}
                            <tr>
                                <td>{{ item.title }}</td>
                                <td>{{ item.author }}</td>
                                <td>{{ item.createdAt|date('Y-m-d H:i') }}</td>
                                <td>
                                    <a href="{{ path('admin_news_edit', {id: item.id}) }}" class="btn btn-sm btn-outline-info">
                                        Edit
                                    </a>
                                    <a href="{{ path('admin_news_delete', {id: item.id}) }}"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Delete this article?');">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">
                                    No news articles found.
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

        {% endblock %}

    {% endembed %}
{% endblock %}