{% extends '@theme/base.html.twig' %}
{% block title %}Edit Article: {{ news_item.title }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}

            <div class="mb-4">
                <a href="{{ path('admin_news_index') }}" class="admin-btn admin-btn-secondary admin-btn-sm mb-3">
                    <i class="fas fa-arrow-left"></i> Back to News Management
                </a>
                <div class="section-title">
                    <h2>Edit News Article</h2>
                    <p>Updating: <strong>{{ news_item.title }}</strong></p>
                </div>
            </div>

            <div class="admin-card">
                {{ form_start(form) }}

                <div class="row g-4 mb-4">
                    <div class="col-lg-8">
                        <label class="admin-form-label">Article Title</label>
                        {{ form_widget(form.title, {
                            attr: { class: 'admin-form-control' }
                        }) }}
                        {{ form_errors(form.title) }}
                    </div>

                    <div class="col-lg-4">
                        <label class="admin-form-label">Author Name</label>
                        {{ form_widget(form.author, {
                            attr: { class: 'admin-form-control' }
                        }) }}
                        {{ form_errors(form.author) }}
                    </div>
                </div>

                <div class="mb-4">
                    <label class="admin-form-label">Article Content</label>
                    <input id="trix-content" type="hidden"
                           name="{{ form.content.vars.full_name }}"
                           value="{{ form.content.vars.value }}">

                    <div class="editor-wrapper shadow-sm">
                        <trix-editor input="trix-content" class="trix-editor-modern"></trix-editor>
                    </div>
                    {{ form_errors(form.content) }}
                </div>

                <div class="row g-4 align-items-end">
                    <div class="col-md-4">
                        <label class="admin-form-label">Published Date</label>
                        {{ form_widget(form.publishedAt, {
                            attr: { class: 'admin-form-control' }
                        }) }}
                        {{ form_errors(form.publishedAt) }}
                    </div>
                    
                    <div class="col-md-8 text-end">
                        {{ form_widget(form._token) }}
                        <button type="submit" class="admin-btn admin-btn-primary px-5">
                            <i class="fas fa-save"></i> Update Article
                        </button>
                    </div>
                </div>

                {{ form_end(form, { render_rest: false }) }}
            </div>

        {% endblock %}

    {% endembed %}
{% endblock %}
