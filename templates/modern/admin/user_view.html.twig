{% extends '@theme/base.html.twig' %}
{% block title %}{{ 'admin.users.profile'|trans({}, 'admin') }}: {{ user.username }} – Admin{% endblock %}
{% block body_id 'admin' %}

{% block main %}
    {% embed '@theme/admin/partials/_nav.html.twig' %}

        {% block admin_content %}

            <div class="mb-4">
                <a href="{{ path('admin_users') }}" class="admin-btn admin-btn-secondary admin-btn-sm mb-3">
                    <i class="fas fa-arrow-left"></i> {{ 'admin.users.title'|trans({}, 'admin') }}
                </a>
                <div class="section-title">
                    <h2>{{ 'admin.users.profile'|trans({}, 'admin') }}</h2>
                    <p>{{ 'admin.users.subtitle'|trans({}, 'admin')|replace({'Monitor and manage all registered accounts on the platform.': 'Comprehensive details for account'}) }} <strong>{{ user.username }}</strong></p>
                </div>
            </div>

            <section>

                {% for message in app.flashes('success') %}
                    <div class="alert alert-success border-0 shadow-sm mb-4">
                        <i class="fas fa-check-circle me-2"></i> {{ message }}
                    </div>
                {% endfor %}

                <div class="row g-4">
                    {# MAIN INFO #}
                    <div class="col-lg-8">
                        <div class="admin-card mb-4">
                            <h5 class="mb-4">{{ 'admin.users.account_info'|trans({}, 'admin') }}</h5>
                            
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="mb-4">
                                        <label class="admin-form-label">{{ 'admin.users.full_name'|trans({}, 'admin') }}</label>
                                        <div class="fs-5 fw-bold text-white">{{ user.firstName ?: 'Not provided' }} {{ user.lastName }}</div>
                                    </div>
                                    <div class="mb-4">
                                        <label class="admin-form-label">{{ 'admin.common.email'|trans({}, 'admin') }}</label>
                                        <div class="text-white">{{ user.email }}</div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="admin-form-label">{{ 'admin.users.user_id'|trans({}, 'admin') }}</label>
                                        <code class="text-accent">#{{ user.id }}</code>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-4">
                                        <label class="admin-form-label">{{ 'admin.users.username'|trans({}, 'admin') }}</label>
                                        <div class="text-white d-flex align-items-center">
                                            {{ user.username }}
                                            {% if user.isVerified %}
                                                <i class="fas fa-check-circle text-info ms-2" title="Verified Account"></i>
                                            {% endif %}
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <label class="admin-form-label">{{ 'admin.users.account_created'|trans({}, 'admin') }}</label>
                                        <div class="text-white">{{ user.createdAt|date('F j, Y, g:i a')|default('N/A') }}</div>
                                    </div>
                                    <div class="mb-0">
                                        <label class="admin-form-label">{{ 'admin.users.last_login'|trans({}, 'admin') }}</label>
                                        <div class="text-white">{{ user.lastLoginAt|date('F j, Y, g:i a')|default('Never') }}</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="admin-card">
                            <h5 class="mb-4">{{ 'admin.users.activity_logs'|trans({}, 'admin') }}</h5>
                            <div class="text-muted text-center py-4">
                                <i class="fas fa-clock-rotate-left d-block mb-3 fs-3 opacity-25"></i>
                                <p>{{ 'admin.users.activity_integration'|trans({}, 'admin') }}</p>
                            </div>
                        </div>
                    </div>

                    {# SIDEBAR INFO #}
                    <div class="col-lg-4">
                        <div class="admin-card mb-4">
                            <h5 class="mb-4">{{ 'admin.users.status_access'|trans({}, 'admin') }}</h5>
                            
                            <div class="admin-list-group">
                                <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                    <span>{{ 'admin.users.status'|trans({}, 'admin') }}</span>
                                    {% if user.active %}
                                        <span class="admin-badge admin-badge-success">Active</span>
                                    {% else %}
                                        <span class="admin-badge admin-badge-danger">Suspended</span>
                                    {% endif %}
                                </div>
                                <div class="admin-list-group-item d-flex justify-content-between align-items-center">
                                    <span>{{ 'admin.users.verified'|trans({}, 'admin') }}</span>
                                    {% if user.isVerified %}
                                        <span class="admin-badge admin-badge-info">{{ 'admin.users.yes'|trans({}, 'admin') }}</span>
                                    {% else %}
                                        <span class="admin-badge admin-badge-secondary">{{ 'admin.users.no'|trans({}, 'admin') }}</span>
                                    {% endif %}
                                </div>
                            </div>

                            <div class="mt-4">
                                <label class="admin-form-label mb-2">{{ 'admin.users.assigned_roles'|trans({}, 'admin') }}</label>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for role in user.roles %}
                                        <span class="badge bg-dark border border-secondary p-2">{{ role|replace({'ROLE_': ''}) }}</span>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                        <div class="admin-card">
                            <h5 class="mb-4 text-warning"><i class="fas fa-shield-halved me-2"></i>{{ 'admin.users.security_controls'|trans({}, 'admin') }}</h5>
                            <p class="small text-muted mb-4">{{ 'admin.users.security_subtitle'|trans({}, 'admin') }}</p>
                            
                            <div class="d-grid gap-2">
                                <a href="{{ path('admin_clear_trusted_devices', {id: user.id}) }}" 
                                   class="admin-btn admin-btn-danger justify-content-center"
                                   onclick="return confirm('Clear all trusted devices? The user will need to re-verify their next login.')">
                                    <i class="fas fa-user-lock"></i> {{ 'admin.users.reset_trusted_devices'|trans({}, 'admin') }}
                                </a>
                                <button class="admin-btn admin-btn-secondary justify-content-center" disabled>
                                    <i class="fas fa-key"></i> {{ 'admin.users.force_password_reset'|trans({}, 'admin') }}
                                </button>
                                <button class="admin-btn admin-btn-secondary justify-content-center" disabled>
                                    <i class="fas fa-ban"></i> {{ 'admin.users.terminate_sessions'|trans({}, 'admin') }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </section>

        {% endblock %}

    {% endembed %}
{% endblock %}
