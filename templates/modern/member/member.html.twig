{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'base.member'|trans({}, 'base') }}{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'member_area' %}

{% block main %}

    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'base.member'|trans({}, 'base') }}</h2>
            <p class="lead text-muted mt-2">{{ 'member.subtitle'|trans({}, 'member') }}</p>
        </div>
    </section>

    <section class="section section-md bg-default text-center pt-0">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <h5 class="text-gray-500">{{ 'member.tier_upgrade_notice'|trans({}, 'member') }}</h5>
                </div>
            </div>
        </div>
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-xl-10">
                    <h4 class="text-uppercase">{{ 'member.tiers_rewards'|trans({}, 'member') }}</h4>
                    <div class="tabs-custom tabs-horizontal tabs-corporate" id="tabs-1">
                        <ul class="nav nav-tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="tier-1-tab" data-bs-toggle="tab" data-bs-target="#tier-1" type="button" role="tab" aria-controls="tier-1" aria-selected="true">
                                    {% if is_granted('ROLE_TIER_I') %}<i class="fas fa-lock-open"></i>{% else %}<i class="fas fa-lock"></i>{% endif %} Tier I
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tier-2-tab" data-bs-toggle="tab" data-bs-target="#tier-2" type="button" role="tab" aria-controls="tier-2" aria-selected="false">
                                    {% if is_granted('ROLE_TIER_II') %}<i class="fas fa-lock-open"></i>{% else %}<i class="fas fa-lock"></i>{% endif %} Tier II
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tier-3-tab" data-bs-toggle="tab" data-bs-target="#tier-3" type="button" role="tab" aria-controls="tier-3" aria-selected="false">
                                    {% if is_granted('ROLE_TIER_III') %}<i class="fas fa-lock-open"></i>{% else %}<i class="fas fa-lock"></i>{% endif %} Tier III
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tier-4-tab" data-bs-toggle="tab" data-bs-target="#tier-4" type="button" role="tab" aria-controls="tier-4" aria-selected="false">
                                    {% if is_granted('ROLE_TIER_IV') %}<i class="fas fa-lock-open"></i>{% else %}<i class="fas fa-lock"></i>{% endif %} Tier IV
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="tier-5-tab" data-bs-toggle="tab" data-bs-target="#tier-5" type="button" role="tab" aria-controls="tier-5" aria-selected="false">
                                    {% if is_granted('ROLE_TIER_V') %}<i class="fas fa-lock-open"></i>{% else %}<i class="fas fa-lock"></i>{% endif %} Tier V
                                </button>
                            </li>
                        </ul>
                        <div class="tab-content" id="nav-tabContent">
                            <!-- Tier I -->
                            <div class="tab-pane fade show active" id="tier-1" role="tabpanel" aria-labelledby="tier-1-tab">
                                <div class="mt-3">
                                    {% if is_granted('ROLE_TIER_I') %}
                                        <p>{{ 'member.download_beta_text'|trans({}, 'member') }}:</p>
                                        <div class="row row-condensed">
                                            {% for g in games %}
                                                <div class="col-3">
                                                    <h5 class="text-primary"><b>{{ g.ourGameName }}</b></h5>
                                                    <p><a class="button button-sm button-gradient" href="{{ g.ourGameBeta }}">{{ 'base.mods'|trans({}, 'base')|replace({'Mods': 'Download'}) }}</a></p>
                                                    <p><a class="button button-sm button-gradient" href="{{ path('play_online') }}">{{ 'base.streaming'|trans({}, 'base')|replace({'Streaming': 'Play Online'}) }}</a></p>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <p>{{ 'member.upgrade_now_text'|trans({}, 'member') }}</p>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Tier II -->
                            <div class="tab-pane fade" id="tier-2" role="tabpanel" aria-labelledby="tier-2-tab">
                                <div class="mt-3">
                                    {% if is_granted('ROLE_TIER_II') %}
                                        <p>{{ 'member.download_alpha_text'|trans({}, 'member') }}:</p>
                                        <div class="row row-condensed">
                                            {% for g in games %}
                                                <div class="col-3">
                                                    <h5 class="text-primary">{{ g.ourGameName }}</h5>
                                                    <p><a class="button button-sm button-gradient" href="{{ g.ourGameAlpha }}">{{ 'base.mods'|trans({}, 'base')|replace({'Mods': 'Download'}) }}</a></p>
                                                </div>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <p>{{ 'member.upgrade_now_text'|trans({}, 'member') }}</p>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Tier III -->
                            <div class="tab-pane fade" id="tier-3" role="tabpanel" aria-labelledby="tier-3-tab">
                                <div class="mt-3">
                                    {% if is_granted('ROLE_TIER_III') %}
                                        <p>{{ 'member.credits_request'|trans({}, 'member') }}</p>
                                        <form class="col-lg-12">
                                            <label>{{ 'label.fullname'|trans({}, 'profile') }}</label>
                                            <input id="your_name" name="Your name">
                                            <label>{{ 'label.firstName'|trans({}, 'profile')|replace({'First Name': 'Nickname'}) }}</label>
                                            <input id="nickname" name="Nickname">
                                            <button class="button button-sm button-gradient">{{ 'common.save'|trans({}, 'common') }}</button>
                                        </form>
                                    {% else %}
                                        <p>{{ 'member.upgrade_now_text'|trans({}, 'member') }}</p>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Tier IV -->
                            <div class="tab-pane fade" id="tier-4" role="tabpanel" aria-labelledby="tier-4-tab">
                                <div class="mt-3">
                                    {% if is_granted('ROLE_TIER_IV') %}
                                        <p>{{ 'member.tier_4_content'|trans({}, 'member') }}</p>
                                    {% else %}
                                        <p>{{ 'member.upgrade_now_text'|trans({}, 'member') }}</p>
                                    {% endif %}
                                </div>
                            </div>

                            <!-- Tier V -->
                            <div class="tab-pane fade" id="tier-5" role="tabpanel" aria-labelledby="tier-5-tab">
                                <div class="mt-3">
                                    {% if is_granted('ROLE_TIER_V') %}
                                        <p>{{ 'member.download_source'|trans({}, 'member') }}</p>
                                    {% else %}
                                        <p>{{ 'member.upgrade_now_text'|trans({}, 'member') }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

{% endblock %}