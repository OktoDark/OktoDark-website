{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'title.change_password'|trans }}{% endblock %}

{% block head %}
    {{ parent() }}
{% endblock %}

{% block body_id 'user_password' %}

{% block main %}

    <section class="section section-page-title context-dark">
        <div class="container">
            <h2>{{ 'title.change_password'|trans }}</h2>
        </div>
    </section>

    <section class="section section-md bg-default text-center">
        <div class="container">
            <div class="row">
                <div class="col-8">
                    <div class="alert alert-info" role="alert">{{ 'info.change_password'|trans }}</div>
                    {{ form_start(form, {'attr': {'class': 'rd-mailform text-left', 'data-form-type': 'contact', 'data-form-output': 'form-output-global'}}) }}
                    <div class="form-warp">
                        {{ form_widget(form) }}
                    </div>
                    <br>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-save" aria-hidden="true"></i> {{ 'action.save'|trans }}
                    </button>
                    <br>
                    {{ form_end(form) }}
                </div>
                <div class="col-4" style="text-align:left;">
                    <i class="fas fa-key"></i>  <a href="{{ path('user_change_password') }}">{{ 'change.password'|trans }}</a>
                    <br>
                    <i class="fas fa-user"></i> <a href="{{ path('user_edit') }}">{{ 'change.informations'|trans }}</a>
                </div>
            </div>
        </div>
    </section>

{% endblock %}

