{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.member'|trans({}, 'titles') }}{% endblock %}
{% block body_id 'profile' %}

{% block main %}

    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.profile'|trans({}, 'titles') }}</h2>
        </div>
    </section>

    <section class="py-5 bg-light">
        <div class="container">
            <div class="row">

                <!-- Sidebar -->
                <div class="col-lg-3 mb-4">

                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body text-center">

                            <img
                                    src="{{ app.user.avatarUrl ?? asset('images/default-avatar.png') }}"
                                    class="rounded-circle img-fluid shadow-sm mb-3"
                                    width="140" height="140"
                                    alt="{{ users.username }}"
                            >

                            <h4 class="fw-bold">{{ users.username }}</h4>
                            <p class="text-muted">{{ users.firstName }} {{ users.lastName }}</p>

                            <div class="list-group mt-4">
                                <a href="{{ path('profile_area') }}" class="list-group-item list-group-item-action active">
                                    <i class="fas fa-user me-2"></i>{{ 'title.profile'|trans({}, 'titles') }}
                                </a>
                                <a href="{{ path('settings_area') }}" class="list-group-item list-group-item-action">
                                    <i class="fas fa-cog me-2"></i>{{ 'title.settings'|trans({}, 'titles') }}
                                </a>
                            </div>

                        </div>
                    </div>

                </div>

                <!-- Main Content -->
                <div class="col-lg-9">

                    <!-- Profile Overview -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">

                            <h3 class="fw-bold mb-3 text-success">{{ users.username }}</h3>

                            <div class="row g-3">

                                <div class="col-md-6">
                                    <strong>{{ 'label.name'|trans({}, 'labels') }}:</strong>
                                    <p>{{ users.firstName }} {{ users.lastName }}</p>
                                </div>

                                <div class="col-md-6">
                                    <strong>{{ 'label.email'|trans({}, 'labels') }}:</strong>
                                    <p>{{ users.email }}</p>
                                </div>

                                <div class="col-md-6">
                                    <strong>{{ 'label.roles'|trans({}, 'labels') }}:</strong>
                                    <p>{% include("@theme/member/parts/roles.html.twig") %}</p>
                                </div>

                                <div class="col-md-6">
                                    <strong>{{ 'label.member_since'|trans({}, 'labels') }}:</strong>
                                    <p>{{ users.agreedTerms|format_datetime('medium', 'short', '', 'UTC') }}</p>
                                </div>

                                <div class="col-md-6">
                                    <strong>{{ 'label.account_status'|trans({}, 'labels') }}:</strong>
                                    <p>{% include("@theme/member/parts/active.html.twig") %}</p>
                                </div>

                            </div>

                            <hr class="my-4">

                            <p class="text-muted fst-italic">
                                {{ 'profile.rules_note'|trans({
                                    '%settings_link%': path('settings_area')
                                }, 'profile')|raw }}
                            </p>

                        </div>
                    </div>

                    <!-- Social Information -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white fw-bold">
                            <i class="fas fa-comments me-2"></i>{{ 'social.social_info'|trans({}, 'titles') }}
                        </div>
                        <div class="card-body">

                            <ul class="list-unstyled fs-5">
                                <li class="mb-2">
                                    <i class="fas fa-archive me-2"></i>
                                    <a href="https://forum.truckersmp.com/index.php?/profile/189416-Viruzzz/" target="_blank">
                                        Forum Profile
                                    </a>
                                </li>
                                <li class="mb-2">
                                    <i class="fab fa-twitter me-2 text-info"></i>
                                    <a href="https://twitter.com/mvt3am" target="_blank">Twitter</a>
                                </li>
                                <li class="mb-2">
                                    <i class="fab fa-twitch me-2 text-purple"></i>
                                    <a href="https://twitch.tv/mvt3am" target="_blank">Twitch</a>
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-truck me-2"></i>
                                    <a href="https://worldoftrucks.com/en/online_profile.php?id=4025088" target="_blank">
                                        World of Trucks
                                    </a>
                                </li>
                                <li class="mb-2">
                                    <i class="fab fa-youtube me-2 text-danger"></i>
                                    <a href="https://www.youtube.com/channel/UCzPfw3b7L4oVr9C4BykM-8w" target="_blank">
                                        YouTube
                                    </a>
                                </li>
                            </ul>

                        </div>
                    </div>

                    <!-- Player History -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-header bg-white fw-bold">
                            <i class="fas fa-briefcase me-2"></i>{{ 'title.player_history'|trans({}, 'titles') }}
                        </div>
                        <div class="card-body text-center py-5">
                            <h4 class="text-muted">{{ 'profile.no_history'|trans({}, 'titles') }}</h4>
                        </div>
                    </div>

                    <!-- Punishment History -->
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white fw-bold">
                            <i class="fas fa-graduation-cap me-2"></i>{{ 'title.punishment_history'|trans }}
                            <small class="text-success ms-2">{{ 'label.public'|trans }}</small>
                        </div>
                        <div class="card-body text-center py-5">
                            <h4 class="text-muted">{{ 'profile.no_penalties'|trans }}</h4>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </section>

{% endblock %}