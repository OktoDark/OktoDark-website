{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'forum.title'|trans({}, 'forum') }}{% endblock %}

{% block body %}
    <div class="container py-5">

        <div class="text-center mb-5">
            <h1 class="fw-bold">{{ 'forum.title'|trans({}, 'forum') }}</h1>
            <p class="text-muted">{{ 'forum.categories_subtitle'|trans({}, 'forum') }}</p>
        </div>

        {% if categories is empty %}
            <div class="alert alert-info text-center">
                {{ 'forum.no_categories'|trans({}, 'forum') }}
            </div>
        {% else %}
            <div class="row g-4">
                {% for category in categories %}
                    <div class="col-md-6 col-lg-4">
                        <a href="{{ path('forum_category_view', { slug: category.slug }) }}"
                           class="text-decoration-none text-dark">
                            <div class="card h-100 shadow-sm border-0 hover-shadow">
                                <div class="card-body">
                                    <h5 class="card-title fw-semibold">{{ category.name }}</h5>

                                    {% if category.description %}
                                        <p class="card-text text-muted small">
                                            {{ category.description }}
                                        </p>
                                    {% endif %}
                                </div>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% endif %}

    </div>
{% endblock %}