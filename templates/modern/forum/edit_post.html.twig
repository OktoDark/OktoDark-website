{% extends '@theme/base.html.twig' %}

{% block title %}Edit Post{% endblock %}

{% block body %}
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">Edit Forum Post</h2>
            <p class="lead text-muted mt-2">Modify your contribution to the discussion.</p>
        </div>
    </section>

    <section class="section section-lg bg-default pt-0">
        <div class="container">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('forum') }}" class="text-success">Forum</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('forum_category_view', { slug: post.thread.category.slug }) }}" class="text-success">{{ post.thread.category.name }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('forum_thread_view', { slug: post.thread.slug }) }}" class="text-success">{{ post.thread.title|length > 30 ? post.thread.title|slice(0, 30) ~ '...' : post.thread.title }}</a></li>
                    <li class="breadcrumb-item active">Edit Post</li>
                </ol>
            </nav>

            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-5">
                            <h2 class="fw-bold mb-4">Edit Your Post</h2>

                            {{ form_start(form) }}
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Content</label>
                                    <div class="editor-wrapper rounded border bg-white mb-2">
                                        {{ form_widget(form.content) }}
                                    </div>
                                    {{ form_errors(form.content) }}
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-success px-5 text-bg-success shadow-sm fw-bold">Save Changes</button>
                                    <a href="{{ path('forum_thread_view', { slug: post.thread.slug }) }}" class="btn btn-outline-secondary">Cancel</a>
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}