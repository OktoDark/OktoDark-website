{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'forum.search.results_title'|trans({}, 'forum') }} - {{ 'forum.title'|trans({}, 'forum') }}{% endblock %}

{% block body %}
    <!-- Hero Section consistent with Blog -->
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'forum.search.hero_title'|trans({}, 'forum') }}</h2>
            <p class="lead text-muted mt-2">{{ 'forum.search.hero_subtitle'|trans({}, 'forum') }}</p>
        </div>
    </section>

    <section class="section section-lg bg-default pt-0">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-10 mx-auto">

                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="{{ path('forum') }}" class="text-success">{{ 'forum.title'|trans({}, 'forum') }}</a></li>
                            <li class="breadcrumb-item active">{{ 'forum.search.title'|trans({}, 'forum') }}</li>
                        </ol>
                    </nav>

                    <!-- Search Input Card -->
                    <div class="card shadow-sm border-0 mb-5">
                        <div class="card-body p-4 p-lg-5">
                            <form action="{{ path('forum_search') }}" method="get" class="d-flex gap-2">
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa-solid fa-search"></i></span>
                                    <input type="text" name="q" class="form-control border-start-0 ps-0" placeholder="{{ 'forum.search_placeholder'|trans({}, 'forum') }}" value="{{ query }}" required>
                                    <button class="btn btn-success text-bg-success px-5 fw-bold">{{ 'forum.search.title'|trans({}, 'forum') }}</button>
                                </div>
                            </form>
                            {% if query %}
                                <div class="mt-3 d-flex align-items-center gap-2">
                                    <span class="text-muted small">{{ 'forum.search.showing_results_for'|trans({}, 'forum') }}:</span>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 fs-6">"{{ query }}"</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Results List -->
                    <div class="results-container">
                        {% if paginator.numResults == 0 %}
                            {% if query %}
                                <div class="card border-0 shadow-sm">
                                    <div class="card-body p-5 text-center">
                                        <div class="mb-4">
                                            <i class="fa-solid fa-magnifying-glass fa-4x text-light"></i>
                                        </div>
                                        <h3 class="fw-bold">{{ 'forum.search.no_results'|trans({}, 'forum') }}</h3>
                                        <p class="text-muted mb-4">{{ 'forum.search.no_results_help'|trans({'%query%': query}, 'forum')|raw }}<br>{{ 'forum.search.no_results_try_again'|trans({}, 'forum') }}</p>
                                        <a href="{{ path('forum') }}" class="btn btn-outline-success px-5">{{ 'forum.search.back_to_forum'|trans({}, 'forum') }}</a>
                                    </div>
                                </div>
                            {% endif %}
                        {% else %}
                            {% for thread in paginator.results %}
                                <div class="card shadow-sm border-0 mb-3 overflow-hidden result-item">
                                    <a href="{{ path('forum_thread_view', {slug: thread.slug}) }}" class="text-decoration-none">
                                        <div class="card-body p-4">
                                            <div class="row align-items-center">
                                                <div class="col-md-9">
                                                    <h5 class="mb-1 fw-bold text-dark hover-success">
                                                        {% if thread.pinned %}<i class="fa-solid fa-thumbtack text-warning me-1 small"></i>{% endif %}
                                                        {{ thread.title }}
                                                    </h5>
                                                    <div class="small text-muted mb-3">
                                                        <span class="badge bg-light text-success border border-success-subtle me-2">{{ thread.category.name }}</span>
                                                        {{ 'forum.by'|trans({}, 'forum') }} <span class="text-dark fw-medium">{{ thread.author.username }}</span> &bull; {{ thread.createdAt|date('M d, Y') }}
                                                    </div>
                                                    <p class="mb-0 text-muted small">
                                                        {{ thread.content|striptags|slice(0, 180) }}...
                                                    </p>
                                                </div>
                                                <div class="col-md-3 text-md-end mt-3 mt-md-0">
                                                    <div class="d-flex d-md-block justify-content-between">
                                                        <div class="mb-md-2">
                                                            <span class="h5 mb-0 fw-bold text-success d-block">{{ thread.posts|length }}</span>
                                                            <span class="x-small text-muted text-uppercase">{{ 'forum.replies'|trans({}, 'forum') }}</span>
                                                        </div>
                                                        <div>
                                                            <span class="h6 mb-0 fw-bold text-dark d-block">{{ thread.views }}</span>
                                                            <span class="x-small text-muted text-uppercase">{{ 'forum.views'|trans({}, 'forum') }}</span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            {% endfor %}

                            <!-- Pagination -->
                            {% if paginator.hasToPaginate %}
                                <nav aria-label="{{ 'forum.search.pagination_label'|trans({}, 'forum') }}" class="mt-5">
                                    <ul class="pagination justify-content-center">
                                        <li class="page-item {{ not paginator.hasPreviousPage ? 'disabled' }}">
                                            <a class="page-link shadow-sm"
                                               href="{{ paginator.hasPreviousPage
                                               ? path('forum_search', { q: query, page: paginator.previousPage })
                                               : '#' }}">
                                                <span class="fas fa-chevron-left"></span>
                                            </a>
                                        </li>

                                        {% for i in 1..paginator.lastPage %}
                                            <li class="page-item {{ i == paginator.currentPage ? 'active' }}">
                                                <a class="page-link shadow-sm"
                                                   href="{{ path('forum_search', { q: query, page: i }) }}">
                                                    {{ i }}
                                                </a>
                                            </li>
                                        {% endfor %}

                                        <li class="page-item {{ not paginator.hasNextPage ? 'disabled' }}">
                                            <a class="page-link shadow-sm"
                                               href="{{ paginator.hasNextPage
                                               ? path('forum_search', { q: query, page: paginator.nextPage })
                                               : '#' }}">
                                                <span class="fas fa-chevron-right"></span>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            {% endif %}
                        {% endif %}
                    </div>

                </div>
            </div>
        </div>
    </section>
{% endblock %}