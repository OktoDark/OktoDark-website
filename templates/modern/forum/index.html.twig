{% extends '@theme/base.html.twig' %}

{% block title %}Forum{% endblock %}

{% block body %}
    <!-- Hero Section consistent with Blog -->
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">Discussions</h2>
            <p class="lead text-muted mt-2">Join our community and share your thoughts</p>
        </div>
    </section>

    <section class="section section-lg bg-default pt-0">
        <div class="container">
            <div class="row g-5">
                <!-- Main Content -->
                <div class="col-lg-8 col-xl-9">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fw-bold mb-0">Categories</h4>
                        <form action="{{ path('forum_search') }}" method="get" class="d-flex gap-2">
                            <div class="input-group input-group-sm">
                                <input type="text" name="q" class="form-control" placeholder="Search forum..." required>
                                <button class="btn btn-primary"><i class="fa-solid fa-search"></i></button>
                            </div>
                        </form>
                    </div>

                    {% for category in categories %}
                        <div class="card shadow-sm border-0 mb-5 overflow-hidden">
                            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center">
                                <div class="category-icon-box me-3">
                                    <i class="fa-solid fa-comments text-success fs-4"></i>
                                </div>
                                <div>
                                    <h5 class="mb-0 fw-bold text-dark">{{ category.name }}</h5>
                                    {% if category.description %}
                                        <small class="text-muted">{{ category.description }}</small>
                                    {% endif %}
                                </div>
                            </div>
                            
                            <div class="list-group list-group-flush">
                                {# SUB-CATEGORIES SECTION #}
                                {% if category.children|length > 0 %}
                                    <div class="bg-light bg-opacity-25 px-4 py-2 border-bottom">
                                        <small class="text-uppercase fw-bold text-muted" style="font-size: 0.7rem; letter-spacing: 1px;">Sub-Categories</small>
                                    </div>
                                    <div class="row g-0">
                                        {% for sub in category.children %}
                                            <div class="col-12 border-bottom">
                                                <div class="d-flex align-items-center p-3 px-4 text-decoration-none transition-all hover-bg-light">
                                                    <i class="fa-solid fa-folder-tree text-success opacity-50 me-3 fs-5"></i>
                                                    <div class="flex-grow-1">
                                                        <a href="{{ path('forum_category_view', {slug: sub.slug}) }}" class="fw-bold text-dark text-decoration-none hover-success">{{ sub.name }}</a>
                                                        <div class="x-small text-muted">{{ sub.threads|length }} discussions</div>
                                                    </div>
                                                    
                                                    {# LAST POST INFO FOR SUBCATEGORY #}
                                                    <div class="d-none d-md-block text-end flex-shrink-0" style="min-width: 200px;">
                                                        {% set lastThread = sub.lastThread %}
                                                        {% if lastThread %}
                                                            <div class="x-small text-dark fw-bold text-truncate" style="max-width: 180px;">
                                                                <a href="{{ path('forum_thread_view', {slug: lastThread.slug}) }}" class="text-dark text-decoration-none">{{ lastThread.title }}</a>
                                                            </div>
                                                            <div class="x-small text-muted">
                                                                by <span class="fw-medium text-success">{{ lastThread.author.username }}</span> &bull; {{ lastThread.updatedAt|date('M d, H:i') }}
                                                            </div>
                                                        {% else %}
                                                            <span class="x-small text-muted italic">No posts</span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                {% endif %}

                                {# LATEST THREADS IN THIS CATEGORY #}
                                {% for thread in category.threads|slice(0, 5) %}
                                    <a href="{{ path('forum_thread_view', {slug: thread.slug}) }}" class="list-group-item list-group-item-action p-4 border-start-0 border-end-0">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="pe-3">
                                                <h6 class="mb-1 fw-bold text-success">
                                                    {% if thread.pinned %}<i class="fa-solid fa-thumbtack text-warning me-1 small"></i>{% endif %}
                                                    {% if thread.locked %}<i class="fa-solid fa-lock text-muted me-1 small"></i>{% endif %}
                                                    {{ thread.title }}
                                                </h6>
                                                <div class="small text-muted">
                                                    by <span class="text-dark fw-medium">{{ thread.author.username }}</span> &bull; {{ thread.createdAt|date('M d, Y') }}
                                                </div>
                                            </div>
                                            <div class="text-end flex-shrink-0">
                                                <span class="badge bg-light text-success border-success-subtle border">{{ thread.posts|length }} replies</span>
                                                <div class="small text-muted mt-1">{{ thread.views }} views</div>
                                            </div>
                                        </div>
                                    </a>
                                {% else %}
                                    {% if category.children|length == 0 %}
                                        <div class="p-4 text-center text-muted italic">No threads in this category yet.</div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                            {% if category.threads|length > 0 %}
                                <div class="card-footer bg-white border-0 text-center py-2">
                                    <a href="{{ path('forum_category_view', {slug: category.slug}) }}" class="btn btn-link btn-sm text-success text-decoration-none fw-bold">
                                        View all discussions in {{ category.name }} <i class="fa-solid fa-chevron-right ms-1 small"></i>
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}

                    {# FORUM LEGEND / STATISTICS #}
                    <div class="card shadow-sm border-0 mt-5 bg-light bg-opacity-50">
                        <div class="card-header bg-white border-bottom py-3">
                            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-chart-simple me-2 text-success"></i> Community Statistics</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4 text-center mb-4 pb-4 border-bottom">
                                <div class="col-md-4">
                                    <div class="display-6 fw-bold text-dark">{{ totalThreads }}</div>
                                    <div class="small text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Total Threads</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="display-6 fw-bold text-dark">{{ totalPosts }}</div>
                                    <div class="small text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Total Posts</div>
                                </div>
                                <div class="col-md-4">
                                    <div class="display-6 fw-bold text-success">{{ onlineUsers|length }}</div>
                                    <div class="small text-muted text-uppercase fw-bold" style="letter-spacing: 1px;">Members Online</div>
                                </div>
                            </div>

                            <div>
                                <h6 class="fw-bold mb-3 small text-muted text-uppercase"><i class="fa-solid fa-users me-2"></i> Who is online now?</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for user in onlineUsers %}
                                        <a href="{{ path('admin_user_view', {id: user.id}) }}" class="badge bg-white border text-dark text-decoration-none py-2 px-3 shadow-xs hover-bg-light transition-all">
                                            <i class="fa-solid fa-circle text-success me-1" style="font-size: 0.5rem;"></i> {{ user.username }}
                                        </a>
                                    {% else %}
                                        <span class="text-muted italic small">Only ghosts here right now...</span>
                                    {% endfor %}
                                </div>
                                <p class="mt-3 x-small text-muted mb-0">List based on users active in the last 15 minutes.</p>
                            </div>

                            {# BADGES LEGEND #}
                            {% if permanentBadges|length > 0 %}
                                <div class="mt-5 pt-4 border-top">
                                    <h6 class="fw-bold mb-3 small text-muted text-uppercase"><i class="fa-solid fa-award me-2"></i> Badges Legend</h6>
                                    <div class="d-flex flex-wrap gap-3">
                                        {% for badge in permanentBadges %}
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="rounded-circle d-flex align-items-center justify-content-center shadow-xs" style="width: 28px; height: 28px; font-size: 0.8rem; background-color: {{ badge.color }}; color: #fff;">
                                                    <i class="{{ badge.icon }}"></i>
                                                </span>
                                                <span class="small text-muted" title="{{ badge.description }}" data-bs-toggle="tooltip" data-bs-placement="top">{{ badge.name }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                </div>

                <!-- Sidebar -->
                <div class="col-lg-4 col-xl-3">
                    <aside class="aside-components">
                        <!-- User Profile Card -->
                        <div class="aside-component card shadow-sm border-0 p-4 mb-4 text-center">
                            <h5 class="fw-bold mb-4 border-bottom pb-2">Community Profile</h5>
                            {% if app.user %}
                                <div class="avatar-container mb-3 d-flex justify-content-center">
                                    {% if app.user.avatarUrl %}
                                        <img src="{{ app.user.avatarUrl }}" class="rounded-circle shadow-sm border border-2 border-white" width="90" height="90" alt="{{ app.user.username }}">
                                    {% else %}
                                        <div class="avatar-profile-fallback rounded-circle shadow-sm d-flex align-items-center justify-content-center mx-auto" style="width: 90px; height: 90px; background: #f8f9fa; border: 1px solid #dee2e6;">
                                            <i class="fa-solid fa-user fa-3x text-muted"></i>
                                        </div>
                                    {% endif %}
                                </div>
                                <h5 class="fw-bold mb-1">{{ app.user.username }}</h5>
                                <p class="text-muted small mb-3">Reputation: <span class="text-success fw-bold">{{ app.user.reputation }}</span></p>
                                
                                <div class="d-flex flex-wrap justify-content-center gap-2 mb-4">
                                    {% for badge in app.user.badges %}
                                        <span class="badge bg-success-subtle text-success border border-success-subtle" title="{{ badge.description }}">
                                            <i class="{{ badge.icon }} me-1"></i> {{ badge.name }}
                                        </span>
                                    {% endfor %}
                                </div>
                                
                                <div class="d-grid gap-2">
                                    <a href="{{ path('forum_feed') }}" class="btn btn-outline-success btn-sm border-success">
                                        <i class="fa-solid fa-rss me-1"></i> My Circle Feed
                                    </a>
                                    <a href="{{ path('forum_search', {author: app.user.username}) }}" class="btn btn-success text-bg-success btn-sm">
                                        <i class="fa-solid fa-list-check me-1"></i> My Discussions
                                    </a>
                                </div>
                            {% else %}
                                <div class="py-3">
                                    <i class="fa-solid fa-users-rays fa-3x text-light mb-3"></i>
                                    <p class="text-muted small mb-4">Join our community to participate in discussions and earn reputation!</p>
                                    <a href="{{ path('security_login') }}" class="btn btn-success text-bg-success w-100">Login to Forum</a>
                                </div>
                            {% endif %}
                        </div>

                        <!-- Latest Activity Widget -->
                        {% if latestThreads|default is not empty %}
                            <div class="aside-component card shadow-sm border-0 p-4 mb-4">
                                <h5 class="fw-bold mb-3 border-bottom pb-2">Latest Activity</h5>
                                <div class="list-group list-group-flush">
                                    {% for thread in latestThreads %}
                                        <a href="{{ path('forum_thread_view', {slug: thread.slug}) }}" class="list-group-item list-group-item-action px-0 py-3 border-0 border-bottom">
                                            <h6 class="small fw-bold mb-1 text-truncate text-success">{{ thread.title }}</h6>
                                            <div class="d-flex justify-content-between x-small text-muted">
                                                <span><i class="fa-regular fa-clock me-1"></i> {{ (thread.updatedAt ?? thread.createdAt)|date('H:i') }}</span>
                                                <span>by {{ thread.author.username }}</span>
                                            </div>
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </aside>
                </div>
            </div>
        </div>
    </section>
{% endblock %}