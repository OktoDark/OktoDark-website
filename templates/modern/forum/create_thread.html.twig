{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'forum.thread.create_title'|trans({}, 'forum') }} — {{ category.name }}{% endblock %}

{% block body %}
    <!-- Hero Section -->
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'forum.thread.create_title'|trans({}, 'forum') }}</h2>
            <p class="lead text-muted mt-2">{{ 'forum.thread.create_subtitle'|trans({}, 'forum') }} <strong>{{ category.name }}</strong></p>
        </div>
    </section>

    <section class="section section-lg bg-default pt-0">
        <div class="container">
            <!-- Breadcrumb -->
            <nav aria-label="breadcrumb" class="mb-5">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('forum') }}" class="text-success">{{ 'forum.title'|trans({}, 'forum') }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('forum_category_view', { slug: category.slug }) }}" class="text-success">{{ category.name }}</a></li>
                    <li class="breadcrumb-item active" aria-current="page">{{ 'forum.category.create_new'|trans({}, 'forum') }}</li>
                </ol>
            </nav>

            <div class="row justify-content-center">
                <div class="col-xl-10">
                    <div class="card shadow-sm border-0 overflow-hidden">
                        <div class="card-body p-4 p-lg-5">
                            
                            {{ form_start(form, { 'enctype': 'multipart/form-data' }) }}
                            
                            {# SURFACING FORM-LEVEL ERRORS #}
                            {{ form_errors(form) }}

                            <div class="row g-4 mb-4">
                                <div class="col-lg-8">
                                    <div class="form-group">
                                        <label class="form-label fw-bold text-dark">{{ 'forum.thread.title_label'|trans({}, 'forum') }}</label>
                                        {{ form_widget(form.title, { attr: { class: 'form-control form-control-lg border-0 bg-light shadow-none', placeholder: 'forum.thread.title_placeholder'|trans({}, 'forum') } }) }}
                                        <div class="small text-muted mt-1">{{ 'forum.thread.title_help'|trans({}, 'forum') }}</div>
                                        {{ form_errors(form.title) }}
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="form-group">
                                        <label class="form-label fw-bold text-dark">{{ 'forum.thread.type_label'|trans({}, 'forum') }}</label>
                                        {{ form_widget(form.type, { attr: { class: 'form-select form-select-lg border-0 bg-light shadow-none', onchange: 'applyTemplate(this.value)' } }) }}
                                    </div>
                                </div>
                            </div>

                            <div class="mb-5">
                                <label class="form-label fw-bold text-dark">{{ 'forum.thread.description_label'|trans({}, 'forum') }}</label>
                                <div class="editor-wrapper rounded border bg-white">
                                    {{ form_widget(form.content) }}
                                </div>
                                {{ form_errors(form.content) }}
                            </div>

                            <!-- Modern Poll Toggle Card -->
                            <div class="card border-0 bg-light bg-opacity-50 mb-5">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-center mb-0">
                                        <div>
                                            <h5 class="fw-bold mb-1"><i class="fa-solid fa-square-poll-vertical text-success me-2"></i>{{ 'forum.poll.create_title'|trans({}, 'forum') }}</h5>
                                            <p class="small text-muted mb-0">{{ 'forum.poll.create_subtitle'|trans({}, 'forum') }}</p>
                                        </div>
                                        <div class="form-check form-switch fs-4">
                                            <input class="form-check-input" type="checkbox" id="togglePoll" onchange="togglePollSection(this.checked)">
                                        </div>
                                    </div>

                                    <div class="mt-4 pt-4 border-top d-none" id="pollSection">
                                        <div class="row g-4">
                                            <div class="col-12">
                                                <label class="form-label fw-bold">{{ 'forum.poll.question_label'|trans({}, 'forum') }}</label>
                                                {{ form_widget(form.poll.question, { attr: { class: 'form-control border-0 shadow-sm', placeholder: 'forum.poll.question_placeholder'|trans({}, 'forum') } }) }}
                                                {{ form_errors(form.poll.question) }}
                                            </div>
                                            
                                            <div class="col-lg-7">
                                                <label class="form-label fw-bold">{{ 'forum.poll.options_label'|trans({}, 'forum') }}</label>
                                                <div id="poll-options-list" 
                                                     data-prototype="{{ form_widget(form.poll.options.vars.prototype)|e('html_attr') }}"
                                                     data-index="{{ form.poll.options|length }}">
                                                    {% for option in form.poll.options %}
                                                        <div class="input-group mb-2 shadow-sm rounded">
                                                            {{ form_widget(option, { attr: { class: 'form-control border-0' } }) }}
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                                <button type="button" class="btn btn-white btn-sm mt-2 border shadow-sm" onclick="addPollOption()">
                                                    <i class="fa-solid fa-plus me-1 text-success"></i> {{ 'forum.poll.add_option'|trans({}, 'forum') }}
                                                </button>
                                            </div>

                                            <div class="col-lg-5">
                                                <label class="form-label fw-bold">{{ 'forum.poll.ends_on'|trans({}, 'forum') }}</label>
                                                {{ form_widget(form.poll.expiresAt, { attr: { class: 'form-control border-0 shadow-sm' } }) }}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center pt-4 border-top">
                                <a href="{{ path('forum_category_view', {slug: category.slug}) }}" class="text-muted text-decoration-none">
                                    <i class="fa-solid fa-arrow-left me-1"></i> {{ 'admin.common.back'|trans({}, 'admin')|replace({'Back': 'Back to Category'}) }}
                                </a>
                                <button class="btn btn-success btn-lg px-5 shadow-sm text-bg-success fw-bold">
                                    {{ 'forum.thread.launch_btn'|trans({}, 'forum') }} <i class="fa-solid fa-paper-plane ms-2"></i>
                                </button>
                            </div>

                            {{ form_end(form) }}

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        var templates = {
            'bug_report': "{{ 'forum.create_thread.template.bug_report'|trans({}, 'forum')|escape('js') }}",
            'feature_request': "{{ 'forum.create_thread.template.feature_request'|trans({}, 'forum')|escape('js') }}",
            'question': "{{ 'forum.create_thread.template.question'|trans({}, 'forum')|escape('js') }}",
            'discussion': ''
        };

        function applyTemplate(type) {
            var editor = document.querySelector('trix-editor').editor;
            if (editor.getDocument().toString().trim() === "" || confirm("{{ 'forum.create_thread.template_confirm'|trans({}, 'forum')|escape('js') }}")) {
                editor.loadHTML(templates[type] || '');
            }
        }

        function togglePollSection(show) {
            var section = document.getElementById('pollSection');
            section.classList.toggle('d-none', !show);
            if(show && document.querySelectorAll('#poll-options-list input').length === 0) {
                addPollOption();
                addPollOption();
            }
        }

        function addPollOption() {
            var list = document.getElementById('poll-options-list');
            var counter = parseInt(list.dataset.index);
            var prototype = list.dataset.prototype;
            var newForm = prototype.replace(/__name__/g, counter);

            var div = document.createElement('div');
            div.className = 'input-group mb-2 shadow-sm rounded overflow-hidden';
            div.innerHTML = newForm + '<button type="button" class="btn btn-white border-start" onclick="this.parentElement.remove()"><i class="fa-solid fa-times text-danger"></i></button>';

            var input = div.querySelector('input');
            if(input) {
                input.classList.add('form-control', 'border-0');
            }

            list.appendChild(div);
            list.dataset.index = counter + 1;
        }
    </script>
{% endblock %}