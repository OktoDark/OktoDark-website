{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'title.login'|trans({}, 'titles') }}{% endblock %}

{% block body_id 'login' %}

{% block body %}

    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.login'|trans({}, 'titles') }}</h2>
            <p class="lead text-muted mt-2">{{ 'content.login_subtitle'|trans({}, 'titles') }}</p>
        </div>
    </section>

    <section class="section section-md bg-default text-center pt-0">
        <div class="container">
            <div class="row justify-content-center">

                <div class="login-modern p-4 p-md-5">

                    <form method="post" action="{{ path('security_login', {'_locale': app.request.locale}) }}">
                        <input type="hidden" name="x_token_98342" value="{{ csrf_token('security_login') }}">

                        {% if error %}
                            <div class="alert alert-danger mb-3">
                                {{ error.messageKey|trans(error.messageData, 'security') }}
                            </div>
                        {% endif %}

                        <fieldset>

                            <div class="form-wrap-modern">
                                <label for="email">{{ 'label.email'|trans|trans({}, 'labels') }}</label>
                                <input type="text" id="email" name="email" value="{{ last_username }}" required autofocus>
                            </div>

                            <div class="form-wrap-modern">
                                <label for="password">{{ 'label.password'|trans({}, 'labels') }}</label>
                                <input type="password" id="password" name="password" required>
                            </div>

                            <div class="remember-modern mb-3">
                                <input type="checkbox" id="remember_me" name="_remember_me">
                                <label for="remember_me">{{ 'checkbox.remember_me'|trans({}, 'login') }}</label>
                            </div>

                            <button class="button button-gradient w-100 py-2" type="submit">
                                <i class="fa fa-sign-in me-2"></i>{{ 'action.sign_in'|trans({}, 'login') }}
                            </button>

                            <div class="mt-3 text-center">
                                <a href="{{ path('app_forgot_password_request') }}" class="text-sm text-gray-400 hover:text-gray-200">
                                    {{ 'action.forgot_password'|trans({}, 'login') }}
                                </a>
                            </div>
                        </fieldset>
                    </form>
                </div>

            </div>

            <div class="mt-4 text-muted small">
                {{ 'content.login_note'|trans({}, 'content')|raw }}
            </div>

        </div>
    </section>

{% endblock %}