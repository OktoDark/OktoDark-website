{% if app.user %}
    <h4 class="fw-bold mb-4">{{ 'blog.leave_comment'|trans({}, 'blog') }}</h4>

    {{ form_start(form, {
        action: path('comment_new', { postSlug: post.slug }),
        method: 'POST'
    }) }}

    <!-- Comment Content -->
    <div class="mb-3">
        {{ form_label(form.content, 'blog.label.content'|trans({}, 'blog'), { label_attr: { class: 'form-label fw-semibold' } }) }}
        <div class="editor-wrapper rounded border bg-white">
            {{ form_widget(form.content, { attr: { style: 'display: none;' } }) }}
            <trix-editor input="{{ form.content.vars.id }}"></trix-editor>
        </div>
        <div class="text-danger small">{{ form_errors(form.content) }}</div>
    </div>

    <!-- Submit -->
    <button class="btn btn-primary px-4">
        <i class="fas fa-paper-plane"></i> {{ 'blog.submit_comment'|trans({}, 'blog') }}
    </button>

    {{ form_end(form) }}

{% else %}
    <div class="alert alert-info">
        {{ 'blog.login_to_comment'|trans({}, 'blog') }}
    </div>
{% endif %}