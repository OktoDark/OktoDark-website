{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.edit_post'|trans({}, 'titles') }} - {{ post.title }}{% endblock %}
{% block body_id %}post_edit{% endblock %}

{% block main %}
    <section class="section section-lg bg-default py-5">
        <div class="container">

            <!-- Page Title + Back Button -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="fw-bold">
                    {{ 'title.edit_post'|trans({}, 'titles') }}: {{ post.title }}
                </h1>

                <a href="{{ path('blog_post', { slug: post.slug }) }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> {{ 'action.back'|trans({}, 'actions') }}
                </a>
            </div>

            <!-- Edit Form Card -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    {{ form_start(form) }}

                    <!-- Title -->
                    <div class="mb-4">
                        {{ form_label(form.title, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.title, { attr: { class: 'form-control form-control-lg' } }) }}
                        <div class="text-danger small">{{ form_errors(form.title) }}</div>
                    </div>

                    <!-- Summary -->
                    <div class="mb-4">
                        {{ form_label(form.summary, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.summary, { attr: { class: 'form-control' } }) }}
                        <div class="text-danger small">{{ form_errors(form.summary) }}</div>
                    </div>

                    <!-- Content -->
                    <div class="mb-4">
                        {{ form_label(form.content, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.content, { attr: { class: 'form-control', rows: 12 } }) }}
                        <div class="text-danger small">{{ form_errors(form.content) }}</div>
                    </div>

                    <!-- Published At -->
                    <div class="mb-4">
                        {{ form_label(form.publishedAt, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.publishedAt, { attr: { class: 'form-control' } }) }}
                        <div class="text-danger small">{{ form_errors(form.publishedAt) }}</div>
                    </div>

                    <!-- Tags -->
                    <div class="mb-4">
                        {{ form_label(form.tags, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                        {{ form_widget(form.tags, { attr: { class: 'form-control' } }) }}
                        <div class="text-danger small">{{ form_errors(form.tags) }}</div>
                    </div>

                    <!-- Submit -->
                    <button class="btn btn-warning btn-lg px-4">
                        <i class="fas fa-edit"></i> {{ 'action.update'|trans({}, 'actions') }}
                    </button>

                    {{ form_end(form) }}

                </div>
            </div>

        </div>
    </section>
{% endblock %}