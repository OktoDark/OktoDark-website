{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'navbar.blog'|trans }} - {{ post.title }}{% endblock %}
{% block body_id %}post_show{% endblock %}

{% block main %}
    <section class="section section-lg bg-default py-5">
        <div class="container">
            <div class="row g-5">

                <!-- Main Content -->
                <div class="col-lg-8 col-xl-9">

                    <!-- Post Header -->
                    <article class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">

                            <!-- Title -->
                            <h1 class="fw-bold mb-3">{{ post.title }}</h1>

                            <!-- Meta -->
                            <div class="d-flex flex-wrap gap-4 text-muted small mb-4">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="far fa-clock"></i>
                                    <time datetime="{{ post.publishedAt|date('c') }}">
                                        {{ post.publishedAt|format_datetime('long', 'medium') }}
                                    </time>
                                </div>

                                <div class="d-flex align-items-center gap-2">
                                    <i class="far fa-user"></i>
                                    {{ post.author.firstName }}
                                </div>
                            </div>

                            <!-- Admin Buttons -->
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="d-flex gap-2 mb-4">
                                    <a href="{{ path('blog_edit', { slug: post.slug }) }}"
                                       class="btn btn-warning btn-sm">
                                        <i class="fas fa-edit"></i> {{ 'action.edit'|trans({}, 'actions') }}
                                    </a>

                                    <a href="{{ path('blog_delete', { slug: post.slug }) }}"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('{{ 'action.confirm_delete'|trans({}, 'actions') }}');">
                                        <i class="fas fa-trash"></i> {{ 'action.delete'|trans({}, 'actions') }}
                                    </a>
                                </div>
                            {% endif %}

                            <!-- Content -->
                            <div class="post-body mb-4">
                                {{ post.content|markdown_to_html|sanitize_html }}
                            </div>

                            <!-- Share -->
                            <div class="mt-4">
                                <h5 class="fw-semibold mb-3">{{ 'post.share'|trans({}, 'blog') }}</h5>
                                <div class="d-flex gap-3">

                                    <a class="btn btn-primary btn-sm"
                                       target="_blank"
                                       href="https://www.facebook.com/sharer/sharer.php?u={{ app.request.schemeAndHttpHost }}{{ path('blog_post', {slug: post.slug}) }}">
                                        <i class="fab fa-facebook-square"></i> Facebook
                                    </a>

                                    <a class="btn btn-info btn-sm text-white"
                                       target="_blank"
                                       href="https://twitter.com/share?url={{ app.request.schemeAndHttpHost }}{{ path('blog_post', {slug: post.slug}) }}">
                                        <i class="fab fa-twitter-square"></i> Twitter
                                    </a>

                                </div>
                            </div>

                        </div>
                    </article>

                    <!-- Comments -->
                    <div class="card shadow-sm border-0 mb-4">
                        <div class="card-body p-4">

                            <h3 class="fw-bold mb-4">
                                {{ post.comments|length }} {{ 'post.comments'|trans({}, 'blog') }}
                            </h3>

                            {% for comment in post.comments %}
                                <div class="d-flex gap-3 mb-4">
                                    <img src="{{ asset('images/default-avatar.png') }}"
                                         class="rounded-circle"
                                         width="64" height="64"
                                         alt="avatar">

                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between">
                                            <strong>{{ comment.author.fullName }}</strong>
                                            <small class="text-muted">
                                                <i class="far fa-clock"></i>
                                                {{ comment.publishedAt|format_datetime('long', 'medium') }}
                                            </small>
                                        </div>

                                        <div class="mt-2">
                                            {{ comment.content|markdown_to_html|sanitize_html }}
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-muted">{{ 'post.no_comments'|trans({}, 'blog') }}</p>
                            {% endfor %}

                        </div>
                    </div>

                    <!-- Comment Form -->
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            {{ render(controller('App\\Controller\\BlogController::commentForm', { id: post.id })) }}
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </section>
{% endblock %}