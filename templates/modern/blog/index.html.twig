{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'blog.title'|trans({}, 'blog') }}{% endblock %}

{% block body_id 'blog' %}

{% block main %}

    <!-- Hero -->
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'blog.title'|trans({}, 'blog') }}</h2>
            <p class="lead text-muted mt-2">{{ 'blog.subtitle'|trans({}, 'blog') }}</p>
        </div>
    </section>

    <!-- Blog Content -->
    <section class="section section-lg bg-default pt-0">
        <div class="container">
            <div class="row g-5">

                <!-- Main Column -->
                <div class="col-lg-8 col-xl-9">

                    {% for post in paginator.results %}
                        <article class="blog-card">

                            <!-- Author Header -->
                            <header class="blog-card-header">
                                {% if post.author.avatarUrl %}
                                    <img src="{{ post.author.avatarUrl }}"
                                         alt="{{ post.author.firstName }}"
                                         class="blog-avatar">
                                {% else %}
                                    <div class="blog-avatar-fallback">
                                        <i class="fa-solid fa-user"></i>
                                    </div>
                                {% endif %}

                                <div>
                                    <h5 class="mb-0 fw-semibold">{{ post.author.firstName }}</h5>
                                    <small class="text-muted">{{ 'blog.role_blogger'|trans({}, 'blog') }}</small>
                                </div>
                            </header>

                            <!-- Body -->
                            <div class="blog-card-body">

                                <!-- Meta -->
                                <div class="blog-meta">
                                    <div>
                                        <span class="far fa-clock"></span>
                                        {{ post.publishedAt|format_datetime('long', 'medium') }}
                                    </div>

                                    <div>
                                        <span class="far fa-comments"></span>
                                        {{ post.comments|length }} {{ 'blog.comments_count'|trans({}, 'blog') }}
                                    </div>
                                </div>

                                <!-- Title -->
                                <h2 class="blog-title">
                                    <a href="{{ path('blog_post', { slug: post.slug }) }}">
                                        {{ post.title }}
                                    </a>
                                </h2>

                                <!-- Summary -->
                                <p class="blog-summary">{{ post.summary }}</p>

                                <!-- Buttons -->
                                <div class="blog-actions">
                                    <a class="btn btn-success text-bg-success"
                                       href="{{ path('blog_post', { slug: post.slug }) }}">
                                        {{ 'common.read_more'|trans({}, 'common') }}
                                    </a>

                                    {% if is_granted('ROLE_ADMIN') %}
                                        <a href="{{ path('blog_edit', { slug: post.slug }) }}"
                                           class="btn btn-warning text-bg-warning btn-sm">
                                            <i class="fas fa-edit"></i> {{ 'common.edit'|trans({}, 'common') }}
                                        </a>

                                        <a href="{{ path('blog_delete', { slug: post.slug }) }}"
                                           class="btn btn-danger text-bg-danger btn-sm"
                                           onclick="return confirm('{{ 'common.confirm_delete'|trans({}, 'common') }}');">
                                            <i class="fas fa-trash"></i> {{ 'common.delete'|trans({}, 'common') }}
                                        </a>
                                    {% endif %}
                                </div>

                            </div>
                        </article>

                    {% else %}
                        <div class="alert alert-info text-center">
                            {{ 'blog.no_posts_found'|trans({}, 'blog') }}
                        </div>
                    {% endfor %}

                    <!-- Pagination -->
                    {% if paginator.hasToPaginate %}
                        <nav aria-label="{{ 'blog.pagination_label'|trans({}, 'blog') }}" class="mt-4">
                            <ul class="pagination justify-content-center">

                                <li class="page-item {{ not paginator.hasPreviousPage ? 'disabled' }}">
                                    <a class="page-link"
                                       href="{{ paginator.hasPreviousPage
                                       ? path('blog_index_paginated', { page: paginator.previousPage, tag: tagName })
                                       : '#' }}">
                                        <span class="fas fa-chevron-left"></span>
                                    </a>
                                </li>

                                {% for i in 1..paginator.lastPage %}
                                    <li class="page-item {{ i == paginator.currentPage ? 'active' }}">
                                        <a class="page-link"
                                           href="{{ path('blog_index_paginated', { page: i, tag: tagName }) }}">
                                            {{ i }}
                                        </a>
                                    </li>
                                {% endfor %}

                                <li class="page-item {{ not paginator.hasNextPage ? 'disabled' }}">
                                    <a class="page-link"
                                       href="{{ paginator.hasNextPage
                                       ? path('blog_index_paginated', { page: paginator.nextPage, tag: tagName })
                                       : '#' }}">
                                        <span class="fas fa-chevron-right"></span>
                                    </a>
                                </li>

                            </ul>
                        </nav>
                    {% endif %}

                </div>

                <!-- Sidebar -->
                <div class="col-lg-4 col-xl-3">
                    <aside class="aside-components">

                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="text-end mb-4">
                                <a href="{{ path('blog_new') }}" class="btn btn-success text-bg-success">
                                    <i class="fas fa-plus"></i> {{ 'blog.new_post'|trans({}, 'blog') }}
                                </a>
                            </div>
                        {% endif %}

                        <div class="aside-component card shadow-sm border-0 p-4 mb-4">
                            <h4 class="component-title mb-3">{{ 'blog.search'|trans({}, 'blog') }}</h4>

                            <form action="{{ path('blog_search') }}" method="get">
                                <div class="input-group">
                                    <input class="form-control" name="q" type="text"
                                           placeholder="{{ 'blog.search_placeholder'|trans({}, 'blog') }}">
                                    <button class="btn btn-primary" type="submit">
                                        <i class="bi bi-search"></i>
                                    </button>
                                </div>
                            </form>
                        </div>

                    </aside>
                </div>

            </div>
        </div>
    </section>

{% endblock %}