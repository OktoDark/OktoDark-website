<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ settings.getSiteName() }} – Confirm Your Email</title>
</head>
<body style="font-family: Arial, sans-serif; background: #f7f7f7; padding: 40px;">

<table width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; margin: auto; background: #ffffff; border-radius: 8px; padding: 30px;">
    <tr>
        <td style="text-align: center;">
            <h1 style="margin-bottom: 10px; font-size: 26px; color: #333;">
                {{ 'email.verify.title'|trans({}, 'emails') }}
            </h1>

            <p style="color: #666; font-size: 15px; margin-bottom: 25px;">
                {{ 'email.verify.intro'|trans({}, 'emails') }}
            </p>

            <a href="{{ signedUrl|raw }}"
               style="display: inline-block; background: linear-gradient(90deg, #6a11cb, #2575fc); 
                          color: #fff; padding: 14px 28px; border-radius: 6px; 
                          text-decoration: none; font-weight: bold; font-size: 16px;">
                {{ 'email.verify.button'|trans({}, 'emails') }}
            </a>

            <p style="margin-top: 25px; color: #999; font-size: 13px;">
                {{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}
            </p>

            <p style="margin-top: 30px; color: #444; font-size: 14px;">
                {{ 'email.verify.footer'|trans({}, 'emails') }}<br>
                <strong>{{ settings.getSiteName() }}</strong>
            </p>
        </td>
    </tr>
</table>

</body>
</html>