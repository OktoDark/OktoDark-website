{% extends '@theme/base.html.twig' %}

{% block title %}
    {{ 'title.email_verified'|trans({}, 'titles') }} – {{ settings.getSiteName() }}
{% endblock %}

{% block body %}
    <section class="section section-md">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6 text-center">

                    <h1 class="mb-3 text-success">
                        {{ 'title.email_verified'|trans({}, 'titles') }}
                    </h1>

                    <p class="text-muted mb-4">
                        {{ 'text.email_verified_intro'|trans({}, 'messages') }}
                    </p>

                    <a href="{{ path('app_complete_profile') }}" class="button button-gradient w-100">
                        {{ 'title.complete_profile'|trans({}, 'titles') }}
                    </a>

                </div>
            </div>
        </div>
    </section>

    <section>
        <div class="progress-wrapper">
            {% include '@theme/registration/_progress.html.twig' with { current_step: 2 } %}
        </div>
    </section>
{% endblock %}