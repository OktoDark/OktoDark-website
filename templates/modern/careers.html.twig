{% extends "@theme/base.html.twig" %}

{% block title %}{{ 'title.careers'|trans({}, 'careers') }}{% endblock %}

{% block body_id 'careers' %}

{% block main %}

    <!-- Page Title -->
    <section class="section section-page-title context-dark text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'title.careers'|trans({}, 'careers') }}</h2>
            <p class="lead text-muted mt-2">{{ 'careers.text_1'|trans({}, 'careers') }}</p>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="section section-lg bg-gray-100">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <ul class="modern-list">
                        {{ 'careers.description'|trans({}, 'careers')|raw }}
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- Careers Accordion -->
    <section class="section section-lg bg-default">
        <div class="container">
            <div class="accordion modern-accordion" id="accordion1">

                {% for c in careers %}
                    <div class="accordion-item shadow-sm mb-3 rounded-3 overflow-hidden">

                        <h2 class="accordion-header" id="heading{{ c.id }}">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapse{{ c.id }}"
                                    aria-expanded="false"
                                    aria-controls="collapse{{ c.id }}">
                                <strong>{{ c.jobTitle }}</strong>
                                <span class="badge bg-gradient ms-3">
                                    {{ 'careers.available'|trans({}, 'careers') }}: {{ c.number }}
                                </span>
                                {% if c.publishedAt %}
                                    <span class="small text-light ms-3">{{ 'careers.published'|trans({}, 'careers') }}: {{ c.publishedAt|date('M d, Y') }}</span>
                                {% endif %}
                            </button>
                        </h2>

                        <div id="collapse{{ c.id }}"
                             class="accordion-collapse collapse"
                             aria-labelledby="heading{{ c.id }}"
                             data-bs-parent="#accordion1">

                            <div class="accordion-body">
                                <div class="row">
                                    <div class="col-lg-6 mb-4 mb-lg-0">
                                        <h5 class="mb-3 text-light">{{ 'careers.requirements'|trans({}, 'careers') }}:</h5>
                                        <div class="d-flex flex-wrap gap-2 mb-4">
                                            {% if c.requirements is iterable and c.requirements is not empty %}
                                                {% for req in c.requirements %}
                                                    <span class="badge bg-info text-dark px-3 py-2">{{ req }}</span>
                                                {% endfor %}
                                            {% else %}
                                                <span class="text-muted italic">{{ 'careers.no_requirements'|trans({}, 'careers') }}</span>
                                            {% endif %}
                                        </div>

                                        <h5 class="mb-3 text-light">{{ 'careers.description_title'|trans({}, 'careers') }}</h5>
                                        <div class="career-description">
                                            {{ c.description|raw }}
                                        </div>
                                    </div>
                                    <div class="col-lg-6">
                                        <div class="card border-0 bg-light p-4">
                                            <h5 class="mb-3">{{ 'careers.apply_title'|trans({}, 'careers') }}</h5>
                                            <form action="{{ path('careers') }}" method="post" enctype="multipart/form-data">
                                                <input type="hidden" name="job_title" value="{{ c.jobTitle }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('career_apply') }}">
                                                
                                                <div class="mb-3">
                                                    <input class="form-control" type="text" name="name" placeholder="{{ 'label.fullname'|trans({}, 'profile')|default('Full Name') }}" required>
                                                </div>
                                                <div class="mb-3">
                                                    <input class="form-control" type="email" name="email" placeholder="{{ 'label.email'|trans({}, 'profile') }}" required>
                                                </div>
                                                <div class="mb-3">
                                                    <label class="form-label small">{{ 'careers.upload_cv'|trans({}, 'careers') }}</label>
                                                    <input class="form-control" type="file" name="cv" accept=".pdf,.doc,.docx" required>
                                                </div>
                                                <div class="mb-3">
                                                    <textarea class="form-control" name="message" rows="4" placeholder="{{ 'careers.tell_us'|trans({}, 'careers') }}" required></textarea>
                                                </div>
                                                <button class="button button-sm bg-info text-bg-info w-100" type="submit">
                                                    {{ 'careers.submit'|trans({}, 'careers') }}
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                {% endfor %}

            </div>
        </div>
    </section>

{% endblock %}