{% extends '@theme/base.html.twig' %}

{% block title %}Media Tracker – Import Trakt{% endblock %}
{% block head %}{{ parent() }}{% endblock %}
{% block body_id %}tracker{% endblock %}

{% block main %}
    <section class="section section-page-title bg-default text-center py-4">
        <div class="container">
            <h2 class="display-6 fw-bold">Import Trakt Data</h2>
            <p class="lead text-muted mt-2">Upload your Trakt export to import your media</p>
        </div>
    </section>

    <section class="section section-lg">
        <div class="container-fluid px-4">

            <!-- CENTER EVERYTHING -->
            <div class="d-flex justify-content-center">
                <div class="row w-100 justify-content-center">

                    <!-- SIDEBAR -->
                    {% include '@theme/tracker/partials/_sidebar.html.twig' %}

                    <!-- MAIN CONTENT -->
                    <div class="col-md-9">

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h3 class="h5 mb-0">Import Trakt Data</h3>
                                <small class="text-muted">Upload your Trakt JSON or CSV export</small>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-4">
                                <form method="post" action="{{ path('app_import_trakt') }}" enctype="multipart/form-data">
                                    <div class="mb-3">
                                        <label class="form-label">Upload Trakt JSON or CSV</label>
                                        <input type="file" name="trakt_file" class="form-control" required>
                                    </div>

                                    <button class="btn btn-primary">Import</button>
                                </form>

                                {% for message in app.flashes('success') %}
                                    <div class="alert alert-success mt-3">{{ message }}</div>
                                {% endfor %}

                                {% for message in app.flashes('error') %}
                                    <div class="alert alert-danger mt-3">{{ message }}</div>
                                {% endfor %}
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>

    {% block javascripts %}
        {{ parent() }}
    {% endblock %}
{% endblock %}
