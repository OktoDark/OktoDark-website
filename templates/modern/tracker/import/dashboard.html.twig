{% extends '@theme/base.html.twig' %}

{% block title %}Import Dashboard{% endblock %}
{% block head %}{{ parent() }}{% endblock %}
{% block body_id %}tracker{% endblock %}

{% block main %}

    <!-- PAGE TITLE -->
    <section class="section section-page-title bg-default text-center py-4">
        <div class="container">
            <h2 class="display-6 fw-bold">Import Dashboard</h2>
            <p class="lead text-muted mt-2">Choose an import source to get started</p>
        </div>
    </section>

    <section class="section section-lg">
        <div class="container-fluid px-4">
            <div class="row justify-content-center">

                <!-- SIDEBAR -->
                {% include '@theme/tracker/partials/_sidebar.html.twig' %}

                <!-- MAIN CONTENT -->
                <div class="col-md-9">

                    <!-- FLASH MESSAGES -->
                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-dismissible alert-{{ type }} fade show mb-4" role="alert">
                                {{ message|trans }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <!-- IMPORT CARDS -->
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <h5 class="fw-bold mb-3">Import TV</h5>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">TV Time</h6>
                                    <p class="card-text text-muted small">
                                        Upload TV Time CSV exports (tracking-prod-records*.csv).
                                    </p>
                                    <a href="{{ path('app_import_tv_source', { source: 'tvtime' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import TV Time
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Trakt</h6>
                                    <p class="card-text text-muted small">
                                        Upload Trakt JSON or CSV exports.
                                    </p>
                                    <a href="{{ path('app_import_tv_source', { source: 'trakt' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import Trakt
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Simkl</h6>
                                    <p class="card-text text-muted small">
                                        Upload Simkl JSON exports.
                                    </p>
                                    <a href="{{ path('app_import_tv_source', { source: 'simkl' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import Simkl
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Generic CSV / JSON</h6>
                                    <p class="card-text text-muted small">
                                        Upload a custom CSV or JSON with title, season, episode columns.
                                    </p>
                                    <a href="{{ path('app_import_tv_source', { source: 'generic' }) }}"
                                       class="btn btn-outline-primary mt-auto align-self-start">
                                        Import Generic
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <h5 class="fw-bold mb-3">Import Movies</h5>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">TV Time</h6>
                                    <p class="card-text text-muted small">
                                        Upload TV Time CSV exports for movies.
                                    </p>
                                    <a href="{{ path('app_import_movies_source', { source: 'tvtime' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import TV Time
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Trakt</h6>
                                    <p class="card-text text-muted small">
                                        Upload Trakt JSON or CSV exports for movies.
                                    </p>
                                    <a href="{{ path('app_import_movies_source', { source: 'trakt' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import Trakt
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Letterboxd</h6>
                                    <p class="card-text text-muted small">
                                        Upload Letterboxd CSV export for movies.
                                    </p>
                                    <a href="{{ path('app_import_movies_source', { source: 'letterboxd' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import Letterboxd
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Simkl</h6>
                                    <p class="card-text text-muted small">
                                        Upload Simkl JSON exports for movies.
                                    </p>
                                    <a href="{{ path('app_import_movies_source', { source: 'simkl' }) }}"
                                       class="btn btn-primary text-bg-primary mt-auto align-self-start">
                                        Import Simkl
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h6 class="card-title fw-bold">Generic CSV / JSON</h6>
                                    <p class="card-text text-muted small">
                                        Upload a custom CSV or JSON with title, year, watched_at columns.
                                    </p>
                                    <a href="{{ path('app_import_movies_source', { source: 'generic' }) }}"
                                       class="btn btn-outline-primary mt-auto align-self-start">
                                        Import Generic
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- DATA MANAGEMENT CARDS -->
                    <div class="row g-3">
                        <!-- EXPORT DATA -->
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold">Export Data</h5>
                                    <p class="card-text text-muted small">
                                        Download all your tracker data as a JSON file for backup or migration purposes.
                                    </p>
                                    <a href="{{ path('app_tracker_data_export') }}"
                                       class="btn btn-outline-primary mt-auto align-self-start">
                                        Export All Data
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- CLEAN DATABASE -->
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm border-danger">
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title fw-bold text-danger">Clean Database</h5>
                                    <div class="alert alert-danger py-2 px-3 small mb-3" role="alert">
                                        <strong>Warning:</strong> This will permanently delete all your tracker data including TV shows, movies, anime, games, manga, comics, books, and board games. This action cannot be undone.
                                    </div>
                                    <form method="post" action="{{ path('app_tracker_data_clean') }}" class="mt-auto"
                                          onsubmit="return confirm('Are you absolutely sure? This will destroy ALL your tracker data and cannot be undone.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('tracker_clean') }}">
                                        <button type="submit" class="btn btn-danger">
                                            Delete All My Data
                                        </button>
                                    </form>
                                    {% if app.flashes('success') %}
                                        <div class="alert alert-success py-2 px-3 small mt-3 mb-0" role="alert">
                                            Your tracker data has been erased successfully.
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

    {% block javascripts %}
        {{ parent() }}
    {% endblock %}

{% endblock %}
