{% extends '@theme/base.html.twig' %}

{% block title %}{{ series.mediaMetadata.title }} – Series{% endblock %}

{% block main %}
    <section class="section section-lg">
        <div class="container">

            <div class="d-flex align-items-center mb-4">
                <img src="{{ series.mediaMetadata.image }}" class="rounded me-3" style="width:120px;" alt="image">
                <div>
                    <h2 class="fw-bold">{{ series.mediaMetadata.title }}</h2>
                    <p class="text-muted">{{ series.mediaMetadata.overview }}</p>
                </div>
            </div>

            <h4 class="fw-bold mb-3">Seasons</h4>

            <div class="row">
                {% for season in seasons %}
                    <div class="col-md-3 mb-4">
                        <a href="{{ path('app_tracker_season', {id: season.id}) }}"
                           class="card shadow-sm border-0 h-100 text-decoration-none text-light">
                            <div class="card-body">
                                <h5 class="card-title">Season {{ season.mediaMetadata.seasonNumber }}</h5>
                                <p class="small text-muted">
                                    {{ season.getWatchedEpisodes() }} / {{ season.getTotalEpisodes() }} episodes
                                </p>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>

        </div>
    </section>
{% endblock %}
