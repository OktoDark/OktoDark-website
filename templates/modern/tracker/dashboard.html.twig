{% extends '@theme/base.html.twig' %}

{% block title %}Media Tracker – TV Seasons{% endblock %}
{% block head %}{{ parent() }}{% endblock %}
{% block body_id 'tracker' %}

{% block main %}

    <section class="section section-page-title bg-default text-center py-4">
        <div class="container">
            <h2 class="display-6 fw-bold">TV Seasons</h2>
            <p class="lead text-muted mt-2">Track your progress across all seasons</p>
        </div>
    </section>

    <section class="section section-lg pt-0">
        <div class="container-fluid px-4">
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3 mb-4">
                {% include '@theme/tracker/components/stats_cards.html.twig' %}
            </div>
        </div>
    </section>

    <section class="section section-lg">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-center">
                <div class="row w-100 justify-content-center">

                    <!-- SIDEBAR -->
                    {% include '@theme/tracker/partials/_sidebar.html.twig' %}

                    <!-- MAIN CONTENT -->
                    <div class="col-md-9">

                        <style>
                            .fade-soft {
                                opacity: 0;
                                transition: opacity 0.35s ease-in-out;
                            }
                            .fade-soft.show {
                                opacity: 1;
                            }
                        </style>

                        {% include '@theme/tracker/components/continue_watching.html.twig' %}

                        {% if animeList is not empty %}
                            <div class="card mb-4 shadow-sm border-0">
                                <div class="card-header fw-semibold">My Anime</div>
                                <div class="card-body">
                                    <div id="anime-grid" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-7 g-3">

                                        {% for anime in animeList %}
                                            {% if loop.index > 7 %}
                                                <div class="col anime-extra" style="display: none;">
                                            {% else %}
                                                <div class="col">
                                            {% endif %}

                                                    <div class="card h-100 border-0 shadow-sm">
                                                        {% if anime.coverUrl %}
                                                            <img src="{{ anime.coverUrl }}" class="card-img-top" alt="{{ anime.title }}" style="aspect-ratio: 2 / 3; object-fit: cover;">
                                                        {% else %}
                                                            <div class="bg-secondary d-flex align-items-center justify-content-center" style="aspect-ratio: 2 / 3;">
                                                                <span class="text-white-50 small">No Image</span>
                                                            </div>
                                                        {% endif %}

                                                        <div class="card-body p-2">
                                                            <h6 class="card-title text-truncate mb-1">{{ anime.title }}</h6>

                                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                                <span class="badge {{ anime.statusClass }}">{{ anime.statusLabel|capitalize }}</span>
                                                                <span class="text-muted small">{{ anime.score ?: '—' }}/10</span>
                                                            </div>

                                                            <div class="text-muted small">
                                                                {% if anime.releaseDate %}
                                                                    {{ anime.releaseDate|date('Y') }}
                                                                {% else %}
                                                                    —
                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                        {% endfor %}

                                    </div>

                                    {% if animeList|length > 7 %}
                                        <div class="text-center mt-3">
                                            <button id="anime-show-more" class="btn btn-outline-primary btn-sm">
                                                Show More ({{ animeList|length - 7 }})
                                            </button>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% else %}
                            <div class="card mb-4 shadow-sm border-0">
                                <div class="card-header fw-semibold">My Anime</div>
                                <div class="card-body">
                                    <p class="text-muted small">No anime in your list yet.</p>
                                </div>
                            </div>
                        {% endif %}

                        {% include '@theme/tracker/components/next_episode.html.twig' %}
                        {% include '@theme/tracker/components/recent_watched.html.twig' %}
                        {% include '@theme/tracker/components/seasons_filters.html.twig' %}
                        {% include '@theme/tracker/components/seasons_grid.html.twig' %}
                        {% include '@theme/tracker/components/pagination.html.twig' %}

                    </div>
                </div>
            </div>
        </div>
    </section>

    {% block javascripts %}
        {{ parent() }}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const items = [...document.querySelectorAll('.cw-item')];
                const showMoreTile = document.querySelector('.cw-show-more-tile');
                const grid = document.getElementById('cw-grid');

                let page = 0;
                const perPage = 7;

                function renderPage(slideDirection = 0) {
                    items.forEach((item, index) => {
                        item.classList.add('cw-hidden');
                        if (index >= page * perPage && index < (page + 1) * perPage) {
                            item.classList.remove('cw-hidden');
                        }
                    });

                    const hasMore = (page + 1) * perPage < items.length;
                    showMoreTile.classList.toggle('cw-hidden', !hasMore);

                    // Slide animation
                    grid.style.transform = `translateX(${slideDirection * -20}px)`;
                    setTimeout(() => {
                        grid.style.transform = `translateX(0px)`;
                    }, 10);
                }

                document.getElementById('cw-prev').addEventListener('click', () => {
                    if (page > 0) {
                        page--;
                        renderPage(-1);
                    }
                });

                document.getElementById('cw-next').addEventListener('click', () => {
                    const maxPage = Math.floor(items.length / perPage);
                    if (page < maxPage) {
                        page++;
                        renderPage(1);
                    }
                });

                showMoreTile.addEventListener('click', () => {
                    page++;
                    renderPage(1);
                    grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                });

                renderPage();
            });
        </script>
        <script>
            let touchStartX = 0;

            grid.addEventListener('touchstart', (e) => {
                touchStartX = e.changedTouches[0].screenX;
            });

            grid.addEventListener('touchend', (e) => {
                const touchEndX = e.changedTouches[0].screenX;
                const diff = touchEndX - touchStartX;

                if (Math.abs(diff) > 50) {
                    if (diff < 0) {
                        document.getElementById('cw-next').click();
                    } else {
                        document.getElementById('cw-prev').click();
                    }
                }
            });
        </script>


        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const items = [...document.querySelectorAll('.cw-item')];
                const showMoreTile = document.querySelector('.cw-show-more-tile');
                const grid = document.getElementById('cw-grid');

                let page = 0;
                const perPage = 7;

                function renderPage() {
                    items.forEach((item, index) => {
                        item.classList.add('cw-hidden');
                        if (index >= page * perPage && index < (page + 1) * perPage) {
                            item.classList.remove('cw-hidden');
                        }
                    });

                    // Show More tile only if more items exist
                    const hasMore = (page + 1) * perPage < items.length;
                    showMoreTile.classList.toggle('cw-hidden', !hasMore);

                    grid.classList.remove('show');
                    setTimeout(() => grid.classList.add('show'), 10);
                }

                document.getElementById('cw-prev').addEventListener('click', () => {
                    if (page > 0) {
                        page--;
                        renderPage();
                    }
                });

                document.getElementById('cw-next').addEventListener('click', () => {
                    const maxPage = Math.floor(items.length / perPage);
                    if (page < maxPage) {
                        page++;
                        renderPage();
                    }
                });

                showMoreTile.addEventListener('click', () => {
                    page++;
                    renderPage();
                });

                renderPage();
            });
        </script>

        <script>
        document.addEventListener('DOMContentLoaded', () => {

            const grid = document.getElementById('cw-grid');
            const pagination = document.getElementById('cw-pagination');

            async function loadContinueWatchingPage(page) {
                const url = new URL(window.location.href);
                url.searchParams.set('cwPage', page);

                const response = await fetch(url);
                const html = await response.text();

                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                const newGrid = doc.querySelector('#cw-grid');
                const newPagination = doc.querySelector('#cw-pagination');

                if (newGrid && grid) {
                    grid.innerHTML = newGrid.innerHTML;
                }

                if (newPagination && pagination) {
                    pagination.innerHTML = newPagination.innerHTML;
                }

                attachEvents();

                if (grid) grid.classList.add('show');
                if (pagination) pagination.classList.add('show');
            }

            async function refreshContinueWatching() {
                const url = new URL(window.location.href);
                const cwPage = url.searchParams.get('cwPage') || 1;
                await loadContinueWatchingPage(cwPage);
            }

            function attachEvents() {
                // mark episode watched (auto-advance)
                document.querySelectorAll('.cw-mark-watched').forEach(btn => {
                    btn.addEventListener('click', async () => {
                        const id = btn.dataset.id;
                        const season = btn.dataset.season;
                        const episode = btn.dataset.episode;

                        btn.disabled = true;
                        btn.innerText = 'Updating...';

                        await fetch('{{ path("app_mark_episode_watched") }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ id, season, episode })
                        });

                        if (grid) grid.classList.remove('show');
                        if (pagination) pagination.classList.remove('show');

                        await refreshContinueWatching();

                        const updatedCard = document.querySelector('[data-id="' + id + '"]');
                        if (updatedCard) {
                            updatedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    });
                });

                // mark entire season watched
                document.querySelectorAll('.cw-mark-season').forEach(btn => {
                    btn.addEventListener('click', async () => {
                        const id = btn.dataset.id;
                        const season = btn.dataset.season;

                        btn.disabled = true;
                        btn.innerText = 'Marking...';

                        await fetch('{{ path("app_mark_season_watched") }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ id, season })
                        });

                        if (grid) grid.classList.remove('show');
                        if (pagination) pagination.classList.remove('show');

                        await refreshContinueWatching();

                        const updatedCard = document.querySelector('[data-id="' + id + '"]');
                        if (updatedCard) {
                            updatedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    });
                });

                // undo watched
                document.querySelectorAll('.cw-undo-watched').forEach(btn => {
                    btn.addEventListener('click', async () => {
                        const id = btn.dataset.id;

                        btn.disabled = true;
                        btn.innerText = 'Reverting...';

                        await fetch('{{ path("app_undo_episode_watched") }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: new URLSearchParams({ id })
                        });

                        if (grid) grid.classList.remove('show');
                        if (pagination) pagination.classList.remove('show');

                        await refreshContinueWatching();

                        const updatedCard = document.querySelector('[data-id="' + id + '"]');
                        if (updatedCard) {
                            updatedCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        }
                    });
                });

                // pagination
                document.querySelectorAll('.cw-nav').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        const page = parseInt(btn.dataset.page);
                        if (page && page > 0) {
                            loadContinueWatchingPage(page);
                        }
                    });
                });
            }

            if (grid) grid.classList.add('show');
            if (pagination) pagination.classList.add('show');
            attachEvents();

            // Show More / Show Less for Anime
            const animeBtn = document.getElementById('anime-show-more');
            if (animeBtn) {
                animeBtn.addEventListener('click', () => {
                    const extras = document.querySelectorAll('.anime-extra');
                    const isHidden = extras[0] && extras[0].style.display === 'none';

                    extras.forEach(el => {
                        el.style.display = isHidden ? '' : 'none';
                    });

                    animeBtn.innerText = isHidden
                        ? 'Show Less'
                        : 'Show More (' + extras.length + ')';
                });
            }
        });
    </script>

        <script>
            (function() {
                // Sync active filter buttons with URL parameters on page load
                var urlParams = {};
                var query = window.location.search.substring(1);
                if (query) {
                    var pairs = query.split('&');
                    for (var i = 0; i < pairs.length; i++) {
                        var pair = pairs[i].split('=');
                        urlParams[decodeURIComponent(pair[0])] = decodeURIComponent(pair[1] || '');
                    }
                }
                var statusParam = urlParams['status'] || 'all';

                // Update sidebar filter active states
                var sidebarItems = document.querySelectorAll('.list-group-item-action[data-filter]');
                for (var j = 0; j < sidebarItems.length; j++) {
                    var sidebarBtn = sidebarItems[j];
                    var filter = sidebarBtn.getAttribute('data-filter');
                    if (filter === statusParam) {
                        sidebarBtn.classList.add('active');
                    } else {
                        sidebarBtn.classList.remove('active');
                    }
                }

                // Update top filter button active states
                var topButtons = document.querySelectorAll('.btn-group .btn[data-filter]');
                for (var k = 0; k < topButtons.length; k++) {
                    var topBtn = topButtons[k];
                    var filter = topBtn.getAttribute('data-filter');
                    if (filter === statusParam) {
                        topBtn.classList.remove('btn-outline-secondary');
                        topBtn.classList.add('btn-primary');
                    } else {
                        topBtn.classList.remove('btn-primary');
                        topBtn.classList.add('btn-outline-secondary');
                    }
                }
            })();
        </script>

    {% endblock %}
{% endblock %}
