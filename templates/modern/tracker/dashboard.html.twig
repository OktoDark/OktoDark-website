{% extends '@theme/base.html.twig' %}

{% block title %}Media Tracker – TV Seasons{% endblock %}
{% block head %}{{ parent() }}{% endblock %}
{% block body_id 'tracker' %}

{% block main %}

    <section class="section section-page-title bg-default text-center py-4">
        <div class="container">
            <h2 class="display-6 fw-bold">TV Seasons</h2>
            <p class="lead text-muted mt-2">Track your progress across all seasons</p>
        </div>
    </section>

    <section class="section section-lg pt-0">
        <div class="container-fluid px-4">
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3 mb-4">
                {% include '@theme/tracker/components/stats_cards.html.twig' %}
            </div>
        </div>
    </section>

    <section class="section section-lg">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-center">
                <div class="row w-100 justify-content-center">

                    <!-- SIDEBAR -->
                    {% include '@theme/tracker/partials/_sidebar.html.twig' %}

                    <!-- MAIN CONTENT -->
                    <div class="col-md-9">

                        <style>
                            .fade-soft {
                                opacity: 0;
                                transition: opacity 0.35s ease-in-out;
                            }
                            .fade-soft.show {
                                opacity: 1;
                            }
                        </style>

                        {% include '@theme/tracker/components/continue_watching.html.twig' %}

                        {% include '@theme/tracker/components/next_episode.html.twig' %}
                        {% include '@theme/tracker/components/recent_watched.html.twig' %}
                        {% include '@theme/tracker/components/seasons_filters.html.twig' %}
                        {% include '@theme/tracker/components/seasons_grid.html.twig' %}
                        {% include '@theme/tracker/components/pagination.html.twig' %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {% block javascripts %}
        {{ parent() }}
        <script>
            document.addEventListener('DOMContentLoaded', () => {

                /**
                 * Continue Watching navigation driven by the `cwPage` query parameter.
                 *  - Right arrow / "Show More" tile / left-swipe : load the NEXT page
                 *    and append its items (no full reload, already-loaded shows stay).
                 *  - Left arrow / right-swipe : go back to the FIRST page.
                 * Marking / undoing an episode reloads the dashboard keeping cwPage.
                 */
                const grid = document.getElementById('cw-grid');
                const showMoreTile = document.getElementById('cw-show-more-tile');

                function currentCwPage() {
                    const url = new URL(window.location.href);
                    return parseInt(url.searchParams.get('cwPage') || '1', 10);
                }

                let cwPage = currentCwPage();

                function syncUrl(page) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('cwPage', page);
                    history.replaceState(null, '', url);
                }

                async function fetchContinueWatchingFragment(page) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('cwPage', page);

                    const response = await fetch(url, {
                        headers: { 'X-Continue-Watching-Fragment': '1' },
                    });
                    const html = await response.text();

                    return new DOMParser().parseFromString(html, 'text/html');
                }

                function setShowMoreVisible(visible) {
                    if (showMoreTile) {
                        showMoreTile.classList.toggle('cw-hidden', !visible);
                    }
                }

                // Append the next page's items just BEFORE the Show More tile so the
                // tile always stays at the end of the row.
                async function loadNextPage() {
                    if (!grid) {
                        return;
                    }

                    const nextPage = cwPage + 1;
                    const doc = await fetchContinueWatchingFragment(nextPage);
                    const newGrid = doc.querySelector('#cw-grid');
                    if (!newGrid) {
                        return;
                    }

                    const newItems = newGrid.querySelectorAll('.cw-item');
                    newItems.forEach(item => {
                        if (showMoreTile) {
                            grid.insertBefore(item, showMoreTile);
                        } else {
                            grid.appendChild(item);
                        }
                    });

                    cwPage = nextPage;
                    syncUrl(cwPage);

                    // Server reports no further pages -> hide the tile.
                    const hasMore = !!doc.querySelector('.cw-show-more-tile:not(.cw-hidden)');
                    setShowMoreVisible(hasMore);

                    attachEvents();
                }

                // Go back to the FIRST page: replace the grid contents with page 1.
                async function goToFirstPage() {
                    if (!grid || cwPage <= 1) {
                        return;
                    }

                    const doc = await fetchContinueWatchingFragment(1);
                    const newGrid = doc.querySelector('#cw-grid');
                    if (!newGrid) {
                        return;
                    }

                    grid.querySelectorAll('.cw-item').forEach(el => el.remove());

                    newGrid.querySelectorAll('.cw-item').forEach(item => {
                        if (showMoreTile) {
                            grid.insertBefore(item, showMoreTile);
                        } else {
                            grid.appendChild(item);
                        }
                    });

                    cwPage = 1;
                    syncUrl(1);

                    const hasMore = !!doc.querySelector('.cw-show-more-tile:not(.cw-hidden)');
                    setShowMoreVisible(hasMore);

                    attachEvents();
                }

                function refreshContinueWatching() {
                    const url = new URL(window.location.href);
                    url.searchParams.set('cwPage', cwPage);
                    window.location.href = url.toString();
                }

                function attachEvents() {
                    // mark episode watched
                    document.querySelectorAll('.cw-mark-watched').forEach(btn => {
                        btn.addEventListener('click', async () => {
                            const id = btn.dataset.id;
                            const season = btn.dataset.season;
                            const episode = btn.dataset.episode;

                            btn.disabled = true;
                            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i> Updating...';

                            await fetch('{{ path("app_mark_episode_watched") }}', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams({ id, season, episode })
                            });

                            refreshContinueWatching();
                        });
                    });

                    // mark entire season watched
                    document.querySelectorAll('.cw-mark-season').forEach(btn => {
                        btn.addEventListener('click', async () => {
                            const id = btn.dataset.id;
                            const season = btn.dataset.season;

                            btn.disabled = true;
                            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i> Marking...';

                            await fetch('{{ path("app_mark_season_watched") }}', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams({ id, season })
                            });

                            refreshContinueWatching();
                        });
                    });

                    // undo watched
                    document.querySelectorAll('.cw-undo-watched').forEach(btn => {
                        btn.addEventListener('click', async () => {
                            const id = btn.dataset.id;

                            btn.disabled = true;
                            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i> Reverting...';

                            await fetch('{{ path("app_undo_episode_watched") }}', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                                body: new URLSearchParams({ id })
                            });

                            refreshContinueWatching();
                        });
                    });
                }

                if (grid) grid.classList.add('show');
                attachEvents();

                const cwPrev = document.getElementById('cw-prev');
                const cwNext = document.getElementById('cw-next');

                if (cwPrev) {
                    cwPrev.addEventListener('click', goToFirstPage);
                }

                if (cwNext) {
                    cwNext.addEventListener('click', loadNextPage);
                }

                if (showMoreTile) {
                    showMoreTile.addEventListener('click', () => {
                        loadNextPage();
                        if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    });
                }

                // Touch swipe: left = next page, right = back to first page.
                if (grid) {
                    let touchStartX = 0;
                    grid.addEventListener('touchstart', (e) => {
                        touchStartX = e.changedTouches[0].screenX;
                    }, { passive: true });

                    grid.addEventListener('touchend', (e) => {
                        const diff = e.changedTouches[0].screenX - touchStartX;
                        if (Math.abs(diff) > 50) {
                            if (diff < 0) {
                                loadNextPage();
                            } else {
                                goToFirstPage();
                            }
                        }
                    }, { passive: true });
                }

                // Show More / Show Less for Anime
                const animeBtn = document.getElementById('anime-show-more');
                if (animeBtn) {
                    animeBtn.addEventListener('click', () => {
                        const extras = document.querySelectorAll('.anime-extra');
                        if (!extras.length) {
                            return;
                        }
                        const isHidden = extras[0].style.display === 'none';

                        extras.forEach(el => {
                            el.style.display = isHidden ? '' : 'none';
                        });

                        animeBtn.innerText = isHidden
                            ? 'Show Less'
                            : 'Show More (' + extras.length + ')';
                    });
                }
            });
        </script>

        <script>
            (function () {
                // Keep the Status <select> in the sidebar/filters panel in sync with
                // the current URL on load (the form submits via GET, so this is a
                // safety net for deep links / back-forward navigation).
                const params = new URLSearchParams(window.location.search);
                const status = params.get('status');

                if (status) {
                    const statusSelect = document.querySelector('select[name="status"]');
                    if (statusSelect) {
                        statusSelect.value = status;
                    }
                }
            })();
        </script>

    {% endblock %}
{% endblock %}
