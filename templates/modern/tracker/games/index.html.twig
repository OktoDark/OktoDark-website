{% extends '@theme/base.html.twig' %}

{% block body %}
    <div class="container-fluid px-4 py-4">
        <div class="row w-100 justify-content-center">
            {% include '@theme/tracker/partials/_sidebar.html.twig' %}

            <div class="col-md-9">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="h3">Games Tracker</h1>
                    <form action="{{ path('app_tracker_games_add') }}" method="POST" class="d-flex">
                        <input type="text" name="metadata_id" class="form-control form-control-sm me-2" placeholder="Metadata ID">
                        <button class="btn btn-sm btn-primary">Add Game</button>
                    </form>
                </div>

                <form action="{{ path('app_tracker_games_import_igdb') }}" method="POST" class="d-flex mb-3">
                    <input type="text" name="igdb_id" class="form-control form-control-sm me-2" placeholder="IGDB ID">
                    <button class="btn btn-sm btn-outline-info">Import from IGDB</button>
                </form>


                <table class="table table-dark table-striped align-middle">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Progress</th>
                        <th>Score</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for game in games %}
                        <tr>
                            <td>{{ game.getTitle() }}</td>
                            <td><span class="badge {{ game.getStatusClass() }}">{{ game.getStatusLabel() }}</span></td>
                            <td>{{ game.getFormattedProgress() }}</td>
                            <td>{{ game.getFormattedScore() }}</td>
                            <td class="d-flex gap-1">
                                <form action="{{ path('app_tracker_games_complete', {id: game.id}) }}" method="POST">
                                    <button class="btn btn-sm btn-success">Complete</button>
                                </form>
                                <form action="{{ path('app_tracker_games_delete', {id: game.id}) }}" method="POST">
                                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted">No games tracked yet.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
