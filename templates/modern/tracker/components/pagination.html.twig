{% if totalPages is defined and totalPages > 1 %}
    <nav aria-label="Seasons pagination" class="mt-3">
        <ul class="pagination justify-content-center">

            {# Previous #}
            <li class="page-item {{ currentPage <= 1 ? 'disabled' }}">
                <a class="page-link"
                   href="{{ currentPage > 1
                   ? path('app_tracking_dashboard', {
                       page: currentPage - 1,
                       status: currentStatus,
                       sort: currentSort,
                       search: searchQuery,
                       perPage: perPage
                   })
                   : '#' }}">
                    ‹
                </a>
            </li>

            {# Pages #}
            {% for page in 1..totalPages %}
                <li class="page-item {{ page == currentPage ? 'active' }}">
                    <a class="page-link"
                       href="{{ path('app_tracking_dashboard', {
                           page: page,
                           status: currentStatus,
                           sort: currentSort,
                           search: searchQuery,
                           perPage: perPage
                       }) }}">
                        {{ page }}
                    </a>
                </li>
            {% endfor %}

            {# Next #}
            <li class="page-item {{ currentPage >= totalPages ? 'disabled' }}">
                <a class="page-link"
                   href="{{ currentPage < totalPages
                   ? path('app_tracking_dashboard', {
                       page: currentPage + 1,
                       status: currentStatus,
                       sort: currentSort,
                       search: searchQuery,
                       perPage: perPage
                   })
                   : '#' }}">
                    ›
                </a>
            </li>

        </ul>
    </nav>
{% endif %}
