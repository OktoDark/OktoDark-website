{% extends '@theme/base.html.twig' %}

{% block title %}{{ 'login.title'|trans({}, 'login') }}{% endblock %}

{% block body_id 'login' %}

{% block main %}

    <!-- PAGE TITLE SECTION -->
    <section class="section section-page-title bg-default text-center py-5">
        <div class="container">
            <h2 class="display-5 fw-bold">{{ 'login.title'|trans({}, 'login') }}</h2>
            <p class="lead text-muted mt-2">{{ 'login.subtitle'|trans({}, 'login') }}</p>
        </div>
    </section>

    <!-- AUTH WRAPPER -->
    <div class="od-auth-wrapper">
        <div class="od-auth-card">

            <h1 class="od-auth-title">{{ 'login.verify_title'|trans({}, 'login') }}</h1>

            <p class="od-auth-subtitle">
                {{ 'login.verify_subtitle'|trans({'%email%': user.email}, 'login') }}
            </p>

            <!-- ERROR MESSAGES -->
            {% for message in app.flashes('error') %}
                <div class="od-alert od-alert-error">{{ message }}</div>
            {% endfor %}

            <!-- MAIN VERIFY FORM -->
            <form method="post" action="{{ path('login_2fa_verify') }}" class="od-form">

                <div class="od-form-group">
                    <label for="code" class="od-label">{{ 'login.code_label'|trans({}, 'login') }}</label>
                    <input type="text"
                           id="code"
                           name="code"
                           maxlength="6"
                           autofocus
                           class="od-input"
                           placeholder="{{ 'login.code_placeholder'|trans({}, 'login') }}">
                </div>

                <div class="od-form-check">
                    <input type="checkbox" id="trust_device" name="trust_device" value="1">
                    <label for="trust_device">{{ 'login.trust_device'|trans({}, 'login') }}</label>
                </div>

                <button class="od-btn od-btn-primary w-100" type="submit">
                    {{ 'login.continue_btn'|trans({}, 'login') }}
                </button>
            </form>

            <!-- RESEND CODE -->
            <form method="post" action="{{ path('login_2fa_resend') }}" class="od-resend">
                <p class="small text-muted mb-1">{{ 'login.resend_code'|trans({}, 'login') }}</p>
                <button class="od-btn-link">{{ 'login.resend_btn'|trans({}, 'login') }}</button>
            </form>

        </div>
    </div>

{% endblock %}