{
  "name": "oktodark/website",
  "type": "project",
  "description": "OktoDark Studios Main Website",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "proprietary",
  "authors": [
    {
      "name": "Razvan George H. (Viruzzz)",
      "email": "contact@oktodark.com"
    }
  ],
  "require": {
    "php": ">=8.4",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "beberlei/doctrineextensions": "^1.5",
    "doctrine/dbal": "^4.4",
    "doctrine/doctrine-bundle": "^3.2",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.6",
    "erusev/parsedown": "^1.8",
    "geoip2/geoip2": "^3.3",
    "paragonie/sodium_compat": "dev-master",
    "patreon/patreon": "dev-master",
    "pentatrion/vite-bundle": "^8.2",
    "symfony/asset": "^8.0",
    "symfony/console": "^8.0",
    "symfony/discord-notifier": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/expression-language": "^8.0",
    "symfony/flex": "^2.10",
    "symfony/form": "^8.0",
    "symfony/framework-bundle": "^8.0",
    "symfony/html-sanitizer": "^8.0",
    "symfony/intl": "^8.0",
    "symfony/mailer": "^8.0",
    "symfony/messenger": "^8.0",
    "symfony/monolog-bundle": "^4.0",
    "symfony/notifier": "^8.0",
    "symfony/polyfill-intl-messageformatter": "^1.33",
    "symfony/rate-limiter": "^8.0",
    "symfony/runtime": "^8.0",
    "symfony/security-bundle": "^8.0",
    "symfony/security-csrf": "^8.0",
    "symfony/string": "^8.0",
    "symfony/translation": "^8.0",
    "symfony/twig-bundle": "^8.0",
    "symfony/validator": "^8.0",
    "symfony/yaml": "^8.0",
    "symfonycasts/reset-password-bundle": "^1.25",
    "symfonycasts/verify-email-bundle": "^1.18",
    "twig/extra-bundle": "*",
    "twig/intl-extra": "^3.24",
    "twig/markdown-extra": "*",
    "twig/twig": "^3.24"
  },
  "require-dev": {
    "dama/doctrine-test-bundle": "^8.6",
    "doctrine/doctrine-fixtures-bundle": "^4.3",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpunit/phpunit": "^12.5",

    "symfony/browser-kit": "^8.0",
    "symfony/css-selector": "^8.0",
    "symfony/debug-bundle": "^8.0",
    "symfony/maker-bundle": "^1.67",
    "symfony/stopwatch": "^8.0",
    "symfony/web-profiler-bundle": "^8.0"
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": "*",
    "symfony/polyfill-php84": "*"
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "platform": {
      "php": "8.4.0"
    },
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "^8.0"
    }
  }
}
